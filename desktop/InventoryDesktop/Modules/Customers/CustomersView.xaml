<UserControl x:Class="InventoryDesktop.Modules.Customers.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="#FFFFFF"
                BorderBrush="#E1E7F3"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="CLIENTES" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="{Binding CountLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Clientes" FontSize="25" FontWeight="Black" Margin="0,9,0,0" />
                    <TextBlock Text="Gestiona clientes, documentos, contacto e historial reciente de ventas POS."
                               Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="Actualizar" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Refresh_Click" />
                    <Button Content="+ Nuevo cliente"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanCreate}"
                            ToolTip="Requiere permiso para crear clientes."
                            Click="NewCustomer_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Buscar" Style="{StaticResource FilterLabelStyle}" />
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" VerticalContentAlignment="Center" ToolTip="Buscar por nombre, documento, teléfono o correo" />
                </StackPanel>

                <CheckBox Grid.Column="1"
                          Content="Solo activos"
                          IsChecked="{Binding ActiveOnly}"
                          VerticalAlignment="Bottom"
                          Margin="0,0,14,10"
                          FontWeight="SemiBold" />
                <Button Grid.Column="2" Content="Aplicar" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Bottom" Click="ApplyFilters_Click" />
                <Button Grid.Column="3" Content="Limpiar" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" VerticalAlignment="Bottom" Click="ClearFilters_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="410" />
            </Grid.ColumnDefinitions>

            <Border Padding="10" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <DataGrid x:Name="CustomersGrid"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              RowHeight="42"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding DocumentLabel}" Width="130" />
                            <DataGridTextColumn Header="CONTACTO" Binding="{Binding ContactLabel}" Width="2*" />
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TypeLabel}" Width="130" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="360"
                            Padding="18"
                            Background="#F8FAFC"
                            BorderBrush="#E1E7F3"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasNoCustomers, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="No hay clientes para mostrar" FontSize="18" FontWeight="Black" TextAlignment="Center" />
                            <TextBlock Text="Ajusta la busqueda o crea un cliente nuevo si tienes permiso."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                                <TextBlock Text="{Binding SelectedStatus}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                            </Border>
                            <TextBlock Text="{Binding SelectedDocument}" Foreground="{StaticResource MutedBrush}" FontWeight="Black" Margin="8,4,0,0" />
                        </StackPanel>

                        <TextBlock Text="{Binding SelectedName}" FontSize="23" FontWeight="Black" Margin="0,12,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedContact}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <TextBlock Text="{Binding SelectedAddress}" Foreground="#34415F" TextWrapping="Wrap" Margin="0,12,0,0" />

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Editar"
                                    Width="120"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding CanEditSelected}"
                                    ToolTip="Requiere permiso para editar clientes."
                                    Margin="0,0,8,0"
                                    Click="EditCustomer_Click" />
                            <Button Content="Desactivar"
                                    Width="130"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    IsEnabled="{Binding CanDeactivateSelected}"
                                    ToolTip="Requiere permiso para desactivar clientes. El consumidor final esta protegido."
                                    Click="DeactivateCustomer_Click" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,18,0,12" Padding="12" Background="#F8FAFC" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9">
                        <StackPanel>
                            <TextBlock Text="Historial POS" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="{Binding HistorySummaryLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />

                            <UniformGrid Columns="2" Margin="0,12,0,0">
                                <Border Padding="10" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL" Foreground="#64718C" FontSize="10" FontWeight="Black" />
                                        <TextBlock Text="{Binding HistoryTotalLabel}" FontSize="18" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="10" Background="#FFFFFF" BorderBrush="#FFD2D9" BorderThickness="1" CornerRadius="8" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="SALDO" Foreground="#64718C" FontSize="10" FontWeight="Black" />
                                        <TextBlock Text="{Binding HistoryBalanceLabel}" FontSize="18" FontWeight="Black" Foreground="#D9365C" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding RecentOrders}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              RowHeight="34"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ORDEN" Binding="{Binding OrderLabel}" Width="90" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="90" />
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="110" />
                            <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Black"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
