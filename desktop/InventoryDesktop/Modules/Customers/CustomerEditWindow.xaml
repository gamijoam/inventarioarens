<Window x:Class="InventoryDesktop.Modules.Customers.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cliente"
        Width="760"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                    <TextBlock Text="CLIENTE" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                </Border>
                <TextBlock Text="{Binding TitleText}" FontSize="28" FontWeight="Black" Margin="0,12,0,0" />
                <TextBlock Text="Registra datos fiscales y de contacto para ventas, garantías y reportes."
                           Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,0" Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="3" Margin="0,0,0,14">
                    <TextBlock Text="Nombre" FontWeight="Black" />
                    <TextBox x:Name="NameTextBox" Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" VerticalContentAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,10,14">
                    <TextBlock Text="Tipo" FontWeight="Black" />
                    <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding DocumentTypeInput}" MinHeight="42" Padding="10,0" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                    <TextBlock Text="Documento" FontWeight="Black" />
                    <TextBox Text="{Binding DocumentNumberInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" VerticalContentAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,10,14">
                    <TextBlock Text="Teléfono" FontWeight="Black" />
                    <TextBox Text="{Binding PhoneInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" VerticalContentAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                    <TextBlock Text="Correo" FontWeight="Black" />
                    <TextBox Text="{Binding EmailInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="42" VerticalContentAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,0,0,14">
                    <TextBlock Text="Dirección fiscal" FontWeight="Black" />
                    <TextBox Text="{Binding FiscalAddressInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="72" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                    <CheckBox Content="Cliente activo" IsChecked="{Binding IsActiveInput}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox Content="Consumidor final / genérico" IsChecked="{Binding IsGenericInput}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Black" TextWrapping="Wrap" Margin="0,16,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar" Width="130" Height="42" FontWeight="Black" Margin="0,0,10,0" Click="Cancel_Click" />
            <Button Content="Guardar cliente" Width="170" Height="42" FontWeight="Black" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
