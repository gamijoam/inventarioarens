<Window x:Class="InventoryDesktop.Modules.Sync.SyncSetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asistente de sincronizacion"
        Width="980"
        Height="720"
        MinWidth="900"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#F3F7FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="INSTALACION" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#ECFDF5" BorderBrush="#B7F0D5" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="Sin comandos" Foreground="#00896B" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Asistente de sincronizacion" FontSize="30" FontWeight="Black" Margin="0,14,0,0" />
                    <TextBlock Text="Autoriza esta computadora, selecciona la empresa y deja la sincronizacion lista para trabajar en segundo plano."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Cerrar"
                        Width="130"
                        Height="46"
                        FontWeight="Black"
                        VerticalAlignment="Top"
                        Click="Close_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="22">
                <StackPanel>
                    <TextBlock Text="1. Credenciales del gerente" FontSize="22" FontWeight="Black" />
                    <TextBlock Text="El correo se usa para encontrar las empresas disponibles. La contrasena solo autoriza la configuracion."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,6,0,16" />

                    <TextBlock Text="URL nube" FontWeight="Black" />
                    <TextBox x:Name="CloudUrlBox" Margin="0,5,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Correo" FontWeight="Black" />
                            <TextBox x:Name="EmailBox" Margin="0,5,0,12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Contrasena" FontWeight="Black" />
                            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,12" />
                        </StackPanel>
                    </Grid>

                    <Button Content="Buscar empresas"
                            Height="46"
                            FontWeight="Black"
                            Click="SearchCompanies_Click" />

                    <Border Margin="0,18,0,0"
                            Padding="16"
                            Background="#F8FAFE"
                            BorderBrush="#DCE4F2"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="2. Empresa a sincronizar" FontSize="18" FontWeight="Black" />
                            <TextBlock Text="Si el gerente tiene varias empresas, selecciona la que se va a usar en esta computadora."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,10" />
                            <ComboBox x:Name="TenantBox"
                                      DisplayMemberPath="Name"
                                      Height="42" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="3. Identificacion local" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Estos datos identifican esta computadora para evitar mezclar eventos con otros locales."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,16" />

                        <TextBlock Text="Codigo del equipo" FontWeight="Black" />
                        <TextBox x:Name="NodeCodeBox" Margin="0,5,0,12" />

                        <TextBlock Text="Nombre visible" FontWeight="Black" />
                        <TextBox x:Name="NodeNameBox" Margin="0,5,0,12" />

                        <TextBlock Text="Intervalo automatico" FontWeight="Black" />
                        <Grid Margin="0,5,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IntervalBox" Text="30" />
                            <TextBlock Grid.Column="2"
                                       Text="segundos entre cada sincronizacion automatica"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Border Padding="14"
                                Background="#ECFDF5"
                                BorderBrush="#B7F0D5"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Text="Despues de guardar, puedes sincronizar manualmente o iniciar el worker automatico. Si internet falla, el sistema sigue trabajando local."
                                       Foreground="#00896B"
                                       FontWeight="Black"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <Border Padding="12"
                                Background="#F8FAFE"
                                BorderBrush="#DCE4F2"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,12">
                            <TextBlock x:Name="MessageText"
                                       Text="Completa los pasos y configura la sincronizacion."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Black"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <Button Content="Configurar sincronizacion"
                                    Height="52"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    FontWeight="Black"
                                    Click="GenerateAndSave_Click" />
                            <Button Grid.Column="2"
                                    Content="Cerrar"
                                    Height="52"
                                    FontWeight="Black"
                                    Click="Close_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,14,0,0"
                   Text="La app guarda la configuracion solo en esta instalacion local. El token no se vuelve a mostrar en pantalla por seguridad."
                   Foreground="{StaticResource MutedBrush}"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
