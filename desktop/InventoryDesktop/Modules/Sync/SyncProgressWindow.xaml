<Window x:Class="InventoryDesktop.Modules.Sync.SyncProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sincronizando empresa"
        Width="560"
        Height="330"
        MinWidth="520"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="24">
        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="16" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                            <TextBlock Text="SYNC" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border Padding="10,5" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                            <TextBlock Text="Empresa local" Foreground="#047857" FontSize="11" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="TitleText"
                               Text="Preparando esta empresa"
                               FontSize="28"
                               FontWeight="Black"
                               Margin="0,18,0,0" />
                    <TextBlock x:Name="DetailText"
                               Text="Estamos sincronizando productos, precios, cajas y permisos para esta computadora."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <ProgressBar x:Name="Progress"
                                 Height="14"
                                 IsIndeterminate="True"
                                 Foreground="{StaticResource AccentBrush}" />
                    <TextBlock x:Name="StatusText"
                               Text="Conectando con la nube..."
                               Foreground="#51617F"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Este proceso solo prepara esta instalacion local."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Content="Cerrar"
                            Width="110"
                            Height="40"
                            FontWeight="Black"
                            Visibility="Collapsed"
                            Click="Close_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
