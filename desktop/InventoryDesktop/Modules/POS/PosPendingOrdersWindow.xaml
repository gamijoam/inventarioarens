<Window x:Class="InventoryDesktop.Modules.POS.PosPendingOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordenes POS pendientes"
        Width="1120"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="18">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                            <TextBlock Text="POS" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border Padding="10,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                            <TextBlock Text="Ordenes abiertas" Foreground="#B45309" FontSize="11" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Ordenes POS pendientes" FontSize="28" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="Revisa cobros incompletos, agrega pagos capturados y cierra la venta cuando el total quede cubierto."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Content="Actualizar"
                        Width="116"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Refresh_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Pendientes" FontSize="20" FontWeight="Black" />
                            <TextBlock x:Name="OrdersSummaryText"
                                       Text="Cargando ordenes..."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="OrdersGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="42"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#E1E7F3"
                              BorderThickness="1"
                              SelectionChanged="OrdersGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ORDEN" Binding="{Binding Id}" Width="74" />
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding CustomerLabel}" Width="*" />
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="110" />
                            <DataGridTextColumn Header="PAGADO" Binding="{Binding PaidLabel}" Width="110" />
                            <DataGridTextColumn Header="FALTA" Binding="{Binding RemainingLabel}" Width="110" />
                            <DataGridTextColumn Header="PAGOS" Binding="{Binding PaymentsLabel}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="16" Margin="14,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Cobrar faltante" FontSize="20" FontWeight="Black" />
                        <TextBlock x:Name="SelectedOrderText"
                                   Text="Selecciona una orden pendiente."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="Al cobrar el faltante como pago capturado, la orden se cierra si el total queda cubierto."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Total" FontWeight="Black" />
                                <TextBlock x:Name="TotalText" Text="USD 0.00" HorizontalAlignment="Right" FontWeight="Black" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="Pagado" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                <TextBlock x:Name="PaidText" Text="USD 0.00" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="Faltante" Foreground="#D9365C" FontWeight="Black" />
                                <TextBlock x:Name="RemainingText" Text="USD 0.00" HorizontalAlignment="Right" Foreground="#D9365C" FontSize="18" FontWeight="Black" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock Text="Metodo de pago" FontWeight="Black" />
                        <ComboBox x:Name="PaymentMethodBox"
                                  Height="38"
                                  Margin="0,6,0,0"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectionChanged="PaymentMethodBox_SelectionChanged" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Moneda" FontWeight="Black" />
                            <ComboBox x:Name="CurrencyBox" Height="38" Margin="0,6,0,0" />
                        </StackPanel>

                        <ComboBox x:Name="PaymentStatusBox" Grid.Column="1" Width="1" Height="1" Visibility="Collapsed" DisplayMemberPath="Label" />
                    </Grid>

                    <StackPanel Grid.Row="4" Margin="0,12,0,0">
                        <TextBlock Text="Monto recibido" FontWeight="Black" />
                        <TextBox x:Name="AmountBox" Height="38" Margin="0,6,0,0" FontSize="15" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Completar faltante"
                                    Width="142"
                                    Height="32"
                                    FontWeight="Black"
                                    Click="UseRemaining_Click" />
                            <Button Content="Limpiar"
                                    Width="84"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    FontWeight="Black"
                                    Click="ClearPayment_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ReferenceLabel" Text="Referencia" FontWeight="Black" Margin="0,14,0,0" />
                        <TextBox x:Name="ReferenceBox" Height="38" Margin="0,6,0,0" FontSize="15" />
                        <TextBlock x:Name="StatusText"
                                   Foreground="#D9365C"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Solo los pagos capturados cierran una orden. Los pendientes quedan como respaldo para validar despues."
                       Foreground="{StaticResource MutedBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    x:Name="CancelOrderButton"
                    Content="Cancelar orden"
                    Width="136"
                    Height="40"
                    Margin="12,0,0,0"
                    FontWeight="Black"
                    Click="CancelOrder_Click" />
            <Button Grid.Column="2"
                    Content="Cerrar"
                    Width="110"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="Close_Click" />
            <Button x:Name="SubmitPaymentButton"
                    Grid.Column="3"
                    Content="Cobrar faltante y cerrar"
                    Width="180"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="AddPayment_Click" />
        </Grid>
    </Grid>
</Window>
