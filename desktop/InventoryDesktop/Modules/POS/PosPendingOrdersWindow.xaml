<Window x:Class="InventoryDesktop.Modules.POS.PosPendingOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Ordenes POS pendientes"
        Width="1160"
        Height="740"
        MinWidth="1020"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ClockOutline"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="POS"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Padding="8,4" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                         Foreground="#B45309"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Ordenes abiertas"
                                           Foreground="#B45309"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Ordenes POS pendientes"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Revisa cobros incompletos, agrega pagos capturados y cierra la venta cuando el total quede cubierto."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Actualizar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListBulleted"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Pendientes"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="OrdersSummaryText"
                                   Text="Cargando ordenes..."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <DataGrid x:Name="OrdersGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              SelectionMode="Single"
                              RowHeight="46"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1"
                              SelectionChanged="OrdersGrid_SelectionChanged">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ORDEN" Binding="{Binding Id}" Width="74" />
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding CustomerLabel}" Width="*" />
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="110" />
                            <DataGridTextColumn Header="PAGADO" Binding="{Binding PaidLabel}" Width="110" />
                            <DataGridTextColumn Header="FALTA" Binding="{Binding RemainingLabel}" Width="110" />
                            <DataGridTextColumn Header="PAGOS" Binding="{Binding PaymentsLabel}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="16,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardClockOutline"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="20" Height="20"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Cobrar faltante"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="SelectedOrderText"
                                   Text="Selecciona una orden pendiente."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Al cobrar el faltante como pago capturado, la orden se cierra si el total queda cubierto."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,12,0,0">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CashMultiple"
                                                                 Foreground="{StaticResource MutedBrush}"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Total"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="TotalText"
                                               Text="USD 0.00"
                                               HorizontalAlignment="Right"
                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="{StaticResource InkBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircle"
                                                                 Foreground="#047857"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Pagado"
                                                   Foreground="#047857"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="PaidText"
                                               Text="USD 0.00"
                                               HorizontalAlignment="Right"
                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#047857"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AlertCircle"
                                                                 Foreground="#BE123C"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Faltante"
                                                   Foreground="#BE123C"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="RemainingText"
                                               Text="USD 0.00"
                                               HorizontalAlignment="Right"
                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#BE123C"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CreditCardOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Metodo de pago"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="PaymentMethodBox"
                                      Height="44"
                                      FontSize="13"
                                      Margin="0,4,0,0"
                                      DisplayMemberPath="DisplayLabel"
                                      SelectionChanged="PaymentMethodBox_SelectionChanged" />
                        </StackPanel>

                        <Grid Margin="0,12,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CurrencyUsd"
                                                             Foreground="{StaticResource MutedBrush}"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Moneda"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <ComboBox x:Name="CurrencyBox"
                                          Height="44"
                                          FontSize="13"
                                          Margin="0,4,0,0" />
                            </StackPanel>

                            <ComboBox x:Name="PaymentStatusBox"
                                      Grid.Column="1"
                                      Width="1" Height="1"
                                      Visibility="Collapsed"
                                      DisplayMemberPath="Label" />
                        </Grid>

                        <StackPanel Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashMultiple"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Monto recibido"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="AmountBox"
                                     Height="44"
                                     FontSize="16"
                                     FontFamily="Consolas, Cascadia Mono, Courier New"
                                     FontWeight="Bold"
                                     Padding="10,0"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     Margin="0,4,0,0" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Height="38"
                                        Margin="0,0,4,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        Foreground="{StaticResource InkBrush}"
                                        FontWeight="SemiBold"
                                        FontSize="12"
                                        Click="UseRemaining_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Completar"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Height="38"
                                        Margin="4,0,0,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        Foreground="{StaticResource InkBrush}"
                                        FontWeight="SemiBold"
                                        FontSize="12"
                                        Click="ClearPayment_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CloseCircleOutline"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Limpiar"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="NoteTextOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock x:Name="ReferenceLabel"
                                           Text="Referencia"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="ReferenceBox"
                                     Height="44"
                                     FontSize="13"
                                     Padding="10,0"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     Margin="0,4,0,0" />
                        </StackPanel>

                        <Border Background="#FFF1F2"
                                BorderBrush="#FECDD3"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                         Foreground="#BE123C"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock x:Name="StatusText"
                                           Foreground="#BE123C"
                                           FontWeight="Medium"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Solo los pagos capturados cierran una orden. Los pendientes quedan como respaldo."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="Light"
                               FontSize="11"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="CancelOrderButton"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFF1F2"
                        BorderBrush="#FECDD3"
                        Foreground="#BE123C"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="CancelOrder_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloseCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar orden"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cerrar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        x:Name="SubmitPaymentButton"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="AddPayment_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CreditCardCheckOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cobrar y cerrar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

