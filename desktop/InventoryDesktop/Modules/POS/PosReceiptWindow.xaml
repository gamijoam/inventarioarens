<Window x:Class="InventoryDesktop.Modules.POS.PosReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Venta confirmada"
        Width="1020"
        Height="720"
        MinWidth="860"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle"
                                                         Foreground="#047857"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="VENTA CONFIRMADA"
                                           Foreground="#047857"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Padding="8,4" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                         Foreground="#475569"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock x:Name="OrderBadgeText"
                                           Text="Orden POS"
                                           Foreground="#475569"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Recibo de venta"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ReceiptContextText"
                                   Text="Venta cerrada correctamente."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#F0FDF4"
                        BorderBrush="#A7F3D0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20,14"
                        Margin="12,0,0,0">
                    <StackPanel MinWidth="240">
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CurrencyUsd"
                                                         Foreground="#047857"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Total USD"
                                           Foreground="#047857"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="TotalUsdText"
                                       Text="USD 0.00"
                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#047857"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Equivalente Bs"
                                       Foreground="#475569"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="TotalVesText"
                                       Text="Bs 0.00"
                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                       HorizontalAlignment="Right"
                                       Foreground="#475569"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Pagado"
                                       Foreground="#10B981"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="PaidText"
                                       Text="USD 0.00"
                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                       HorizontalAlignment="Right"
                                       Foreground="#10B981"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Vuelto"
                                       Foreground="#1D4ED8"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="ChangeText"
                                       Text="USD 0.00"
                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                       HorizontalAlignment="Right"
                                       Foreground="#1D4ED8"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListBulleted"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Productos vendidos"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Resumen de las lineas confirmadas por el servidor."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <DataGrid x:Name="ItemsGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              RowHeight="76"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{StaticResource InkBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Sku}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11"
                                                       FontWeight="Medium" />
                                            <WrapPanel Margin="0,3,0,0">
                                                <TextBlock Text="{Binding ControlLabel}"
                                                           Foreground="{StaticResource AccentStrongBrush}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding SerialLabel}"
                                                           Foreground="#047857"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="CANT." Binding="{Binding QuantityLabel}" Width="70" />
                            <DataGridTextColumn Header="PRECIO" Binding="{Binding UnitPriceLabel}" Width="110" />
                            <DataGridTextColumn Header="DESC." Binding="{Binding DiscountLabel}" Width="130" />
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="16,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Datos de la venta"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <materialDesign:PackIcon Kind="AccountOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Top"
                                                     Margin="0,4,0,0" />
                            <TextBlock x:Name="CustomerText"
                                       Text="Cliente: Consumidor final"
                                       Foreground="{StaticResource InkBrush}"
                                       FontWeight="Medium"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <materialDesign:PackIcon Kind="TagMultipleOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Top"
                                                     Margin="0,4,0,0" />
                            <TextBlock x:Name="PriceListText"
                                       Text="Lista: Precio base"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Medium"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <materialDesign:PackIcon Kind="CashRegister"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Top"
                                                     Margin="0,4,0,0" />
                            <TextBlock x:Name="CashRegisterText"
                                       Text="Caja: -"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Medium"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardCheckOutline"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Pagos recibidos"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid x:Name="PaymentsGrid"
                              Grid.Row="2"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              RowHeight="42"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ‰TODO" Binding="{Binding MethodName}" Width="*" />
                            <DataGridTextColumn Header="MONTO" Binding="{Binding AmountLabel}" Width="115" />
                            <DataGridTextColumn Header="EQUIV." Binding="{Binding EquivalentLabel}" Width="110" />
                            <DataGridTextColumn Header="REF." Binding="{Binding ReferenceLabel}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Impresion, PDF y numeracion fiscal quedan para la siguiente fase del recibo."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="Light"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="20,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        IsDefault="True"
                        IsCancel="True"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cerrar recibo"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

