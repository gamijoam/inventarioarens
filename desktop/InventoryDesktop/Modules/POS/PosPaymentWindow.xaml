<Window x:Class="InventoryDesktop.Modules.POS.PosPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobrar venta"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="700"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="22" ShadowDepth="3" Opacity="0.10" Color="#0F172A" />

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="SoftTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="BorderBrush" Value="#CAD6EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SoftComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="BorderBrush" Value="#CAD6EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CAD6EA" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorder}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="11,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="12">
                            <TextBlock Text="POS" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border x:Name="RestrictionBadge" Padding="11,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="12" Margin="8,0,0,0">
                            <TextBlock x:Name="RestrictionText" Text="Lista abierta" Foreground="#B45309" FontSize="11" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Cobrar venta" FontSize="28" FontWeight="Black" Foreground="#08142D" Margin="0,10,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="$" Foreground="#64748B" FontWeight="Black" Margin="0,0,6,0" />
                        <TextBlock x:Name="ContextText"
                                   Text="Precio base - Caja Mostrador VAL - Turno #1. Completa el cobro."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl x:Name="OrderItemsList" Visibility="Collapsed" />
                    <TextBlock x:Name="TotalUsdText" Visibility="Collapsed" />
                    <TextBlock x:Name="TotalVesText" Visibility="Collapsed" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Total a cobrar" Foreground="#64748B" FontWeight="Black" HorizontalAlignment="Right" />
                    <TextBlock x:Name="TotalDueText" Text="USD 0.00" Foreground="{StaticResource AccentStrongBrush}" FontSize="28" FontWeight="Black" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="455" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recibir pago" FontSize="20" FontWeight="Black" Foreground="#08142D" />

                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                        <TextBlock Text="Atajos" Style="{StaticResource FieldLabel}" />
                        <WrapPanel x:Name="QuickMethodsPanel" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="132" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Forma de pago" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="PaymentMethodBox"
                                      Style="{StaticResource SoftComboBox}"
                                      DisplayMemberPath="DisplayLabel"
                                      SelectionChanged="PaymentMethodBox_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Moneda" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="CurrencyBox"
                                      Style="{StaticResource SoftComboBox}"
                                      SelectionChanged="CurrencyBox_SelectionChanged" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="PaymentRatePanel" Grid.Row="3" Margin="0,7,0,0" Visibility="Collapsed">
                        <TextBlock Text="Tasa de cobro en Bs" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="PaymentRateBox"
                                  Style="{StaticResource SoftComboBox}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectionChanged="PaymentRateBox_SelectionChanged" />
                        <TextBlock x:Name="PaymentRateHintText"
                                   Text="Esta tasa se usa para convertir este pago a USD."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,8,0,0">
                        <TextBlock Text="Monto" Style="{StaticResource FieldLabel}" />
                        <Border BorderBrush="#CAD6EA" BorderThickness="1" CornerRadius="9" Background="#FFFFFF">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="54" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#F1F5F9" CornerRadius="9,0,0,9" BorderBrush="#CAD6EA" BorderThickness="0,0,1,0">
                                    <TextBlock Text="$ / Bs" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#475569" FontWeight="Black" />
                                </Border>
                                <TextBox x:Name="AmountBox"
                                         Grid.Column="1"
                                         Height="42"
                                         BorderThickness="0"
                                         Padding="12,0"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         PreviewTextInput="DecimalInput_PreviewTextInput"
                                         TextChanged="AmountBox_TextChanged"
                                         KeyDown="AmountBox_KeyDown" />
                            </Grid>
                        </Border>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Saldo exacto" Style="{StaticResource SecondaryButton}" Click="UseRemaining_Click" />
                            <Button Grid.Column="1" Content="Limpiar" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="ClearPaymentForm_Click" />
                            <Button Grid.Column="2" Content="+ Agregar" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="AddPayment_Click" />
                        </Grid>

                        <TextBlock x:Name="PaymentPreviewText"
                                   Text="Escribe el monto o usa Saldo exacto."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,7,0,0">
                        <TextBlock x:Name="ReferenceLabel" Text="Referencia" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="ReferenceBox"
                                 Style="{StaticResource SoftTextBox}"
                                 KeyDown="ReferenceBox_KeyDown" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,5,0,0">
                        <StackPanel Visibility="Collapsed">
                            <TextBlock Text="Registro" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="PaymentStatusBox"
                                      Style="{StaticResource SoftComboBox}"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="PaymentStatusBox_SelectionChanged" />
                        </StackPanel>
                        <TextBlock x:Name="FormHelpText"
                                   Text="El pago queda listo al agregarlo."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Bottom" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="14,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Pagos agregados" FontSize="20" FontWeight="Black" Foreground="#08142D" />
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="Total a Cobrar:" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                                <TextBlock x:Name="TotalDueInlineText" Text="USD 0.00" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="PaymentsSummaryText"
                                       Text="Sin pagos registrados."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Eliminar pago"
                                Width="118"
                                Height="32"
                                Style="{StaticResource SecondaryButton}"
                                Click="RemovePayment_Click" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,12">
                        <DataGrid x:Name="PaymentsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="30"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderBrush="#E1E7F3"
                                  BorderThickness="1"
                                  Background="#FFFFFF">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="FORMA" Binding="{Binding MethodName}" Width="145" />
                                <DataGridTextColumn Header="RECIBIDO" Binding="{Binding AmountLabel}" Width="130" />
                                <DataGridTextColumn Header="EQUIV." Binding="{Binding EquivalentLabel}" Width="130" />
                                <DataGridTextColumn Header="REF." Binding="{Binding ReferenceLabel}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border x:Name="EmptyPaymentsPanel"
                                Background="#FBFDFF"
                                BorderBrush="#E6ECF5"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="58" Height="42" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="8" Background="#FFFFFF">
                                    <Grid>
                                        <Border Height="12" VerticalAlignment="Bottom" Background="#EEF2F7" CornerRadius="0,0,7,7" />
                                        <TextBlock Text="$" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="Black" Foreground="#94A3B8" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="Parece que no hay pagos registrados"
                                           FontWeight="Black"
                                           Foreground="#334155"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Agrega un pago para completar la venta."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#F8FAFC" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="9">
                            <StackPanel>
                                <TextBlock Text="Pagado" Foreground="#64748B" FontWeight="Black" FontSize="11" />
                                <TextBlock x:Name="PaidText" Text="USD 0.00" Foreground="#0F172A" FontSize="16" FontWeight="Black" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFF7F9" BorderBrush="#FBCFE0" BorderThickness="1" CornerRadius="10" Padding="9" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Falta" Foreground="#BE123C" FontWeight="Black" FontSize="11" />
                                <TextBlock x:Name="RemainingText" Text="USD 0.00" Foreground="#D9365C" FontSize="16" FontWeight="Black" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="10" Padding="9" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Vuelto" Foreground="#047857" FontWeight="Black" FontSize="11" />
                                <TextBlock x:Name="ChangeText" Text="USD 0.00" Foreground="#058561" FontSize="16" FontWeight="Black" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="StatusText"
                                   Grid.ColumnSpan="3"
                                   Foreground="#D9365C"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Bottom"
                                   Margin="0,58,0,0" />
                    </Grid>

                    <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="7" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Enter agrega pago · F12 confirma · Esc cancela."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    x:Name="CancelButton"
                                    Content="Cancelar"
                                    Width="108"
                                    Height="32"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="Cancel_Click" />
                            <Button Grid.Column="2"
                                    x:Name="ConfirmButton"
                                    Content="✓ Confirmar venta"
                                    Width="156"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="Confirm_Click" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
