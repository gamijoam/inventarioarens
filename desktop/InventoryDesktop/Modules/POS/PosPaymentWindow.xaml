<Window x:Class="InventoryDesktop.Modules.POS.PosPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Cobrar venta"
        Width="1180"
        Height="780"
        MinWidth="1040"
        MinHeight="700"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="PayComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PointOfSale"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="POS"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="RestrictionBadge"
                                Padding="8,4"
                                Background="#FFF7ED"
                                BorderBrush="#FED7AA"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                         Foreground="#B45309"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock x:Name="RestrictionText"
                                           Text="Lista abierta"
                                           Foreground="#B45309"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Cobrar venta"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,10,0,0" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ContextText"
                                   Text="Precio base - Caja Mostrador VAL - Turno #1. Completa el cobro."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsControl x:Name="OrderItemsList" Visibility="Collapsed" />
                    <TextBlock x:Name="TotalUsdText" Visibility="Collapsed" />
                    <TextBlock x:Name="TotalVesText" Visibility="Collapsed" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#F0FDF4"
                        BorderBrush="#A7F3D0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20,14"
                        Margin="16,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashMultiple"
                                                     Foreground="#047857"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="TOTAL A COBRAR"
                                       Foreground="#047857"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="TotalDueText"
                                   Text="USD 0.00"
                                   Foreground="#047857"
                                   FontFamily="Consolas, Cascadia Mono, Courier New"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,16,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashFast"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="20" Height="20"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Recibir pago"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Flash"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="ATAJOS RAPIDOS"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <WrapPanel x:Name="QuickMethodsPanel" Margin="0,8,0,0" />
                        </StackPanel>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CreditCardOutline"
                                                             Foreground="{StaticResource MutedBrush}"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Forma de pago"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <ComboBox x:Name="PaymentMethodBox"
                                          DisplayMemberPath="DisplayLabel"
                                          Style="{StaticResource PayComboBoxStyle}"
                                          Margin="0,4,0,0"
                                          SelectionChanged="PaymentMethodBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CurrencyUsd"
                                                             Foreground="{StaticResource MutedBrush}"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Moneda"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <ComboBox x:Name="CurrencyBox"
                                          Style="{StaticResource PayComboBoxStyle}"
                                          Margin="0,4,0,0"
                                          SelectionChanged="CurrencyBox_SelectionChanged" />
                            </StackPanel>
                        </Grid>

                        <StackPanel x:Name="PaymentRatePanel" Margin="0,12,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="SwapHorizontal"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Tasa de cobro en Bs"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="PaymentRateBox"
                                      DisplayMemberPath="DisplayLabel"
                                      Style="{StaticResource PayComboBoxStyle}"
                                      Margin="0,4,0,0"
                                      SelectionChanged="PaymentRateBox_SelectionChanged" />
                            <TextBlock x:Name="PaymentRateHintText"
                                       Text="Esta tasa se usa para convertir este pago a USD."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="Light"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashMultiple"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Monto"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#FFFFFF" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#F1F5F9" CornerRadius="8,0,0,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                        <TextBlock Text="$ / Bs"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#475569"
                                                   FontWeight="Bold"
                                                   FontSize="12" />
                                    </Border>
                                    <TextBox x:Name="AmountBox"
                                             Grid.Column="1"
                                             Height="44"
                                             BorderThickness="0"
                                             Padding="12,0"
                                             FontSize="18"
                                             FontFamily="Consolas, Cascadia Mono, Courier New"
                                             FontWeight="Bold"
                                             VerticalContentAlignment="Center"
                                             PreviewTextInput="DecimalInput_PreviewTextInput"
                                             TextChanged="AmountBox_TextChanged"
                                             KeyDown="AmountBox_KeyDown" />
                                </Grid>
                            </Border>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Height="44"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        Foreground="{StaticResource InkBrush}"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        Click="UseRemaining_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                 Width="14" Height="14"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Saldo exacto"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Height="44"
                                        Margin="8,0,0,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        Foreground="{StaticResource InkBrush}"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        Click="ClearPaymentForm_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CloseCircleOutline"
                                                                 Width="14" Height="14"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Limpiar"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Height="44"
                                        Margin="8,0,0,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#4D35FF"
                                        BorderBrush="#4D35FF"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Click="AddPayment_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                                 Width="14" Height="14"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Agregar"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock x:Name="PaymentPreviewText"
                                       Text="Escribe el monto o usa Saldo exacto."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="Light"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="NoteTextOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock x:Name="ReferenceLabel"
                                           Text="Referencia"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="ReferenceBox"
                                     Height="44"
                                     FontSize="13"
                                     Padding="10,0"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     Margin="0,4,0,0"
                                     KeyDown="ReferenceBox_KeyDown" />
                        </StackPanel>

                        <StackPanel Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Registro"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="PaymentStatusBox"
                                      DisplayMemberPath="Label"
                                      Style="{StaticResource PayComboBoxStyle}"
                                      Margin="0,4,0,0"
                                      SelectionChanged="PaymentStatusBox_SelectionChanged" />
                        </StackPanel>

                        <TextBlock x:Name="FormHelpText"
                                   Text="El pago queda listo al agregarlo."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="Light"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FormatListBulleted"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         Width="20" Height="20"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Pagos agregados"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Total a Cobrar:"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Medium"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="TotalDueInlineText"
                                           Text="USD 0.00"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="PaymentsSummaryText"
                                       Text="Sin pagos registrados."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Height="38"
                                Padding="14,0"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Background="#FFFFFF"
                                BorderBrush="#CBD5E1"
                                Foreground="#D72F5E"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Click="RemovePayment_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TrashCanOutline"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Eliminar"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,16">
                        <DataGrid x:Name="PaymentsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="42"
                                  AlternationCount="2"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderBrush="#E2E8F0"
                                  BorderThickness="1">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="12,10" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Foreground" Value="#475569" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="12,8" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#FFFFFF" />
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F8FAFC" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="FORMA" Binding="{Binding MethodName}" Width="160" />
                                <DataGridTextColumn Header="RECIBIDO" Binding="{Binding AmountLabel}" Width="140" />
                                <DataGridTextColumn Header="EQUIV." Binding="{Binding EquivalentLabel}" Width="140" />
                                <DataGridTextColumn Header="REF." Binding="{Binding ReferenceLabel}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border x:Name="EmptyPaymentsPanel"
                                Background="#FBFDFF">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CreditCardOutline"
                                                         Foreground="#CBD5E1"
                                                         Width="56" Height="56"
                                                         HorizontalAlignment="Center" />
                                <TextBlock Text="Parece que no hay pagos registrados"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Agrega un pago para completar la venta."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle"
                                                             Foreground="#047857"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Pagado"
                                               Foreground="#047857"
                                               FontWeight="Bold"
                                               FontSize="10"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="PaidText"
                                           Text="USD 0.00"
                                           Foreground="#047857"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFF1F2" BorderBrush="#FECDD3" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="8,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircle"
                                                             Foreground="#BE123C"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Falta"
                                               Foreground="#BE123C"
                                               FontWeight="Bold"
                                               FontSize="10"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="RemainingText"
                                           Text="USD 0.00"
                                           Foreground="#BE123C"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="8,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRefund"
                                                             Foreground="#1D4ED8"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Vuelto"
                                               Foreground="#1D4ED8"
                                               FontWeight="Bold"
                                               FontSize="10"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="ChangeText"
                                           Text="USD 0.00"
                                           Foreground="#1D4ED8"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="StatusText"
                                   Grid.ColumnSpan="3"
                                   Foreground="#D72F5E"
                                   FontWeight="Medium"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,1,0,0"
                            Margin="-20,16,-20,-20"
                            Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="KeyboardOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Enter agrega pago · F12 confirma · Esc cancela"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="Light"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="CancelButton"
                                    Height="42"
                                    Padding="18,0"
                                    Margin="0,0,8,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#CBD5E1"
                                    Foreground="{StaticResource InkBrush}"
                                    FontWeight="SemiBold"
                                    FontSize="13"
                                    Click="Cancel_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close"
                                                             Width="14" Height="14"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Cancelar"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    x:Name="ConfirmButton"
                                    Height="48"
                                    Padding="20,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="#27AE60"
                                    BorderBrush="#27AE60"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Click="Confirm_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CreditCardCheckOutline"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Confirmar venta"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
