<Window x:Class="InventoryDesktop.Modules.POS.PosDiscountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descuento de producto"
        Width="620"
        Height="600"
        MinWidth="600"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel>
                <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                    <TextBlock Text="DESCUENTO" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                </Border>
                <TextBlock x:Name="ProductNameText" Text="Producto" FontSize="24" FontWeight="Black" Margin="0,12,0,0" TextWrapping="Wrap" />
                <TextBlock x:Name="ProductTotalText" Text="Total original" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,16,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock Text="Configura el descuento" FontSize="18" FontWeight="Black" />
                    <TextBlock Text="El descuento se aplica solo a este producto del carrito y quedará guardado con motivo de auditoría."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,8,0">
                    <TextBlock Text="Tipo de descuento" FontWeight="Black" />
                    <ComboBox x:Name="DiscountTypeBox" Height="40" Margin="0,6,0,0" SelectionChanged="DiscountTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Porcentaje (%)" Tag="percent" />
                        <ComboBoxItem Content="Monto fijo" Tag="fixed" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,16,0,0">
                    <TextBlock x:Name="ValueLabel" Text="Valor" FontWeight="Black" />
                    <TextBox x:Name="ValueBox"
                             Height="40"
                             Margin="0,6,0,0"
                             FontSize="16"
                             PreviewTextInput="DecimalInput_PreviewTextInput"
                             TextChanged="ValueBox_TextChanged" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,16,0,0">
                    <TextBlock Text="Motivo del descuento" FontWeight="Black" />
                    <TextBox x:Name="ReasonBox"
                             Height="78"
                             Margin="0,6,0,0"
                             FontSize="14"
                             TextWrapping="Wrap"
                             AcceptsReturn="True" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="PreviewText" Text="Indica el descuento y el motivo." Foreground="#9A3412" FontWeight="Black" TextWrapping="Wrap" />
                <TextBlock x:Name="ErrorText" Foreground="#D9365C" FontWeight="Black" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Quitar descuento" Width="146" Height="44" FontWeight="Black" Click="Clear_Click" />
            <Button Grid.Column="2" Content="Cancelar" Width="116" Height="44" Margin="10,0,0,0" FontWeight="Black" Click="Cancel_Click" />
            <Button Grid.Column="3" Content="Aplicar descuento" Width="154" Height="44" Margin="10,0,0,0" FontWeight="Black" Background="{StaticResource AccentBrush}" Foreground="White" Click="Apply_Click" />
        </Grid>
    </Grid>
</Window>
