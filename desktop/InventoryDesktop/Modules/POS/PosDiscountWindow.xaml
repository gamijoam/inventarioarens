<Window x:Class="InventoryDesktop.Modules.POS.PosDiscountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Descuento de producto"
        Width="660"
        Height="680"
        MinWidth="620"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TagOutline"
                                                         Foreground="#B45309"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="DESCUENTO"
                                           Foreground="#B45309"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ProductNameText"
                               Text="Producto"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ProductTotalText"
                                   Text="Total original"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CogOutline"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Width="18" Height="18"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Configura el descuento"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Se aplica solo a este producto del carrito y queda con motivo de auditoria."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListBulleted"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Tipo de descuento"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox x:Name="DiscountTypeBox"
                                  Height="44"
                                  FontSize="13"
                                  Margin="0,4,0,0"
                                  SelectionChanged="DiscountTypeBox_SelectionChanged">
                            <ComboBoxItem Content="Porcentaje (%)" Tag="percent" />
                            <ComboBoxItem Content="Monto fijo" Tag="fixed" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Numeric"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="ValueLabel"
                                       Text="Valor"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="ValueBox"
                                 Height="44"
                                 FontSize="16"
                                 FontFamily="Consolas, Cascadia Mono, Courier New"
                                 FontWeight="Bold"
                                 Padding="10,0"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 Margin="0,4,0,0"
                                 PreviewTextInput="DecimalInput_PreviewTextInput"
                                 TextChanged="ValueBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="NoteTextOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Motivo del descuento"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="ReasonBox"
                             Height="92"
                             FontSize="13"
                             Padding="10,8"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             TextWrapping="Wrap"
                             Margin="0,4,0,0"
                             AcceptsReturn="True" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFF7ED"
                BorderBrush="#FDBA74"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="EyeOutline"
                                             Foreground="#9A3412"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock x:Name="PreviewText"
                               Text="Indica el descuento y el motivo."
                               Foreground="#9A3412"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Foreground="#D72F5E"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="#D72F5E"
                               FontWeight="Medium"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFF1F2"
                        BorderBrush="#FECDD3"
                        Foreground="#BE123C"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Clear_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TagOffOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Quitar descuento"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Apply_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Aplicar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

