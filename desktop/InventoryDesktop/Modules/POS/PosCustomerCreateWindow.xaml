<Window x:Class="InventoryDesktop.Modules.POS.PosCustomerCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo cliente"
        Width="560"
        Height="620"
        MinWidth="520"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel>
                <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                    <TextBlock Text="CLIENTE" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                </Border>
                <TextBlock Text="Nuevo cliente" FontSize="26" FontWeight="Black" Margin="0,12,0,0" />
                <TextBlock Text="Registra el cliente y quedará seleccionado automáticamente para esta venta."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,16,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Nombre o razón social" FontWeight="Black" />
                    <TextBox x:Name="NameBox" Height="40" Margin="0,6,0,0" FontSize="15" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="128" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tipo" FontWeight="Black" />
                        <ComboBox x:Name="DocumentTypeBox" Height="40" Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Documento" FontWeight="Black" />
                        <TextBox x:Name="DocumentNumberBox" Height="40" Margin="0,6,0,0" FontSize="15" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <TextBlock Text="Teléfono" FontWeight="Black" />
                    <TextBox x:Name="PhoneBox" Height="40" Margin="0,6,0,0" FontSize="15" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                    <TextBlock Text="Correo" FontWeight="Black" />
                    <TextBox x:Name="EmailBox" Height="40" Margin="0,6,0,0" FontSize="15" />
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,14,0,0">
                    <TextBlock Text="Dirección fiscal" FontWeight="Black" />
                    <TextBox x:Name="FiscalAddressBox"
                             Height="72"
                             Margin="0,6,0,0"
                             FontSize="15"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           Grid.Row="5"
                           Foreground="#D9365C"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Cancelar"
                    Width="112"
                    Height="42"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="Cancel_Click" />
            <Button Grid.Column="2"
                    Content="Crear cliente"
                    Width="138"
                    Height="42"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="Create_Click" />
        </Grid>
    </Grid>
</Window>
