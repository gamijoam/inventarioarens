<Window x:Class="InventoryDesktop.Modules.POS.PosCustomerCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nuevo cliente"
        Width="600"
        Height="680"
        MinWidth="560"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlusOutline"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="CLIENTE"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Nuevo cliente"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Registra el cliente y quedara seleccionado automaticamente para esta venta."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Nombre o razon social"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="NameBox"
                                 Height="44"
                                 FontSize="14"
                                 Padding="10,0"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CardAccountDetailsOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Tipo"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="DocumentTypeBox"
                                      Height="44"
                                      FontSize="13"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Numeric"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Documento"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="DocumentNumberBox"
                                     Height="44"
                                     FontSize="14"
                                     Padding="10,0"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PhoneOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Telefono"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="PhoneBox"
                                 Height="44"
                                 FontSize="14"
                                 Padding="10,0"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EmailOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Correo"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="EmailBox"
                                 Height="44"
                                 FontSize="14"
                                 Padding="10,0"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MapMarkerOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="12" Height="12"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Direccion fiscal"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="FiscalAddressBox"
                                 Height="80"
                                 FontSize="13"
                                 Padding="10,8"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1"
                                 Margin="0,4,0,0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <Border Background="#FFF1F2"
                            BorderBrush="#FECDD3"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                     Foreground="#BE123C"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="StatusText"
                                       Foreground="#BE123C"
                                       FontWeight="Medium"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Create_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Crear cliente"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

