<Window x:Class="InventoryDesktop.Modules.POS.PosSerialSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar IMEI/serial"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                        <TextBlock Text="IMEI" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                    </Border>
                    <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                        <TextBlock Text="{Binding ProductSku}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding ProductName}" FontSize="25" FontWeight="Black" Margin="0,12,0,0" />
                <TextBlock Text="{Binding ContextLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,0" Padding="14" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         ToolTip="Buscar IMEI o serial"
                         KeyDown="SearchBox_KeyDown" />
                <Button Grid.Column="1"
                        Content="Buscar"
                        Height="38"
                        Margin="10,0,0,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        FontWeight="Black"
                        Click="Search_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="0,14,0,0" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F4F7FC" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SERIAL / IMEI" Margin="12,0" VerticalAlignment="Center" FontWeight="Black" />
                    <TextBlock Grid.Column="1" Text="ESTADO" Margin="12,0" VerticalAlignment="Center" FontWeight="Black" />
                    <TextBlock Grid.Column="2" Text="ALMACÉN" Margin="12,0" VerticalAlignment="Center" FontWeight="Black" />
                </Grid>

                <ListBox x:Name="SerialsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Serials}"
                         SelectedItem="{Binding SelectedSerial}"
                         BorderThickness="0"
                         MouseDoubleClick="SerialsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SerialNumber}" Margin="12,0" VerticalAlignment="Center" FontWeight="Black" />
                                <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Margin="12,0" VerticalAlignment="Center" Foreground="#058561" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="{Binding WarehouseLabel}" Margin="12,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,14,0,0" Padding="14" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Cancelar" Height="38" Margin="10,0,0,0" FontWeight="Black" Click="Cancel_Click" />
                <Button Grid.Column="2" Content="Usar IMEI" Height="38" Margin="10,0,0,0" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Black" Click="Use_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
