<Window x:Class="InventoryDesktop.Modules.POS.PosSerialSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Seleccionar IMEI/serial"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BarcodeScan"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="IMEI / SERIAL"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Padding="8,4" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PackageVariantClosed"
                                                         Foreground="#475569"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProductSku}"
                                           Foreground="#475569"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ProductName}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ContextLabel}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"
                                 FontSize="14"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,0,0,0"
                                 ToolTip="Buscar IMEI o serial"
                                 KeyDown="SearchBox_KeyDown" />
                    </Grid>
                </Border>
                <Button Grid.Column="1"
                        Height="42"
                        Margin="10,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#4D35FF"
                        BorderBrush="#4D35FF"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Search_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Buscar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F8FAFC">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SERIAL / IMEI"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="14,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="ESTADO"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="14,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="ALMACEN"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="14,0"
                               VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="SerialsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Serials}"
                         SelectedItem="{Binding SelectedSerial}"
                         BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="SerialsList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderBrush" Value="#F1F5F9" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SerialNumber}"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Margin="14,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusLabel}"
                                           Margin="14,0"
                                           VerticalAlignment="Center"
                                           Foreground="#047857"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding WarehouseLabel}"
                                           Margin="14,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Medium" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{Binding StatusBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding StatusBrush}"
                               FontWeight="Medium"
                               TextWrapping="Wrap"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Use_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Usar IMEI"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

