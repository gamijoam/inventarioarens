<UserControl x:Class="InventoryDesktop.Modules.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F6F8FC">
        <Grid.RowDefinitions>
            <RowDefinition Height="122" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="76" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="118" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Punto de Venta" FontSize="24" FontWeight="Black" />
                        <TextBlock Text="Escanea, agrega, cobra y controla la orden" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="46"
                         Margin="28,0,10,0"
                         FontSize="16"
                         VerticalAlignment="Center"
                         ToolTip="Escanea o escribe SKU, nombre, serial o IMEI. Enter agrega coincidencia exacta."
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown" />

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList}"
                          DisplayMemberPath="Name"
                          Height="46"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center" />

                <Button Grid.Column="3"
                        Content="Buscar"
                        Height="46"
                        VerticalAlignment="Center"
                        FontWeight="Black"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="#111827"
                        Click="Search_Click" />

                <WrapPanel Grid.Row="1" Grid.ColumnSpan="4" VerticalAlignment="Top">
                    <TextBlock Text="Almacén" FontWeight="Black" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="WarehouseLabel"
                              Width="260"
                              Height="30"
                              Margin="0,0,16,0" />
                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="{Binding ActiveCashRegisterLabel}" Foreground="#058561" FontWeight="Black" FontSize="11" />
                    </Border>
                    <TextBlock Text="{Binding OperationalContextLabel}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,14,18,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="ORDEN" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                                </Border>
                                <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding PriceListLabel}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                                </Border>
                                <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding CustomerLabel}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Carrito de venta" FontSize="24" FontWeight="Black" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding CartCountLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="14"
                                       FontWeight="Black"
                                       Margin="0,3,0,0" />
                            <TextBlock Text="Escanea arriba para agregar directo. Usa F2 si necesitas buscar por nombre o seleccionar manualmente."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="+ Buscar producto"
                                    Width="138"
                                    Height="38"
                                    Margin="0,0,8,0"
                                    FontWeight="Black"
                                    Background="#FFFFFF"
                                    BorderBrush="#CBD5E1"
                                    Foreground="#111827"
                                    Click="OpenProductSearch_Click" />
                            <Button Content="Limpiar"
                                    Width="92"
                                    Height="38"
                                    FontWeight="Black"
                                    Click="ClearCart_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="#E6ECF5" BorderThickness="0,1,0,0" Margin="0,16,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="136" />
                                                    <ColumnDefinition Width="138" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="16" TextWrapping="Wrap" />
                                                    <WrapPanel Margin="0,6,0,0">
                                                        <Border Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" Padding="7,3" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding ControlLabel}" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                                                        </Border>
                                                        <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="7,3" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding SerialLabel}" Foreground="#058561" FontSize="10" FontWeight="Black" TextWrapping="Wrap" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding Sku}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding WarehouseLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="Precio" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                                    <TextBlock Text="{Binding UnitPriceLabel}" FontWeight="Black" FontSize="14" Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding RateLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" />
                                                    <TextBlock Text="{Binding DiscountLabel}" Foreground="#B45309" FontSize="11" FontWeight="Black" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                                    <TextBlock Text="Cantidad" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <Button Content="-" Width="32" Height="30" FontWeight="Black" IsEnabled="{Binding CanChangeQuantity}" ToolTip="{Binding QuantityActionHint}" Click="DecreaseItem_Click" />
                                                        <Border Width="46" Height="30" BorderBrush="#DCE4F2" BorderThickness="1">
                                                            <TextBlock Text="{Binding QuantityLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" />
                                                        </Border>
                                                        <Button Content="+" Width="32" Height="30" FontWeight="Black" IsEnabled="{Binding CanChangeQuantity}" ToolTip="{Binding QuantityActionHint}" Click="IncreaseItem_Click" />
                                                    </StackPanel>
                                                    <Button Content="Descuento" Height="30" Margin="0,8,0,0" FontWeight="Black" Foreground="#B45309" Click="DiscountItem_Click" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="14,0,0,0" Width="118">
                                                    <TextBlock Text="Subtotal" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding TotalLabel}" FontWeight="Black" FontSize="18" Foreground="{StaticResource AccentStrongBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    <Button Content="Quitar" Height="30" Margin="0,14,0,0" FontWeight="Black" Foreground="#D9365C" Click="RemoveItem_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="14,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Herramientas POS" FontSize="19" FontWeight="Black" />
                        <Button Content="F8 Cliente" Height="38" Margin="0,12,0,0" FontWeight="Black" Click="SelectCustomer_Click" />
                        <Button Content="F2 Buscar producto" Height="38" Margin="0,12,0,0" FontWeight="Black" Click="OpenProductSearch_Click" />
                        <Button Content="F9 Último recibo" Height="38" Margin="0,8,0,0" FontWeight="Black" IsEnabled="{Binding HasLastReceipt}" Click="LastReceipt_Click" />
                        <Button Content="Pendientes" Height="38" Margin="0,8,0,0" FontWeight="Black" Click="PendingOrders_Click" />
                        <Button Content="Limpiar carrito" Height="38" Margin="0,8,0,0" FontWeight="Black" Click="ClearCart_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,12,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Total USD" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="{Binding TotalUsdLabel}" HorizontalAlignment="Right" FontSize="25" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                        </Grid>
                        <Grid Margin="0,7,0,0">
                            <TextBlock Text="Equivalente Bs" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TotalVesLabel}" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                        </Grid>
                        <Button Content="Cobrar (F12)"
                                Height="50"
                                Margin="0,16,0,0"
                                IsEnabled="{Binding CanPay}"
                                FontWeight="Black"
                                Background="#0F766E"
                                BorderBrush="#0F766E"
                                Foreground="White"
                                Click="Pay_Click" />
                        <TextBlock Text="{Binding PayHint}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,9,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="Volver al panel" Width="132" Height="32" VerticalAlignment="Center" FontWeight="Black" Click="Exit_Click" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="14,0" />
                <TextBlock Grid.Column="2" Text="Enter agrega exacto · F2 buscar · F5 refrescar · F8 cliente · F9 recibo · F12 cobrar · Esc limpia búsqueda" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
