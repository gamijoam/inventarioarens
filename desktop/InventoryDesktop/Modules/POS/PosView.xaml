<UserControl x:Class="InventoryDesktop.Modules.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F6F8FC">
        <Grid.RowDefinitions>
            <RowDefinition Height="118" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="76" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="104" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Punto de Venta" FontSize="24" FontWeight="Black" />
                        <TextBlock Text="Búsqueda rápida, precios y carrito" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="46"
                         Margin="28,0,10,0"
                         FontSize="15"
                         VerticalAlignment="Center"
                         ToolTip="Buscar por nombre, SKU, serial o IMEI"
                         KeyDown="SearchBox_KeyDown" />

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList}"
                          DisplayMemberPath="Name"
                          Height="46"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center" />

                <Button Grid.Column="3"
                        Content="Buscar"
                        Height="46"
                        VerticalAlignment="Center"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="Search_Click" />

                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" VerticalAlignment="Top">
                    <TextBlock Text="Almacén" FontWeight="Black" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="WarehouseLabel"
                              Width="260"
                              Height="30"
                              Margin="0,0,16,0" />
                    <TextBlock Text="Caja" FontWeight="Black" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding CashRegisterSessions}"
                              SelectedItem="{Binding SelectedCashRegisterSession}"
                              DisplayMemberPath="DisplayLabel"
                              Width="210"
                              Height="30"
                              Margin="0,0,16,0" />
                    <Button Content="Recargar contexto"
                            Width="138"
                            Height="30"
                            FontWeight="Black"
                            Click="ReloadContext_Click" />
                    <TextBlock Text="{Binding OperationalContextLabel}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,14,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="16,12" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                                <TextBlock Text="CATÁLOGO" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                            </Border>
                            <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                                <TextBlock Text="{Binding PriceListLabel}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Productos disponibles" FontSize="22" FontWeight="Black" Margin="0,10,0,0" />
                        <TextBlock Text="Selecciona productos por cantidad. Los serializados/IMEI se integran con lectura de serial en la siguiente fase."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding CartCountLabel}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="Black"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="178"
                                    Height="154"
                                    Margin="0,0,10,10"
                                    Padding="0"
                                    Background="#FFFFFF"
                                    BorderBrush="#DCE4F2"
                                    Click="Product_Click">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#F2F5FB" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Border Width="34" Height="34" CornerRadius="10" Background="#EEF0FF" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Initials}" Foreground="{StaticResource AccentStrongBrush}" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Padding="7,3" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0">
                                                <TextBlock Text="{Binding StockLabel}" FontSize="10" FontWeight="Black" Foreground="#34415F" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="10,9,10,9">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{Binding Product.Name}" FontWeight="Black" FontSize="13" TextWrapping="Wrap" MaxHeight="34" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1" Text="{Binding Product.Sku}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />

                                        <Grid Grid.Row="3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding CardPriceLabel}" FontSize="18" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Text="{Binding TrackingShortLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" Margin="0,2,0,0" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,14,18,8" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Orden actual" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="{Binding CartCountLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,3,0,0" />
                        <Border Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Cliente" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                <TextBlock Grid.Row="1" Text="{Binding CustomerLabel}" FontWeight="Black" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="2" Text="{Binding CustomerDetailLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </Grid>
                        </Border>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right">
                        <Button Content="Limpiar"
                                Width="78"
                                Height="34"
                                FontWeight="Black"
                                Click="ClearCart_Click" />
                        <Button Content="Cliente"
                                Width="78"
                                Height="30"
                                Margin="0,8,0,0"
                                FontWeight="Black"
                                Click="SelectCustomer_Click" />
                        <Button Content="Mostrador"
                                Width="78"
                                Height="30"
                                Margin="0,8,0,0"
                                FontWeight="Black"
                                Click="ClearCustomer_Click" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,0,0,12" BorderBrush="#E6ECF5" BorderThickness="0,0,0,1" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="14" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding TotalLabel}" FontWeight="Black" FontSize="14" Margin="10,0,0,0" />

                                        <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding PriceListLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding UnitPriceLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WarehouseLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SerialLabel}" Foreground="#058561" FontSize="11" FontWeight="Black" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RateLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="8,5,0,0" />

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="-" Width="32" Height="28" FontWeight="Black" Click="DecreaseItem_Click" />
                                            <Border Width="42" Height="28" BorderBrush="#DCE4F2" BorderThickness="1">
                                                <TextBlock Text="{Binding QuantityLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" />
                                            </Border>
                                            <Button Content="+" Width="32" Height="28" FontWeight="Black" Click="IncreaseItem_Click" />
                                            <Button Content="Quitar" Width="66" Height="28" Margin="8,0,0,0" FontWeight="Black" Foreground="#D9365C" Click="RemoveItem_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="#E6ECF5" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Total USD" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="{Binding TotalUsdLabel}" HorizontalAlignment="Right" FontSize="25" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                        </Grid>
                        <Grid Margin="0,7,0,0">
                            <TextBlock Text="Equivalente Bs" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TotalVesLabel}" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                        </Grid>
                        <Button Content="Pagar"
                                Height="48"
                                Margin="0,16,0,0"
                                IsEnabled="{Binding CanPay}"
                                FontWeight="Black"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                Click="Pay_Click" />
                        <TextBlock Text="Abre la ventana de cobro para pagos en USD, Bs o mixtos."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,9,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="Volver al panel"
                        Width="132"
                        Height="32"
                        VerticalAlignment="Center"
                        FontWeight="Black"
                        Click="Exit_Click" />

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="14,0" />

                <TextBlock Grid.Column="2"
                           Text="F2 Buscar · Click agrega producto · Pagar confirma contra backend"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
