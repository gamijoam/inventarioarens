<UserControl x:Class="InventoryDesktop.Modules.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26,22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="390" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2" Padding="16" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="46"
                         FontSize="16"
                         ToolTip="Buscar por nombre, SKU, serial o IMEI"
                         KeyDown="SearchBox_KeyDown" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList}"
                          DisplayMemberPath="Name"
                          Height="46"
                          Margin="12,0,0,0" />

                <Button Grid.Column="2"
                        Content="Buscar"
                        Width="108"
                        Height="46"
                        Margin="12,0,0,0"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="Search_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="16" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Margin="0,14,14,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Productos" FontSize="20" FontWeight="Black" />
                        <TextBlock Text="{Binding PriceListLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="210"
                                        Height="178"
                                        Margin="0,0,12,12"
                                        Padding="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#DCE4F2"
                                        Click="Product_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="70" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#F3F6FC" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Border Width="48" Height="48" CornerRadius="13" Background="#EEF0FF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Initials}" Foreground="{StaticResource AccentStrongBrush}" FontSize="17" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border Padding="7,4" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                                                    <TextBlock Text="{Binding StockLabel}" FontSize="11" FontWeight="Black" Foreground="#34415F" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="10">
                                            <TextBlock Text="{Binding Product.Name}" FontWeight="Black" FontSize="14" TextWrapping="Wrap" MaxHeight="42" />
                                            <TextBlock Text="{Binding Product.Sku}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                            <Grid Margin="0,12,0,0">
                                                <TextBlock Text="{Binding CardPriceLabel}" FontSize="20" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                                                <TextBlock Text="{Binding TrackingShortLabel}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Padding="16" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Orden actual" FontSize="20" FontWeight="Black" />
                        <TextBlock Text="{Binding CartCountLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Content="Limpiar"
                            Width="82"
                            Height="34"
                            HorizontalAlignment="Right"
                            FontWeight="Black"
                            Click="ClearCart_Click" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,0,0,12" BorderBrush="#E6ECF5" BorderThickness="0,0,0,1" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="14" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding TotalLabel}" FontWeight="Black" FontSize="14" Margin="10,0,0,0" />
                                        <TextBlock Grid.Row="1" Text="{Binding PriceListLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UnitPriceLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="10,4,0,0" />

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="-" Width="36" Height="30" FontWeight="Black" Click="DecreaseItem_Click" />
                                            <Border Width="46" Height="30" BorderBrush="#DCE4F2" BorderThickness="1,1,1,1">
                                                <TextBlock Text="{Binding QuantityLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" />
                                            </Border>
                                            <Button Content="+" Width="36" Height="30" FontWeight="Black" Click="IncreaseItem_Click" />
                                            <Button Content="Quitar" Width="70" Height="30" Margin="8,0,0,0" FontWeight="Black" Foreground="#D9365C" Click="RemoveItem_Click" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RateLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Border BorderBrush="#E6ECF5" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Total USD" FontSize="17" FontWeight="Black" />
                                <TextBlock Text="{Binding TotalUsdLabel}" HorizontalAlignment="Right" FontSize="25" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="Equivalente Bs" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalVesLabel}" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                            </Grid>
                            <Button Content="Pagar (siguiente fase)"
                                    Height="48"
                                    Margin="0,18,0,0"
                                    IsEnabled="False"
                                    FontWeight="Black"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,12,14,0" />
    </Grid>
</UserControl>
