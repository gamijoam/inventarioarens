<UserControl x:Class="InventoryDesktop.Modules.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F6F8FC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="46" Height="46" CornerRadius="14" Background="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,22,0,26">
                    <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                    <Border Width="48" Height="58" CornerRadius="10" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" Margin="0,0,0,10">
                        <TextBlock Text="POS" Foreground="{StaticResource AccentStrongBrush}" FontSize="12" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="VENTA" Foreground="#64718C" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" />
                </StackPanel>

                <Button Grid.Row="2"
                        Content="Salir"
                        Width="54"
                        Height="34"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        FontSize="11"
                        FontWeight="Black"
                        Click="Exit_Click" />
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="86" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Punto de Venta" FontSize="25" FontWeight="Black" />
                        <TextBlock Text="Busca, cotiza y arma la orden antes del checkout" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Padding="14,9" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                        <TextBlock Text="{Binding PriceListLabel}" FontWeight="Black" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="28,20,28,0" Padding="16" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="48"
                             FontSize="16"
                             ToolTip="Buscar por nombre, SKU, serial o IMEI"
                             KeyDown="SearchBox_KeyDown" />

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding PriceLists}"
                              SelectedItem="{Binding SelectedPriceList}"
                              DisplayMemberPath="Name"
                              Height="48"
                              Margin="12,0,0,0" />

                    <Button Grid.Column="2"
                            Content="Buscar"
                            Height="48"
                            Margin="12,0,0,0"
                            FontWeight="Black"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            Click="Search_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="28,18,28,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Catálogo rápido" FontSize="21" FontWeight="Black" />
                        <TextBlock Text="Selecciona productos por cantidad. Los serializados/IMEI se integran en la siguiente fase." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="246"
                                        Height="174"
                                        Margin="0,0,14,14"
                                        Padding="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#DCE4F2"
                                        Click="Product_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="56" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#F2F5FB" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Border Width="46" Height="46" CornerRadius="14" Background="#EEF0FF" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0,0,0">
                                                    <TextBlock Text="{Binding Initials}" Foreground="{StaticResource AccentStrongBrush}" FontSize="16" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border Padding="8,4" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding StockLabel}" FontSize="11" FontWeight="Black" Foreground="#34415F" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="1" Margin="14,12,14,12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding Product.Name}" FontWeight="Black" FontSize="15" TextWrapping="Wrap" MaxHeight="40" />
                                            <TextBlock Grid.Row="1" Text="{Binding Product.Sku}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />

                                            <Grid Grid.Row="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CardPriceLabel}" FontSize="22" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" VerticalAlignment="Bottom" />
                                                <Border Grid.Column="1" Padding="8,4" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="8" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding TrackingShortLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3" Margin="28,14,28,18" Padding="12" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1,0,0,0">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Orden actual" FontSize="23" FontWeight="Black" />
                        <TextBlock Text="{Binding CartCountLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Content="Limpiar"
                            Width="86"
                            Height="36"
                            HorizontalAlignment="Right"
                            FontWeight="Black"
                            Click="ClearCart_Click" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,0,0,14" BorderBrush="#E6ECF5" BorderThickness="0,0,0,1" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="15" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding TotalLabel}" FontWeight="Black" FontSize="15" Margin="12,0,0,0" />

                                        <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding PriceListLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding UnitPriceLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RateLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="12,5,0,0" />

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="-" Width="36" Height="30" FontWeight="Black" Click="DecreaseItem_Click" />
                                            <Border Width="48" Height="30" BorderBrush="#DCE4F2" BorderThickness="1">
                                                <TextBlock Text="{Binding QuantityLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Black" />
                                            </Border>
                                            <Button Content="+" Width="36" Height="30" FontWeight="Black" Click="IncreaseItem_Click" />
                                            <Button Content="Quitar" Width="72" Height="30" Margin="10,0,0,0" FontWeight="Black" Foreground="#D9365C" Click="RemoveItem_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="#E6ECF5" BorderThickness="0,1,0,0" Padding="0,18,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Total USD" FontSize="18" FontWeight="Black" />
                            <TextBlock Text="{Binding TotalUsdLabel}" HorizontalAlignment="Right" FontSize="28" FontWeight="Black" Foreground="{StaticResource AccentStrongBrush}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="Equivalente Bs" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TotalVesLabel}" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontWeight="Black" />
                        </Grid>
                        <Button Content="Pagar (siguiente fase)"
                                Height="52"
                                Margin="0,20,0,0"
                                IsEnabled="False"
                                FontWeight="Black"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" />
                        <TextBlock Text="El checkout real se conectará con caja, pagos y ventas en la siguiente fase."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
