<UserControl x:Class="InventoryDesktop.Modules.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Focusable="True"
             FocusManager.IsFocusScope="True"
             FocusManager.FocusedElement="{Binding ElementName=SearchBox}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="PosPriceTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="PosQuantityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                    <Setter Property="BorderBrush" Value="#4D35FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PosCartRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Height" Value="50" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="BorderBrush" Value="#F1F5F9" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC" />
                </Trigger>
                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PosCartCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="PosQuickActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                    <Setter Property="BorderBrush" Value="#4D35FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PosComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="14" Background="#4D35FF">
                        <materialDesign:PackIcon Kind="PointOfSale"
                                                 Foreground="White"
                                                 Width="24" Height="24"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Punto de venta" FontSize="20" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="Escanea, agrega, cobra y controla la orden"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="Light"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1" Margin="28,0,28,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="20" Padding="14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <Grid Grid.Column="1" Margin="10,0,0,0">
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42"
                                         FontSize="15"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         ToolTip="Escanea o escribe SKU, nombre, serial o IMEI. Enter agrega coincidencia exacta. (F2)"
                                         LostKeyboardFocus="SearchBox_LostKeyboardFocus"
                                         TextChanged="SearchBox_TextChanged"
                                         KeyDown="SearchBox_KeyDown" />
                                <TextBlock Text="Escanear codigo o buscar producto (F2)"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="15"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Height="42"
                            Padding="16,0"
                            materialDesign:ButtonAssist.CornerRadius="20"
                            Background="#4D35FF"
                            BorderBrush="#4D35FF"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="Search_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Buscar (F2)" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Lista de precios"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding PriceLists}"
                                  SelectedItem="{Binding SelectedPriceList}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource PosComboBoxStyle}"
                                  MinWidth="160"
                                  SelectionChanged="PosContext_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Almacen"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedWarehouse}"
                                  DisplayMemberPath="WarehouseLabel"
                                  Style="{StaticResource PosComboBoxStyle}"
                                  MinWidth="180"
                                  SelectionChanged="PosContext_SelectionChanged" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Caja activa"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2" />
                        <Border Padding="10,6"
                                CornerRadius="8"
                                Background="#ECFDF5"
                                BorderBrush="#A7F3D0"
                                BorderThickness="1"
                                Height="38"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding ActiveCashRegisterLabel}"
                                           Foreground="#047857"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="600" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                                    <TextBlock Text="CARRITO" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                                </Border>
                                <Border Padding="8,4" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding PriceListLabel}" Foreground="#475569" FontSize="10" FontWeight="Bold" />
                                </Border>
                                <Border Padding="8,4" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding CustomerLabel}" Foreground="#475569" FontSize="10" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Carrito de venta"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding CartCountLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                    Click="OpenProductSearch_Click"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                             Foreground="{StaticResource AccentBrush}"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Buscar producto"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                    Click="ClearCart_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TrashCanOutline"
                                                             Foreground="#D72F5E"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Limpiar"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="CartGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding CartItems}"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              AlternationCount="2"
                              RowStyle="{StaticResource PosCartRowStyle}"
                              CellStyle="{StaticResource PosCartCellStyle}"
                              Background="Transparent"
                              BorderThickness="0,1,0,0"
                              BorderBrush="#E2E8F0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="10,12" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="#475569" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource InkBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding Sku}"
                                                           Foreground="#94A3B8"
                                                           FontSize="11"
                                                           FontWeight="Medium" />
                                                <TextBlock Text="  ·  "
                                                           Foreground="#CBD5E1"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding ControlLabel}"
                                                           Foreground="{StaticResource AccentStrongBrush}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SerialLabel}"
                                                       Foreground="#047857"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding SerialLabel, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />
                                            <TextBlock Text="{Binding DiscountLabel}"
                                                       Foreground="#B45309"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding DiscountLabel, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="PRECIO UNIT." Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding UnitPriceLabel}"
                                                       Style="{StaticResource PosPriceTextStyle}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource InkBrush}" />
                                            <TextBlock Text="{Binding RateLabel}"
                                                       HorizontalAlignment="Right"
                                                       Foreground="#94A3B8"
                                                       FontSize="10"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="CANTIDAD" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Content="-"
                                                    Style="{StaticResource PosQuantityButtonStyle}"
                                                    IsEnabled="{Binding CanChangeQuantity}"
                                                    ToolTip="{Binding QuantityActionHint}"
                                                    Click="DecreaseItem_Click" />
                                            <Border Width="40" Height="28"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    Background="#FFFFFF"
                                                    Margin="4,0"
                                                    CornerRadius="4">
                                                <TextBlock Text="{Binding QuantityLabel}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                                           FontWeight="Bold"
                                                           FontSize="13" />
                                            </Border>
                                            <Button Content="+"
                                                    Style="{StaticResource PosQuantityButtonStyle}"
                                                    IsEnabled="{Binding CanChangeQuantity}"
                                                    ToolTip="{Binding QuantityActionHint}"
                                                    Click="IncreaseItem_Click" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="SUBTOTAL" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding TotalLabel}"
                                                       Style="{StaticResource PosPriceTextStyle}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource AccentStrongBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Width="30" Height="30"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Aplicar descuento"
                                                    Click="DiscountItem_Click">
                                                <materialDesign:PackIcon Kind="TagOutline"
                                                                         Foreground="#B45309"
                                                                         Width="16" Height="16" />
                                            </Button>
                                            <Button Width="30" Height="30"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Quitar del carrito"
                                                    Margin="4,0,0,0"
                                                    Click="RemoveItem_Click">
                                                <materialDesign:PackIcon Kind="CloseCircleOutline"
                                                                         Foreground="#D72F5E"
                                                                         Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            Background="#F8FAFC">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CartItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CartOutline"
                                                     Foreground="#CBD5E1"
                                                     Width="64" Height="64"
                                                     HorizontalAlignment="Center" />
                            <TextBlock Text="Carrito vacio"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="Escanea o busca un producto para agregar"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,18,20,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="CLIENTE"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding CustomerLabel}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,2" />

                        <TextBlock Text="{Binding CustomerDetailLabel}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="Light"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource PosQuickActionButtonStyle}"
                                    Click="SelectCustomer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify"
                                                             Foreground="{StaticResource AccentBrush}"
                                                             Width="14" Height="14"
                                                             VerticalAlignment="Center" />
                                    <Border Background="#EEF0FF" Padding="4,1" CornerRadius="4" Margin="6,0,0,0">
                                        <TextBlock Text="F8"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="Buscar"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Style="{StaticResource PosQuickActionButtonStyle}"
                                    Click="ClearCustomer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountOffOutline"
                                                             Foreground="{StaticResource MutedBrush}"
                                                             Width="14" Height="14"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Mostrador"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="1" Padding="20,8" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="CalculatorVariant"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Resumen"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,16">
                                <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                        Margin="0,0,5,5"
                                        Padding="12,12"
                                        MinHeight="84"
                                        Click="OpenProductSearch_Click">
                                    <Grid>
                                        <Border Background="#EEF0FF" Padding="5,2" CornerRadius="4"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="F2"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="Magnify"
                                                                     Foreground="{StaticResource AccentBrush}"
                                                                     Width="28" Height="28" />
                                            <TextBlock Text="Buscar"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                        Margin="5,0,0,5"
                                        Padding="12,12"
                                        MinHeight="84"
                                        Click="ReloadContext_Click">
                                    <Grid>
                                        <Border Background="#EEF0FF" Padding="5,2" CornerRadius="4"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="F5"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="Refresh"
                                                                     Foreground="{StaticResource AccentBrush}"
                                                                     Width="28" Height="28" />
                                            <TextBlock Text="Refrescar"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                        Margin="0,5,5,0"
                                        Padding="12,12"
                                        MinHeight="84"
                                        Click="PendingOrders_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="ClockOutline"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 Width="28" Height="28" />
                                        <TextBlock Text="Pendientes"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Foreground="{StaticResource InkBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PosQuickActionButtonStyle}"
                                        Margin="5,5,0,0"
                                        Padding="12,12"
                                        MinHeight="84"
                                        Click="LastReceipt_Click"
                                        IsEnabled="{Binding HasLastReceipt}">
                                    <Grid>
                                        <Border Background="#EEF0FF" Padding="5,2" CornerRadius="4"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="F9"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="ReceiptTextOutline"
                                                                     Foreground="{StaticResource AccentBrush}"
                                                                     Width="28" Height="28" />
                                            <TextBlock Text="Recibo"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </UniformGrid>

                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Items"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CartCountLabel}"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Foreground="{StaticResource InkBrush}"
                                           VerticalAlignment="Center"
                                           Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Equivalente Bs"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TotalVesLabel}"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontWeight="Medium"
                                           FontSize="13"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Grid.Column="1" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="20,16,20,20">
                        <Border Background="#F0FDF4"
                                BorderBrush="#A7F3D0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="Total USD"
                                               Foreground="#047857"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding TotalUsdLabel}"
                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#047857"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Button materialDesign:ButtonAssist.CornerRadius="10"
                                MinHeight="48"
                                Padding="20,12"
                                Background="#27AE60"
                                BorderBrush="#27AE60"
                                Foreground="White"
                                IsEnabled="{Binding CanPay}"
                                Click="Pay_Click"
                                FontWeight="Bold"
                                FontSize="15"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CreditCardCheckOutline"
                                                         Width="20" Height="20"
                                                         VerticalAlignment="Center" />
                                <Border Background="#1E8B4D" Padding="5,2" CornerRadius="4" Margin="10,0,0,0">
                                    <TextBlock Text="F12"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="FINALIZAR VENTA"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding PayHint}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="Volver al panel"
                        Width="132"
                        Height="32"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Background="Transparent"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        Click="Exit_Click" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="14,0" />
                <TextBlock Grid.Column="2"
                           Text="Enter agrega exacto · F2 buscar · F5 refrescar · F8 cliente · F9 recibo · F12 cobrar · Esc limpia busqueda"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           FontWeight="Light"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
