<Window x:Class="InventoryDesktop.Modules.POS.PosProductSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar producto"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                        <TextBlock Text="SELECTOR POS" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                    </Border>
                    <TextBlock Text="Buscar producto" FontSize="26" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="Usa esta ventana cuando no tengas código de barra o necesites elegir el producto manualmente."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1" Content="Cerrar" Width="108" Height="42" FontWeight="Black" Click="Close_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,14,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="118" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ProductSearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="42"
                         FontSize="15"
                         ToolTip="Nombre, SKU, serial o IMEI"
                         KeyDown="ProductSearchBox_KeyDown" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList}"
                          DisplayMemberPath="Name"
                          Height="42"
                          Margin="10,0,0,0" />

                <Button Grid.Column="2"
                        Content="Buscar"
                        Height="42"
                        Margin="10,0,0,0"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="Search_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="0">
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F7F9FD">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                        <ColumnDefinition Width="160" SharedSizeGroup="SkuColumn" />
                        <ColumnDefinition Width="130" SharedSizeGroup="PriceColumn" />
                        <ColumnDefinition Width="100" SharedSizeGroup="StockColumn" />
                        <ColumnDefinition Width="120" SharedSizeGroup="ControlColumn" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="PRODUCTO" FontWeight="Black" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="SKU" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="PRECIO" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="STOCK" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="CONTROL" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="ProductsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Products}"
                         BorderThickness="0"
                         MouseDoubleClick="ProductsList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="54" Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                                    <ColumnDefinition Width="160" SharedSizeGroup="SkuColumn" />
                                    <ColumnDefinition Width="130" SharedSizeGroup="PriceColumn" />
                                    <ColumnDefinition Width="100" SharedSizeGroup="StockColumn" />
                                    <ColumnDefinition Width="120" SharedSizeGroup="ControlColumn" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Product.Name}" FontWeight="Black" FontSize="14" TextWrapping="Wrap" Margin="14,8" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Product.Sku}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding CardPriceLabel}" Foreground="{Binding CardPriceBrush}" FontWeight="Black" FontSize="15" Margin="10,8" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding StockLabel}" Foreground="{Binding StockBrush}" FontWeight="Black" Margin="10,8" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding TrackingShortLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="Black" Margin="10,8" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Cancelar" Width="118" Height="44" FontWeight="Black" Click="Close_Click" />
            <Button Grid.Column="2" Content="Agregar seleccionado" Width="172" Height="44" Margin="10,0,0,0" FontWeight="Black" Background="{StaticResource AccentBrush}" Foreground="White" Click="AddSelected_Click" />
        </Grid>
    </Grid>
</Window>
