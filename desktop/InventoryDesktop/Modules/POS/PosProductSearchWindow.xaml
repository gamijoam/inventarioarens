<Window x:Class="InventoryDesktop.Modules.POS.PosProductSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Buscar producto"
        Width="1000"
        Height="700"
        MinWidth="880"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="SELECTOR POS"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Buscar producto"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Usa esta ventana cuando no tengas codigo de barra o necesites elegir el producto manualmente."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cerrar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBox x:Name="ProductSearchBox"
                                 Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"
                                 FontSize="14"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,0,0,0"
                                 ToolTip="Nombre, SKU, serial o IMEI"
                                 KeyDown="ProductSearchBox_KeyDown" />
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList}"
                          DisplayMemberPath="Name"
                          Height="42"
                          Margin="10,0,0,0"
                          FontSize="13" />

                <Button Grid.Column="2"
                        Height="42"
                        Margin="10,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#4D35FF"
                        BorderBrush="#4D35FF"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Search_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Buscar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F8FAFC">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                        <ColumnDefinition Width="160" SharedSizeGroup="SkuColumn" />
                        <ColumnDefinition Width="130" SharedSizeGroup="PriceColumn" />
                        <ColumnDefinition Width="100" SharedSizeGroup="StockColumn" />
                        <ColumnDefinition Width="120" SharedSizeGroup="ControlColumn" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="PRODUCTO"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="14,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="SKU"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="10,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="PRECIO"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="10,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="STOCK"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="10,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4"
                               Text="CONTROL"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="#475569"
                               Margin="10,0"
                               VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="ProductsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Products}"
                         BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="ProductsList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderBrush" Value="#F1F5F9" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="54">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                                    <ColumnDefinition Width="160" SharedSizeGroup="SkuColumn" />
                                    <ColumnDefinition Width="130" SharedSizeGroup="PriceColumn" />
                                    <ColumnDefinition Width="100" SharedSizeGroup="StockColumn" />
                                    <ColumnDefinition Width="120" SharedSizeGroup="ControlColumn" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Product.Name}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap"
                                           Margin="14,8"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Product.Sku}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Medium"
                                           Margin="10,8"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CardPriceLabel}"
                                           Foreground="{Binding CardPriceBrush}"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="10,8"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding StockLabel}"
                                           Foreground="{Binding StockBrush}"
                                           FontWeight="Bold"
                                           Margin="10,8"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding TrackingShortLabel}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Medium"
                                           Margin="10,8"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{Binding StatusBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding StatusBrush}"
                               FontWeight="Medium"
                               TextWrapping="Wrap"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="AddSelected_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Agregar seleccionado"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

