<Window x:Class="InventoryDesktop.Modules.POS.PosCustomerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Seleccionar cliente"
        Width="1080"
        Height="660"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="CLIENTE"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Seleccionar cliente"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Busca por nombre, cedula/RIF, telefono o correo. Si no seleccionas ninguno, la venta queda como cliente mostrador."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,16">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Height="42"
                                 FontSize="14"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,0,0,0"
                                 KeyDown="SearchBox_KeyDown" />
                    </Grid>
                </Border>

                <Button Grid.Column="1"
                        Height="42"
                        Margin="10,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#4D35FF"
                        BorderBrush="#4D35FF"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Search_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Buscar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Height="42"
                        Margin="10,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="CreateCustomer_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlusOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Nuevo cliente"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <DataGrid x:Name="CustomersGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          MouseDoubleClick="CustomersGrid_MouseDoubleClick"
                          SelectionChanged="CustomersGrid_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC" />
                            <Setter Property="BorderBrush" Value="#E2E8F0" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="Foreground" Value="#475569" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#FFFFFF" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding DocumentLabel}" Width="130" />
                        <DataGridTextColumn Header="TELEFONO" Binding="{Binding Phone}" Width="125" />
                        <DataGridTextColumn Header="CORREO" Binding="{Binding Email}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="16,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Historial del cliente"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding CustomerHistorySummaryLabel}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="2" Rows="1" Margin="0,14,0,12">
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,4,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CartOutline"
                                                             Foreground="#1D4ED8"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="COMPRAS"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#1D4ED8"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding CustomerHistoryPaidLabel}"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding CustomerHistoryOpenLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="#BE123C"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="4,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashMultiple"
                                                             Foreground="#047857"
                                                             Width="12" Height="12"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="MONTO"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#047857"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding CustomerHistoryMoneyLabel}"
                                           FontFamily="Consolas, Cascadia Mono, Courier New"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding CustomerHistoryDebtLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="#BE123C"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding CustomerHistoryLastLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <DataGrid x:Name="CustomerHistoryGrid"
                                  ItemsSource="{Binding CustomerRecentOrders}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  AlternationCount="2"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderBrush="#E2E8F0"
                                  BorderThickness="1"
                                  MinHeight="190">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="10,8" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Foreground" Value="#475569" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10,6" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#FFFFFF" />
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F8FAFC" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ORDEN" Binding="{Binding OrderLabel}" Width="78" />
                                <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="90" />
                                <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="*" />
                                <DataGridTextColumn Header="PAGADO" Binding="{Binding PaidLabel}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,16,0,0">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="#D72F5E"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText"
                               Foreground="#D72F5E"
                               FontWeight="Medium"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="WalkIn_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountOffOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Mostrador"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        Height="42"
                        Padding="18,0"
                        Margin="8,0,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#27AE60"
                        BorderBrush="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="Select_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Seleccionar"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

