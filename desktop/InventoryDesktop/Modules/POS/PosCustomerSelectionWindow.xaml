<Window x:Class="InventoryDesktop.Modules.POS.PosCustomerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar cliente"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel>
                <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                    <TextBlock Text="CLIENTE" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                </Border>
                <TextBlock Text="Seleccionar cliente" FontSize="26" FontWeight="Black" Margin="0,12,0,0" />
                <TextBlock Text="Busca por nombre, cédula/RIF, teléfono o correo. Si no seleccionas ninguno, la venta queda como cliente mostrador."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="118" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Height="42"
                     FontSize="15"
                     KeyDown="SearchBox_KeyDown" />
            <Button Grid.Column="1"
                    Content="Buscar"
                    Height="42"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="Search_Click" />
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,16,0,16">
            <DataGrid x:Name="CustomersGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      MouseDoubleClick="CustomersGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding DocumentLabel}" Width="150" />
                    <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Phone}" Width="140" />
                    <DataGridTextColumn Header="CORREO" Binding="{Binding Email}" Width="190" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Foreground="#D9365C"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Usar mostrador"
                    Width="130"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="WalkIn_Click" />
            <Button Grid.Column="2"
                    Content="Cancelar"
                    Width="108"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="Cancel_Click" />
            <Button Grid.Column="3"
                    Content="Seleccionar"
                    Width="126"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="Select_Click" />
        </Grid>
    </Grid>
</Window>
