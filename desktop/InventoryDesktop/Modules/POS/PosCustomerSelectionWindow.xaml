<Window x:Class="InventoryDesktop.Modules.POS.PosCustomerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar cliente"
        Width="1040"
        Height="620"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel>
                <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                    <TextBlock Text="CLIENTE" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                </Border>
                <TextBlock Text="Seleccionar cliente" FontSize="26" FontWeight="Black" Margin="0,12,0,0" />
                <TextBlock Text="Busca por nombre, cedula/RIF, telefono o correo. Si no seleccionas ninguno, la venta queda como cliente mostrador."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="118" />
                <ColumnDefinition Width="146" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Height="42"
                     FontSize="15"
                     KeyDown="SearchBox_KeyDown" />
            <Button Grid.Column="1"
                    Content="Buscar"
                    Height="42"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="Search_Click" />
            <Button Grid.Column="2"
                    Content="+ Nuevo cliente"
                    Height="42"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="CreateCustomer_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="12" Padding="12">
                <DataGrid x:Name="CustomersGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          MouseDoubleClick="CustomersGrid_MouseDoubleClick"
                          SelectionChanged="CustomersGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="DOCUMENTO" Binding="{Binding DocumentLabel}" Width="130" />
                        <DataGridTextColumn Header="TELEFONO" Binding="{Binding Phone}" Width="125" />
                        <DataGridTextColumn Header="CORREO" Binding="{Binding Email}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#DCE4F2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="14,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Historial del cliente" FontSize="20" FontWeight="Black" />
                        <TextBlock Text="{Binding CustomerHistorySummaryLabel}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="2" Margin="0,14,0,12">
                        <Border Background="#F8FAFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="COMPRAS" FontSize="10" FontWeight="Black" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding CustomerHistoryPaidLabel}" FontWeight="Black" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CustomerHistoryOpenLabel}" FontWeight="Bold" Foreground="#D9365C" />
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="MONTO" FontSize="10" FontWeight="Black" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding CustomerHistoryMoneyLabel}" FontWeight="Black" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CustomerHistoryDebtLabel}" FontWeight="Bold" Foreground="#D9365C" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding CustomerHistoryLastLabel}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <DataGrid x:Name="CustomerHistoryGrid"
                                  ItemsSource="{Binding CustomerRecentOrders}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  MinHeight="190">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ORDEN" Binding="{Binding OrderLabel}" Width="78" />
                                <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="90" />
                                <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalLabel}" Width="*" />
                                <DataGridTextColumn Header="PAGADO" Binding="{Binding PaidLabel}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Foreground="#D9365C"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Usar mostrador"
                    Width="130"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="WalkIn_Click" />
            <Button Grid.Column="2"
                    Content="Cancelar"
                    Width="108"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Click="Cancel_Click" />
            <Button Grid.Column="3"
                    Content="Seleccionar"
                    Width="126"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Black"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="Select_Click" />
        </Grid>
    </Grid>
</Window>
