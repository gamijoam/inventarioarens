<Window x:Class="InventoryDesktop.Modules.Admin.SwitchTenantDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Cambiar de empresa"
        Width="480"
        Height="520"
        MinWidth="420"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="SwapHorizontal" Foreground="#4D35FF" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Cambiar de empresa" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Selecciona la empresa a la que quieres cambiar." FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="400" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="4" Margin="0,16,0,16">
            <ListBox x:Name="TenantsList"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Margin" Value="2" />
                        <Setter Property="Background" Value="White" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EEF0FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Domain" Foreground="#4D35FF" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" />
                                <TextBlock Text="{Binding Slug}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="CheckCircle"
                                                     Foreground="#10B981"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center"
                                                     Grid.Column="2"
                                                     Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2">
            <Button HorizontalAlignment="Left"
                    Height="40"
                    MinWidth="110"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button HorizontalAlignment="Right"
                    Height="40"
                    MinWidth="140"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#4D35FF"
                    BorderBrush="#4D35FF"
                    Foreground="White"
                    Click="Accept_Click"
                    IsEnabled="{Binding HasSelection}"
                    FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="SwapHorizontal" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cambiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
