<Window x:Class="InventoryDesktop.Modules.Admin.EditGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Editar grupo SaaS"
        Width="520"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PencilOutline" Foreground="#7C3AED" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Editar grupo SaaS" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Modifica los datos estructurales del grupo. Los cambios son auditados."
                               FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="440" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,16,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="NameBox"
                         materialDesign:HintAssist.Hint="Nombre del grupo"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Domain"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="SLUG (unico, formato kebab-case)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="SlugBox"
                         materialDesign:HintAssist.Hint="ej: arens-holding"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="LinkVariant"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="DOMINIO (opcional)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="DomainBox"
                         materialDesign:HintAssist.Hint="ej: arens.example.com"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Web"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="PLAN (opcional)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="PlanBox"
                         materialDesign:HintAssist.Hint="enterprise, premium, demo..."
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="TagOutline"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="STATUS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <ComboBox x:Name="StatusBox"
                          materialDesign:HintAssist.Hint="Estado"
                          materialDesign:HintAssist.IsFloating="True"
                          materialDesign:TextFieldAssist.HasLeadingIcon="True"
                          materialDesign:TextFieldAssist.LeadingIcon="ToggleSwitchOutline"
                          materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          FontSize="14">
                    <ComboBoxItem Content="active" />
                    <ComboBoxItem Content="inactive" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Button HorizontalAlignment="Left"
                    Height="40" MinWidth="110"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button HorizontalAlignment="Right"
                    Height="40" MinWidth="160"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#7C3AED" BorderBrush="#7C3AED" Foreground="White"
                    Click="Accept_Click"
                    IsEnabled="{Binding CanAccept, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Guardar cambios" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>