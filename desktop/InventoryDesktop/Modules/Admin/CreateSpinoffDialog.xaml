<Window x:Class="InventoryDesktop.Modules.Admin.CreateSpinoffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nuevo spinoff"
        Width="520"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="DomainPlus" Foreground="#4D35FF" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Crea una empresa spinoff dentro del grupo. El usuario asignado sera el administrador con todos los permisos."
                               FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="440" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,16,0,16">
            <StackPanel>
                <Expander Header="Datos de la empresa" IsExpanded="True" FontWeight="SemiBold" Margin="0,0,0,12">
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="SpinoffNameBox"
                                 materialDesign:HintAssist.Hint="Nombre de la empresa"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Domain"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="SLUG (unico, formato kebab-case)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="SpinoffSlugBox"
                                 materialDesign:HintAssist.Hint="ej: arens-corp-norte"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="LinkVariant"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,0" />
                    </StackPanel>
                </Expander>

                <Expander Header="Datos del administrador inicial" IsExpanded="True" FontWeight="SemiBold" Margin="0,0,0,0">
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="AdminNameBox"
                                 materialDesign:HintAssist.Hint="Nombre del administrador"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="CORREO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="AdminEmailBox"
                                 materialDesign:HintAssist.Hint="email@empresa.com"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="CONTRASENA (opcional, se genera si se deja vacia)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <PasswordBox x:Name="AdminPasswordBox"
                                     materialDesign:HintAssist.Hint="Contrasena"
                                     materialDesign:HintAssist.IsFloating="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     FontSize="14"
                                     Margin="0,0,0,0" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Button HorizontalAlignment="Left"
                    Height="40"
                    MinWidth="110"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button HorizontalAlignment="Right"
                    Height="40"
                    MinWidth="140"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#4D35FF"
                    BorderBrush="#4D35FF"
                    Foreground="White"
                    Click="Accept_Click"
                    IsEnabled="{Binding CanAccept, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Crear spinoff" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
