<Window x:Class="InventoryDesktop.Modules.Admin.EditPlatformAdminDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Editar Platform Admin"
        Width="520"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ShieldAccountOutline" Foreground="#7C3AED" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Editar Platform Admin" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Modifica nombre, correo o el flag de acceso. Demote a false convierte al admin en user normal."
                               FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="440" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,16,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="NameBox"
                         materialDesign:HintAssist.Hint="Nombre del Platform Admin"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="CORREO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="EmailBox"
                         materialDesign:HintAssist.Hint="email@empresa.com"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <CheckBox x:Name="IsPlatformAdminBox"
                              IsChecked="True"
                              VerticalAlignment="Center"
                              FontWeight="SemiBold" />
                    <materialDesign:PackIcon Kind="ShieldKeyOutline"
                                             Foreground="#7C3AED"
                                             Width="16" Height="16"
                                             VerticalAlignment="Center"
                                             Margin="8,0,6,0" />
                    <TextBlock Text="Mantener acceso Platform Admin"
                               Foreground="#1E293B"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="SelfDemoteWarning"
                Grid.Row="2"
                Background="#FEF3C7"
                BorderBrush="#FBBF24"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertOutline" Foreground="#92400E" Width="16" Height="16" VerticalAlignment="Top" Margin="0,2,0,0" />
                <TextBlock Text="Si desmarcas esto en tu propia cuenta, te auto-revocaras el acceso. Pide a otro admin que lo haga por ti."
                           Foreground="#92400E"
                           FontSize="12"
                           FontWeight="Medium"
                           Margin="8,0,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="420" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Button HorizontalAlignment="Left"
                    Height="40" MinWidth="110"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button HorizontalAlignment="Right"
                    Height="40" MinWidth="140"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#7C3AED" BorderBrush="#7C3AED" Foreground="White"
                    Click="Accept_Click"
                    IsEnabled="{Binding CanAccept, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Guardar cambios" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>