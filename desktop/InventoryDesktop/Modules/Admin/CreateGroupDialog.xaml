<Window x:Class="InventoryDesktop.Modules.Admin.CreateGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nuevo grupo SaaS"
        Width="520"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button" x:Key="SectionToggle">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Domain" Foreground="#7C3AED" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Nuevo grupo SaaS" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Crea el grupo raiz y el Group Owner inicial. El usuario sera asignado con el rol Owner y tendra todos los permisos."
                               FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="440" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,16,0,16">
            <StackPanel>
                <Expander Header="Datos del grupo" IsExpanded="True" FontWeight="SemiBold" Margin="0,0,0,12">
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="GroupNameBox"
                                 materialDesign:HintAssist.Hint="Nombre del grupo"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Domain"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="SLUG (unico, formato kebab-case)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="GroupSlugBox"
                                 materialDesign:HintAssist.Hint="ej: arens-holding"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="LinkVariant"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,0" />
                    </StackPanel>
                </Expander>

                <Expander Header="Datos del Group Owner" IsExpanded="True" FontWeight="SemiBold" Margin="0,0,0,12">
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="NOMBRE" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="OwnerNameBox"
                                 materialDesign:HintAssist.Hint="Nombre del Group Owner"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="CORREO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox x:Name="OwnerEmailBox"
                                 materialDesign:HintAssist.Hint="email@empresa.com"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                            <TextBlock Text="CONTRASENA (opcional, se genera si se deja vacia)" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <PasswordBox x:Name="OwnerPasswordBox"
                                     materialDesign:HintAssist.Hint="Contrasena"
                                     materialDesign:HintAssist.IsFloating="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     FontSize="14"
                                     Margin="0,0,0,0" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Button HorizontalAlignment="Left"
                    Height="40"
                    MinWidth="110"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button HorizontalAlignment="Right"
                    Height="40"
                    MinWidth="140"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Background="#7C3AED"
                    BorderBrush="#7C3AED"
                    Foreground="White"
                    Click="Accept_Click"
                    IsEnabled="{Binding CanAccept, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                    <TextBlock Text="Crear grupo" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
