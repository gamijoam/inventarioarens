<Window x:Class="InventoryDesktop.Modules.Admin.ResetPasswordResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Contrasena reseteada"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <materialDesign:PackIcon Kind="LockReset" Foreground="#7C3AED" Width="22" Height="22" VerticalAlignment="Center" />
            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="Contrasena reseteada" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                <TextBlock Text="Todas las sesiones activas del admin fueron revocadas."
                           FontSize="11" Foreground="#64748B" FontWeight="Light" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,16,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="EmailLabel" Text="CORREO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="EmailValue"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                    <materialDesign:PackIcon Kind="KeyOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="CONTRASENA INICIAL" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Border Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,12">
                    <TextBlock x:Name="PasswordValue"
                               FontFamily="Consolas, Cascadia Mono, monospace"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#FEF3C7"
                BorderBrush="#FBBF24"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertOutline" Foreground="#92400E" Width="16" Height="16" VerticalAlignment="Top" Margin="0,2,0,0" />
                <TextBlock Text="Esta contrasena solo se muestra AHORA. Guardala en un gestor de contrasenas y enviala por un canal seguro."
                           Foreground="#92400E"
                           FontSize="12"
                           FontWeight="Medium"
                           Margin="8,0,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="440" />
            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Height="40" MinWidth="120"
                Margin="0,-40,0,0"
                materialDesign:ButtonAssist.CornerRadius="8"
                Background="#7C3AED" BorderBrush="#7C3AED" Foreground="White"
                Click="Accept_Click"
                FontWeight="Bold">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Check" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                <TextBlock Text="Entendido" Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</Window>