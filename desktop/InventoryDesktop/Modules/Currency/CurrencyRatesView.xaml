<UserControl x:Class="InventoryDesktop.Modules.Currency.CurrencyRatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="#FFFFFF"
                BorderBrush="#E1E7F3"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="TASAS" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="{Binding CountLabel}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Tasas de cambio" FontSize="25" FontWeight="Black" Margin="0,9,0,0" />
                    <TextBlock Text="Consulta las tasas sincronizadas que usa el POS, productos y caja. La administracion se hace desde el portal web."
                               Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="Sincronizar ahora"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding CanRefresh}"
                            Margin="0,0,8,0"
                            Click="SyncNow_Click" />
                    <Button Content="Actualizar"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanRefresh}"
                            Click="Refresh_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,12,0,0">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TIPOS ACTIVOS" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock Text="{Binding ActiveCountLabel}" Style="{StaticResource MetricValueStyle}" Foreground="#059669" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="SIN TASA VIGENTE" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock Text="{Binding MissingCountLabel}" Style="{StaticResource MetricValueStyle}" Foreground="#D9365C" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="PREDETERMINADA" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock Text="{Binding DefaultRateLabel}" Style="{StaticResource MetricValueStyle}" FontSize="18" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="ULTIMA CONSULTA" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock Text="{Binding LastLoadedLabel}" Style="{StaticResource MetricValueStyle}" FontSize="18" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
            <Grid>
                <DataGrid ItemsSource="{Binding Rates}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="40"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIPO" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="CODIGO" Binding="{Binding Code}" Width="100" />
                        <DataGridTextColumn Header="USO" Binding="{Binding DefaultLabel}" Width="140" />
                        <DataGridTextColumn Header="PAR" Binding="{Binding PairLabel}" Width="100" />
                        <DataGridTextColumn Header="TASA VIGENTE" Binding="{Binding CurrentRateLabel}" Width="150" />
                        <DataGridTextColumn Header="VIGENTE DESDE" Binding="{Binding EffectiveLabel}" Width="150" />
                        <DataGridTextColumn Header="FUENTE" Binding="{Binding SourceLabel}" Width="140" />
                        <DataGridTextColumn Header="ESTADO" Binding="{Binding OperationalStatusLabel}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="380"
                        Padding="18"
                        Background="#F8FAFC"
                        BorderBrush="#E1E7F3"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding HasNoRates, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="No hay tasas para mostrar" FontSize="18" FontWeight="Black" TextAlignment="Center" />
                        <TextBlock Text="Sincroniza esta empresa o crea las tasas desde el portal web administrativo."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Black"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
