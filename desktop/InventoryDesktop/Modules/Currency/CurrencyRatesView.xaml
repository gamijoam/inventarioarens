<UserControl x:Class="InventoryDesktop.Modules.Currency.CurrencyRatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CurrencyUsd"
                                                 Foreground="{StaticResource AccentStrongBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Tasas de cambio"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4D35FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding CountLabel}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Height="40" MinWidth="130" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButton}" IsEnabled="{Binding CanRefresh}" Click="SyncNow_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CloudSyncOutline" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Sincronizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Height="40" MinWidth="120" Style="{StaticResource PrimaryActionButton}" IsEnabled="{Binding CanRefresh}" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Actualizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,12,0,0">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                                 Foreground="#059669"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="TIPOS ACTIVOS"
                                   Style="{StaticResource MetricLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveCountLabel}" Style="{StaticResource MetricValueStyle}" Foreground="#059669" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle"
                                                 Foreground="#B91C1C"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="SIN TASA VIGENTE"
                                   Style="{StaticResource MetricLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding MissingCountLabel}" Style="{StaticResource MetricValueStyle}" Foreground="#B91C1C" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Star"
                                                 Foreground="#FBBF24"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="PREDETERMINADA"
                                   Style="{StaticResource MetricLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding DefaultRateLabel}" Style="{StaticResource MetricValueStyle}" FontSize="16" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ClockOutline"
                                                 Foreground="#4D35FF"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="ULTIMA CONSULTA"
                                   Style="{StaticResource MetricLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding LastLoadedLabel}" Style="{StaticResource MetricValueStyle}" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,12,0,0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rates}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="48"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="#E2E8F0" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="20,16" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="Foreground" Value="#475569" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="20,8" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIPO" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="CODIGO" Binding="{Binding Code}" Width="100" />
                        <DataGridTemplateColumn Header="USO" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3" CornerRadius="10"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9" />
                                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                        <Setter Property="BorderBrush" Value="#FDE68A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DefaultLabel}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Foreground" Value="#B45309" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PAR" Binding="{Binding PairLabel}" Width="100" />
                        <DataGridTemplateColumn Header="TASA VIGENTE" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CurrentRateLabel}"
                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="#047857"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="VIGENTE DESDE" Binding="{Binding EffectiveLabel}" Width="160" />
                        <DataGridTextColumn Header="FUENTE" Binding="{Binding SourceLabel}" Width="140" />
                        <DataGridTemplateColumn Header="ESTADO" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3" CornerRadius="10"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FEE2E2" />
                                                <Setter Property="BorderBrush" Value="#FECACA" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NeedsAttention}" Value="False">
                                                        <Setter Property="Background" Value="#D1FAE5" />
                                                        <Setter Property="BorderBrush" Value="#A7F3D0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding OperationalStatusLabel}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#B91C1C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NeedsAttention}" Value="False">
                                                            <Setter Property="Foreground" Value="#047857" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="380" Padding="20"
                        Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12"
                        Visibility="{Binding HasNoRates, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Border Width="56" Height="56" CornerRadius="14" Background="#EEF0FF" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CurrencyUsdOff"
                                                     Foreground="{StaticResource AccentStrongBrush}"
                                                     Width="28" Height="28"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="No hay tasas para mostrar"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   TextAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Text="Sincroniza esta empresa o crea las tasas desde el portal web administrativo."
                                   Foreground="#64748B"
                                   FontWeight="Light"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="18"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <materialDesign:PackIcon Kind="InformationOutline"
                                     Foreground="{Binding StatusBrush}"
                                     Width="14" Height="14"
                                     VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusBrush}"
                       FontWeight="Medium"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="6,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
