<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Detalle del producto"
        Width="1080"
        Height="780"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="MetricChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="ChipLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="ChipValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="Foreground" Value="#10172F" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="DETALLE"
                                           Foreground="{StaticResource AccentStrongBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Margin="6,0,0,0" Padding="8,4" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                            <TextBlock Text="{Binding Detail.Product.Sku}"
                                       Foreground="#475569"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding Detail.Product.Name}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0" />

                    <WrapPanel Margin="0,8,0,0">
                        <Border Padding="8,4" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                            <TextBlock Text="{Binding Detail.Product.TrackingLabel}"
                                       Foreground="{StaticResource AccentStrongBrush}"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Padding="8,4" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="6">
                            <TextBlock Text="{Binding Detail.Product.StatusLabel}"
                                       Foreground="#047857"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Height="36"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="EditProduct_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Editar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Height="36"
                        MinWidth="100"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontWeight="SemiBold"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Cerrar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,12,0,0" SelectionChanged="DetailTabs_SelectionChanged" Background="Transparent" BorderThickness="0">
            <TabItem Header="Resumen">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TagOutline"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="INFORMACION COMERCIAL"
                                           Style="{StaticResource ChipLabelStyle}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding Detail.Product.PriceLabel}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentStrongBrush}"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding Detail.Product.RateLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="{Binding Detail.Product.WarrantyLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="{Binding Detail.Product.UpdatedAt, StringFormat=Actualizado: {0}}"
                                       Foreground="#94A3B8"
                                       FontWeight="Medium"
                                       FontSize="11"
                                       Margin="0,16,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PackageVariantClosed"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="STOCK TOTAL"
                                           Style="{StaticResource ChipLabelStyle}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <UniformGrid Columns="3" Margin="0,12,0,0">
                                <Border Style="{StaticResource MetricChipStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="DISP." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Available}" Style="{StaticResource ChipValueStyle}" Foreground="#047857" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="RES." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Reserved}" Style="{StaticResource ChipValueStyle}" Foreground="#1E40AF" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="DAÑ." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Damaged}" Style="{StaticResource ChipValueStyle}" Foreground="#B45309" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Stock">
                <Border Style="{StaticResource PanelStyle}" Margin="0,12,0,0">
                    <DataGrid ItemsSource="{Binding Detail.Stock.ByWarehouse}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="44"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="14,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ALMACEN" Binding="{Binding WarehouseLabel}" Width="2*" />
                            <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="2*" />
                            <DataGridTextColumn Header="DISP." Binding="{Binding Available}" Width="*" />
                            <DataGridTextColumn Header="RES." Binding="{Binding Reserved}" Width="*" />
                            <DataGridTextColumn Header="DAÑ." Binding="{Binding Damaged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Seriales / IMEI">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SerialSearchBox"
                                     Height="40"
                                     Margin="0,0,10,0"
                                     FontSize="13"
                                     Padding="10,0"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     ToolTip="Buscar IMEI o serial" />
                            <ComboBox x:Name="SerialStatusBox"
                                      Grid.Column="1"
                                      Height="40"
                                      Margin="0,0,10,0"
                                      FontSize="13"
                                      Padding="10,0"
                                      ItemsSource="{Binding SerialStatusOptions}"
                                      SelectedItem="{Binding SelectedSerialStatus}"
                                      DisplayMemberPath="Label" />
                            <ComboBox x:Name="SerialWarehouseBox"
                                      Grid.Column="2"
                                      Height="40"
                                      ItemsSource="{Binding WarehouseFilterOptions}"
                                      SelectedItem="{Binding SelectedSerialWarehouse}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="3"
                                    Height="40"
                                    MinWidth="100"
                                    Margin="10,0,0,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontWeight="SemiBold"
                                    Click="SearchSerials_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Buscar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4"
                                    Height="40"
                                    MinWidth="100"
                                    Margin="8,0,0,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontWeight="SemiBold"
                                    Click="ClearSerials_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SerialRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="44"
                              Margin="0,12,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="14,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IMEI / SERIAL" Binding="{Binding SerialNumber}" Width="2*" />
                            <DataGridTextColumn Header="TIPO" Binding="{Binding SerialType}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="*" />
                            <DataGridTextColumn Header="ALMACEN" Binding="{Binding WarehouseLabel}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SerialStatusMessage}"
                                       Foreground="{Binding SerialStatusBrush}"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoPreviousSerials}" Click="PreviousSerials_Click"
                                    ToolTip="Pagina anterior">
                                <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                            <Button Width="32" Height="32" Padding="0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoNextSerials}" Click="NextSerials_Click"
                                    ToolTip="Pagina siguiente">
                                <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Movimientos">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MovementSearchBox" Height="40" Margin="0,0,10,0" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" ToolTip="Buscar motivo o referencia" />
                            <ComboBox x:Name="MovementTypeBox" Grid.Column="1" Height="40" Margin="0,0,10,0" FontSize="13" Padding="10,0" ItemsSource="{Binding MovementTypeOptions}" SelectedItem="{Binding SelectedMovementType}" DisplayMemberPath="Label" />
                            <ComboBox x:Name="MovementWarehouseBox" Grid.Column="2" Height="40" FontSize="13" Padding="10,0" ItemsSource="{Binding WarehouseFilterOptions}" SelectedItem="{Binding SelectedMovementWarehouse}" DisplayMemberPath="Label" />
                            <TextBox x:Name="MovementDateFromBox" Grid.Column="3" Height="40" Margin="10,0,0,0" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" ToolTip="Desde: yyyy-mm-dd" />
                            <TextBox x:Name="MovementDateToBox" Grid.Column="4" Height="40" Margin="10,0,0,0" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" ToolTip="Hasta: yyyy-mm-dd" />
                            <Button Grid.Column="5" Height="40" MinWidth="100" Margin="10,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="SearchMovements_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Buscar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="6" Height="40" MinWidth="100" Margin="8,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="ClearMovements_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding MovementRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="44"
                              Margin="0,12,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="14,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="1.3*" />
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TypeLabel}" Width="1.2*" />
                            <DataGridTextColumn Header="CANT." Binding="{Binding Quantity}" Width="*" />
                            <DataGridTextColumn Header="ALMACEN" Binding="{Binding WarehouseLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="MOTIVO" Binding="{Binding ReasonLabel}" Width="2*" />
                            <DataGridTextColumn Header="USUARIO" Binding="{Binding CreatedByLabel}" Width="1.2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding MovementStatusMessage}"
                                       Foreground="{Binding MovementStatusBrush}"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoPreviousMovements}" Click="PreviousMovements_Click"
                                    ToolTip="Pagina anterior">
                                <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                            <Button Width="32" Height="32" Padding="0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoNextMovements}" Click="NextMovements_Click"
                                    ToolTip="Pagina siguiente">
                                <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Precios">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="16">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TagMultiple"
                                                             Foreground="{StaticResource AccentBrush}"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Precios por lista"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Configura precios al mayor, detal, tecnico u otras listas."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Light"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxWidth="500"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Height="40" MinWidth="100" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="CopyBasePrices_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentCopy" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Copiar base" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Height="40" MinWidth="100" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="ReloadPrices_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Recargar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Height="40" MinWidth="100" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="OpenPriceHistory_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="History" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Historial" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Height="40" MinWidth="100" Margin="0,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Click="SavePrices_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Guardar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProductPriceRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="56"
                              Margin="0,12,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="14,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="LISTA" Width="1.35*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PriceListName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PriceListCode}" FontSize="11" FontWeight="Medium" Foreground="#8090AD" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="USARA EL POS" Width="1.45*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PosPriceLabel}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PriceSourceLabel}" FontSize="11" FontWeight="Medium" Foreground="{Binding PriceSourceBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="PRECIO LISTA" Width="1.05*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,0" BorderBrush="#E2E8F0" BorderThickness="1" VerticalContentAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="MONEDA" Width="1.05*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.PriceCurrencyOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding SelectedCurrency}" DisplayMemberPath="Label" Height="32" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TASA" Width="1.45*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.PriceRateTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding SelectedRateType}" DisplayMemberPath="Label" Height="32" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="ACTIVO" Binding="{Binding IsActive}" Width="0.65*" />
                            <DataGridTemplateColumn Header="" Width="0.9*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Copiar base" Click="CopyBasePrice_Click">
                                            <materialDesign:PackIcon Kind="ContentCopy" Foreground="{StaticResource AccentBrush}" Width="16" Height="16" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Foreground="{Binding PriceStatusBrush}"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PriceStatusMessage}"
                                   Foreground="{Binding PriceStatusBrush}"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Auditoria">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AuditSearchBox" Height="40" Margin="0,0,10,0" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" ToolTip="Buscar usuario o correo" />
                            <ComboBox x:Name="AuditActionBox" Grid.Column="1" Height="40" FontSize="13" Padding="10,0" ItemsSource="{Binding AuditActionOptions}" SelectedItem="{Binding SelectedAuditAction}" DisplayMemberPath="Label" />
                            <Button Grid.Column="2" Height="40" MinWidth="100" Margin="10,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="SearchAudits_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Buscar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3" Height="40" MinWidth="100" Margin="8,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="ClearAudits_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AuditRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="44"
                              Margin="0,12,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="14,10" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="ACCION" Binding="{Binding ActionLabel}" Width="1.1*" />
                            <DataGridTextColumn Header="USUARIO" Binding="{Binding CreatedByLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="CORREO" Binding="{Binding CreatedByEmailLabel}" Width="1.8*" />
                            <DataGridTextColumn Header="CAMBIOS" Binding="{Binding ChangesLabel}" Width="2.6*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding AuditStatusMessage}"
                                       Foreground="{Binding AuditStatusBrush}"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoPreviousAudits}" Click="PreviousAudits_Click"
                                    ToolTip="Pagina anterior">
                                <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                            <Button Width="32" Height="32" Padding="0"
                                    Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                                    IsEnabled="{Binding CanGoNextAudits}" Click="NextAudits_Click"
                                    ToolTip="Pagina siguiente">
                                <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,12,0,0" Padding="20,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Usa estas acciones para mover inventario o consultar el Kardex completo del producto."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="Light"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               MaxWidth="500"
                               Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Height="40" MinWidth="140" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="OpenEntry_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowDownBoldBoxOutline" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Registrar entrada" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Height="40" MinWidth="140" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="OpenExit_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowUpBoldBoxOutline" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Registrar salida" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Height="40" MinWidth="120" materialDesign:ButtonAssist.CornerRadius="8" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Click="OpenKardex_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Ver Kardex" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
