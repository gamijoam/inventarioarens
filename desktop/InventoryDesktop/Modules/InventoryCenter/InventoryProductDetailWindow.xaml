<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del producto"
        Width="880"
        Height="720"
        MinWidth="780"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <Style x:Key="MetricChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E1E7F3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="ChipLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="ChipValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#10172F" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,18,0,9" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="DETALLE" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="{Binding Product.Sku}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding Product.Name}" FontSize="27" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                    <WrapPanel Margin="0,10,0,0">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" Margin="0,0,7,7">
                            <TextBlock Text="{Binding Product.TrackingLabel}" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border Padding="9,5" Background="#ECFDF5" BorderBrush="#B8F0D2" BorderThickness="1" CornerRadius="7" Margin="0,0,7,7">
                            <TextBlock Text="{Binding Product.StatusLabel}" Foreground="#047857" FontSize="11" FontWeight="Black" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <Button Content="Cerrar"
                        Width="96"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Close_Click" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Información comercial" FontWeight="Black" FontSize="16" />
                            <TextBlock Text="{Binding Product.PriceLabel}" FontSize="22" FontWeight="Black" Margin="0,12,0,0" />
                            <TextBlock Text="{Binding Product.RateLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding Product.WarrantyLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="16" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Stock total" FontWeight="Black" FontSize="16" />
                            <UniformGrid Columns="3" Margin="0,12,0,0">
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="DISP." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Stock.Totals.Available}" Style="{StaticResource ChipValueStyle}" Foreground="#047857" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="RES." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Stock.Totals.Reserved}" Style="{StaticResource ChipValueStyle}" Foreground="#3157C8" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="DAÑ." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Stock.Totals.Damaged}" Style="{StaticResource ChipValueStyle}" Foreground="#B45309" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Stock por almacén" Style="{StaticResource SectionTitleStyle}" />
                <ItemsControl ItemsSource="{Binding Stock.ByWarehouse}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="13" Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#E9EEF7" BorderThickness="1" CornerRadius="9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding WarehouseLabel}" FontWeight="Black" />
                                        <TextBlock Text="{Binding BranchLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock FontWeight="Black" Foreground="#047857" Margin="0,0,12,0">
                                            <Run Text="{Binding Available, Mode=OneWay}" />
                                            <Run Text=" disp." />
                                        </TextBlock>
                                        <TextBlock FontWeight="Black" Foreground="#3157C8" Margin="0,0,12,0">
                                            <Run Text="{Binding Reserved, Mode=OneWay}" />
                                            <Run Text=" res." />
                                        </TextBlock>
                                        <TextBlock FontWeight="Black" Foreground="#B45309">
                                            <Run Text="{Binding Damaged, Mode=OneWay}" />
                                            <Run Text=" dañ." />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Seriales / IMEI" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding Serials.Total, StringFormat={}{0} seriales registrados}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding Serials.Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,0,0,8" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SerialNumber}" FontWeight="Black" />
                                        <TextBlock Text="{Binding WarehouseLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                                        <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Movimientos recientes" Style="{StaticResource SectionTitleStyle}" />
                <ItemsControl ItemsSource="{Binding RecentMovements}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#E9EEF7" BorderThickness="1" CornerRadius="9">
                                <StackPanel>
                                    <TextBlock FontWeight="Black">
                                        <Run Text="{Binding TypeLabel, Mode=OneWay}" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding Quantity, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding ReasonLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding WarehouseLabel}" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Auditoría reciente" Style="{StaticResource SectionTitleStyle}" />
                <ItemsControl ItemsSource="{Binding RecentAudits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#E9EEF7" BorderThickness="1" CornerRadius="9">
                                <StackPanel>
                                    <TextBlock Text="{Binding ActionLabel}" FontWeight="Black" />
                                    <TextBlock Text="{Binding CreatedByLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="12" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Consulta el historial completo de entradas, salidas, traslados, ventas y ajustes de este producto."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Registrar entrada"
                        Width="150"
                        Height="38"
                        Margin="14,0,0,0"
                        FontWeight="Black"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Click="OpenEntry_Click" />
                <Button Grid.Column="2"
                        Content="Registrar salida"
                        Width="140"
                        Height="38"
                        Margin="10,0,0,0"
                        FontWeight="Black"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Click="OpenExit_Click" />
                <Button Grid.Column="3"
                        Content="Ver Kardex"
                        Width="124"
                        Height="38"
                        Margin="10,0,0,0"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="OpenKardex_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
