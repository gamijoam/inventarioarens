<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del producto"
        Width="1040"
        Height="760"
        MinWidth="920"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E1E7F3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="MetricChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#F8FAFE" />
            <Setter Property="BorderBrush" Value="#E1E7F3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="ChipLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="ChipValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#10172F" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="DETALLE" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="{Binding Detail.Product.Sku}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding Detail.Product.Name}" FontSize="27" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                    <WrapPanel Margin="0,10,0,0">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" Margin="0,0,7,7">
                            <TextBlock Text="{Binding Detail.Product.TrackingLabel}" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border Padding="9,5" Background="#ECFDF5" BorderBrush="#B8F0D2" BorderThickness="1" CornerRadius="7" Margin="0,0,7,7">
                            <TextBlock Text="{Binding Detail.Product.StatusLabel}" Foreground="#047857" FontSize="11" FontWeight="Black" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Editar"
                        Width="96"
                        Height="36"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="EditProduct_Click" />

                <Button Grid.Column="2"
                        Content="Cerrar"
                        Width="96"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Close_Click" />
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,16,0,0" SelectionChanged="DetailTabs_SelectionChanged">
            <TabItem Header="Resumen">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Información comercial" FontWeight="Black" FontSize="16" />
                            <TextBlock Text="{Binding Detail.Product.PriceLabel}" FontSize="24" FontWeight="Black" Margin="0,14,0,0" />
                            <TextBlock Text="{Binding Detail.Product.RateLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Detail.Product.WarrantyLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding Detail.Product.UpdatedAt, StringFormat=Actualizado: {0}}" Foreground="#94A3B8" FontWeight="Bold" Margin="0,16,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Stock total" FontWeight="Black" FontSize="16" />
                            <UniformGrid Columns="3" Margin="0,14,0,0">
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="DISP." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Available}" Style="{StaticResource ChipValueStyle}" Foreground="#047857" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="RES." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Reserved}" Style="{StaticResource ChipValueStyle}" Foreground="#3157C8" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricChipStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="DAÑ." Style="{StaticResource ChipLabelStyle}" />
                                        <TextBlock Text="{Binding Detail.Stock.Totals.Damaged}" Style="{StaticResource ChipValueStyle}" Foreground="#B45309" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Stock">
                <Border Style="{StaticResource PanelStyle}" Margin="0,14,0,0">
                    <DataGrid ItemsSource="{Binding Detail.Stock.ByWarehouse}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ALMACÉN" Binding="{Binding WarehouseLabel}" Width="2*" />
                            <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="2*" />
                            <DataGridTextColumn Header="DISP." Binding="{Binding Available}" Width="*" />
                            <DataGridTextColumn Header="RES." Binding="{Binding Reserved}" Width="*" />
                            <DataGridTextColumn Header="DAÑ." Binding="{Binding Damaged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Seriales / IMEI">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SerialSearchBox" Height="36" Margin="0,0,10,0" ToolTip="Buscar IMEI o serial" />
                            <ComboBox x:Name="SerialStatusBox"
                                      Grid.Column="1"
                                      Height="36"
                                      Margin="0,0,10,0"
                                      ItemsSource="{Binding SerialStatusOptions}"
                                      SelectedItem="{Binding SelectedSerialStatus}"
                                      DisplayMemberPath="Label" />
                            <ComboBox x:Name="SerialWarehouseBox"
                                      Grid.Column="2"
                                      Height="36"
                                      ItemsSource="{Binding WarehouseFilterOptions}"
                                      SelectedItem="{Binding SelectedSerialWarehouse}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="3" Content="Buscar" Width="96" Height="36" Margin="10,0,0,0" FontWeight="Black" Click="SearchSerials_Click" />
                            <Button Grid.Column="4" Content="Limpiar" Width="86" Height="36" Margin="8,0,0,0" FontWeight="Black" Click="ClearSerials_Click" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SerialRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,12,0,0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IMEI / SERIAL" Binding="{Binding SerialNumber}" Width="2*" />
                            <DataGridTextColumn Header="TIPO" Binding="{Binding SerialType}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="*" />
                            <DataGridTextColumn Header="ALMACÉN" Binding="{Binding WarehouseLabel}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SerialStatusMessage}" Foreground="{Binding SerialStatusBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Anterior" Width="96" Height="36" FontWeight="Black" IsEnabled="{Binding CanGoPreviousSerials}" Click="PreviousSerials_Click" />
                        <Button Grid.Column="2" Content="Siguiente" Width="96" Height="36" Margin="8,0,0,0" FontWeight="Black" IsEnabled="{Binding CanGoNextSerials}" Click="NextSerials_Click" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Movimientos">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MovementSearchBox" Height="36" Margin="0,0,10,0" ToolTip="Buscar motivo o referencia" />
                            <ComboBox x:Name="MovementTypeBox"
                                      Grid.Column="1"
                                      Height="36"
                                      Margin="0,0,10,0"
                                      ItemsSource="{Binding MovementTypeOptions}"
                                      SelectedItem="{Binding SelectedMovementType}"
                                      DisplayMemberPath="Label" />
                            <ComboBox x:Name="MovementWarehouseBox"
                                      Grid.Column="2"
                                      Height="36"
                                      ItemsSource="{Binding WarehouseFilterOptions}"
                                      SelectedItem="{Binding SelectedMovementWarehouse}"
                                      DisplayMemberPath="Label" />
                            <TextBox x:Name="MovementDateFromBox" Grid.Column="3" Height="36" Margin="10,0,0,0" ToolTip="Desde: yyyy-mm-dd" />
                            <TextBox x:Name="MovementDateToBox" Grid.Column="4" Height="36" Margin="10,0,0,0" ToolTip="Hasta: yyyy-mm-dd" />
                            <Button Grid.Column="5" Content="Buscar" Width="96" Height="36" Margin="10,0,0,0" FontWeight="Black" Click="SearchMovements_Click" />
                            <Button Grid.Column="6" Content="Limpiar" Width="86" Height="36" Margin="8,0,0,0" FontWeight="Black" Click="ClearMovements_Click" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding MovementRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,12,0,0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="1.3*" />
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TypeLabel}" Width="1.2*" />
                            <DataGridTextColumn Header="CANT." Binding="{Binding Quantity}" Width="*" />
                            <DataGridTextColumn Header="ALMACÉN" Binding="{Binding WarehouseLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="MOTIVO" Binding="{Binding ReasonLabel}" Width="2*" />
                            <DataGridTextColumn Header="USUARIO" Binding="{Binding CreatedByLabel}" Width="1.2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding MovementStatusMessage}" Foreground="{Binding MovementStatusBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Anterior" Width="96" Height="36" FontWeight="Black" IsEnabled="{Binding CanGoPreviousMovements}" Click="PreviousMovements_Click" />
                        <Button Grid.Column="2" Content="Siguiente" Width="96" Height="36" Margin="8,0,0,0" FontWeight="Black" IsEnabled="{Binding CanGoNextMovements}" Click="NextMovements_Click" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Precios">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="12">
                        <Grid>
                            <StackPanel Margin="0,0,410,0">
                                <TextBlock Text="Precios por lista" FontWeight="Black" FontSize="16" />
                                <TextBlock Text="Configura precios al mayor, detal, técnico u otras listas. Si una lista queda sin precio, el POS usará el precio base del producto."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Copiar base a vacíos" Width="150" Height="36" FontWeight="Black" Click="CopyBasePrices_Click" />
                                <Button Content="Recargar" Width="96" Height="36" Margin="8,0,0,0" FontWeight="Black" Click="ReloadPrices_Click" />
                                <Button Content="Ver historial" Width="112" Height="36" Margin="8,0,0,0" FontWeight="Black" Click="OpenPriceHistory_Click" />
                                <Button Content="Guardar precios" Width="132" Height="36" Margin="8,0,0,0" FontWeight="Black" Background="{StaticResource AccentBrush}" Foreground="White" Click="SavePrices_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ProductPriceRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="0,12,0,0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="LISTA" Width="1.35*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PriceListName}" FontWeight="Black" />
                                            <TextBlock Text="{Binding PriceListCode}" FontSize="11" FontWeight="SemiBold" Foreground="#8090AD" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="USARÁ EL POS" Width="1.45*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PosPriceLabel}" FontWeight="Black" />
                                            <TextBlock Text="{Binding PriceSourceLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PriceSourceBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="PRECIO LISTA" Width="1.05*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="MONEDA" Width="1.05*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.PriceCurrencyOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedCurrency}"
                                                  DisplayMemberPath="Label"
                                                  Height="32" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TASA" Width="1.45*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.PriceRateTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedRateType}"
                                                  DisplayMemberPath="Label"
                                                  Height="32" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="ACTIVO" Binding="{Binding IsActive}" Width="0.65*" />
                            <DataGridTemplateColumn Header="ACCIÓN" Width="0.9*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Copiar base" Height="30" FontWeight="Black" Click="CopyBasePrice_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="{Binding PriceStatusMessage}" Foreground="{Binding PriceStatusBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,12,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Auditoría">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AuditSearchBox" Height="36" Margin="0,0,10,0" ToolTip="Buscar usuario o correo" />
                            <ComboBox x:Name="AuditActionBox"
                                      Grid.Column="1"
                                      Height="36"
                                      ItemsSource="{Binding AuditActionOptions}"
                                      SelectedItem="{Binding SelectedAuditAction}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="2" Content="Buscar" Width="96" Height="36" Margin="10,0,0,0" FontWeight="Black" Click="SearchAudits_Click" />
                            <Button Grid.Column="3" Content="Limpiar" Width="86" Height="36" Margin="8,0,0,0" FontWeight="Black" Click="ClearAudits_Click" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AuditRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,12,0,0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="ACCIÓN" Binding="{Binding ActionLabel}" Width="1.1*" />
                            <DataGridTextColumn Header="USUARIO" Binding="{Binding CreatedByLabel}" Width="1.4*" />
                            <DataGridTextColumn Header="CORREO" Binding="{Binding CreatedByEmailLabel}" Width="1.8*" />
                            <DataGridTextColumn Header="CAMBIOS" Binding="{Binding ChangesLabel}" Width="2.6*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding AuditStatusMessage}" Foreground="{Binding AuditStatusBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Anterior" Width="96" Height="36" FontWeight="Black" IsEnabled="{Binding CanGoPreviousAudits}" Click="PreviousAudits_Click" />
                        <Button Grid.Column="2" Content="Siguiente" Width="96" Height="36" Margin="8,0,0,0" FontWeight="Black" IsEnabled="{Binding CanGoNextAudits}" Click="NextAudits_Click" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Padding="12" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Usa estas acciones para mover inventario o consultar el Kardex completo del producto."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Registrar entrada"
                        Width="150"
                        Height="38"
                        Margin="14,0,0,0"
                        FontWeight="Black"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Click="OpenEntry_Click" />
                <Button Grid.Column="2"
                        Content="Registrar salida"
                        Width="140"
                        Height="38"
                        Margin="10,0,0,0"
                        FontWeight="Black"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Click="OpenExit_Click" />
                <Button Grid.Column="3"
                        Content="Ver Kardex"
                        Width="124"
                        Height="38"
                        Margin="10,0,0,0"
                        FontWeight="Black"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="OpenKardex_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
