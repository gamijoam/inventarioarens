<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryAlertsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alertas operativas"
        Width="760"
        Height="560"
        MinWidth="660"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#5038F2" />
            <Setter Property="BorderBrush" Value="#5038F2" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5D6B88" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="#FFFFFF"
                BorderBrush="#E1E7F3"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Padding="9,5"
                            Background="#FFF7ED"
                            BorderBrush="#FED7AA"
                            BorderThickness="1"
                            CornerRadius="7"
                            HorizontalAlignment="Left">
                        <TextBlock Text="REVISIÓN OPERATIVA" Foreground="#B45309" FontSize="10" FontWeight="Black" />
                    </Border>
                    <TextBlock Text="Alertas operativas" FontSize="26" FontWeight="Black" Margin="0,10,0,0" />
                    <TextBlock Text="Revisa los productos que requieren atención antes de vender, reponer o ajustar inventario."
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        Background="#EEF0FF"
                        BorderBrush="#DCE4FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding CountLabel}" Foreground="#2F24D6" FontWeight="Black" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="16"
                                Background="#FFFFFF"
                                BorderBrush="#FED7AA"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="48"
                                        Height="48"
                                        Background="#FFF7ED"
                                        BorderBrush="#FED7AA"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding CountLabel}"
                                               Foreground="#B45309"
                                               FontSize="18"
                                               FontWeight="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Black" Foreground="#10172F" />
                                        <Border Margin="10,0,0,0"
                                                Padding="8,3"
                                                Background="#F7F9FD"
                                                BorderBrush="#E1E7F3"
                                                BorderThickness="1"
                                                CornerRadius="7">
                                            <TextBlock Text="{Binding SeverityLabel}" Foreground="#5D6B88" FontSize="10" FontWeight="Black" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Message}" Style="{StaticResource MutedTextStyle}" Margin="0,7,0,0" />

                                    <TextBlock Text="Productos de ejemplo" Foreground="#8A97B1" FontSize="10" FontWeight="Black" Margin="0,12,0,3" />
                                    <TextBlock Text="{Binding ProductNamesLabel}" Foreground="#475569" FontWeight="SemiBold" TextWrapping="Wrap" />

                                    <Border Margin="0,12,0,0"
                                            Padding="10"
                                            Background="#FFFDF9"
                                            BorderBrush="#FED7AA"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Text="{Binding Action}" Foreground="#B45309" FontWeight="Black" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Cerrar"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="Close_Click" />
    </Grid>
</Window>
