<UserControl x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#4D35FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Productos" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TotalProductsLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Disponible" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AvailableLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#047857" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#3157C8" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Reservado" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReservedLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#1E40AF" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Danado" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DamagedLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#B45309" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Stock bajo" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LowStockLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#B91C1C" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#475569" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Sin stock" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WithoutStockLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#475569" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Width="36" Height="36" Padding="0" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            IsEnabled="{Binding HasAlerts}"
                            ToolTip="Abrir alertas operativas"
                            Click="OpenAlerts_Click">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource MutedBrush}" Width="18" Height="18" />
                    </Button>
                    <Button Width="36" Height="36" Padding="0" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Acciones masivas"
                            Click="BulkActions_Click">
                        <materialDesign:PackIcon Kind="PlaylistEdit" Foreground="{StaticResource MutedBrush}" Width="18" Height="18" />
                    </Button>
                    <Button Width="36" Height="36" Padding="0" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Exportar CSV"
                            Click="ExportCsv_Click">
                        <materialDesign:PackIcon Kind="FileDownloadOutline" Foreground="{StaticResource MutedBrush}" Width="18" Height="18" />
                    </Button>
                    <Button Width="36" Height="36" Padding="0" Margin="0,0,8,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Actualizar"
                            Click="Refresh_Click">
                        <materialDesign:PackIcon Kind="Refresh" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" />
                    </Button>
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            ToolTip="Crear producto"
                            Click="CreateProduct_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PlusCircleOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Nuevo" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,12,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="BUSCAR"
                                   Style="{StaticResource FilterLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="40"
                             FontSize="13"
                             Padding="10,0"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             ToolTip="Buscar por nombre, SKU o serial/IMEI" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShapeOutline"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="TIPO"
                                   Style="{StaticResource FilterLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding TrackingOptions}"
                              SelectedValue="{Binding TrackingType, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label"
                              MinHeight="40"
                              FontSize="13"
                              Padding="10,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartLineVariant"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="ESTADO"
                                   Style="{StaticResource FilterLabelStyle}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding StockOptions}"
                              SelectedValue="{Binding StockStatus, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label"
                              MinHeight="40"
                              FontSize="13"
                              Padding="10,0" />
                </StackPanel>

                <Button Grid.Column="3"
                        Height="40"
                        Margin="0,22,8,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="ApplyFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterOutline" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Aplicar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="4"
                        Height="40"
                        Margin="0,22,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        Foreground="{StaticResource InkBrush}"
                        FontWeight="SemiBold"
                        Click="ClearFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,12,0,0">
            <Grid>
                <DataGrid x:Name="ProductsGrid"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowHeight="44"
                          BorderThickness="0"
                          Background="Transparent"
                          AlternationCount="2"
                          HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick"
                          SelectionChanged="ProductsGrid_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC" />
                            <Setter Property="BorderBrush" Value="#E2E8F0" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="14,10" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="Foreground" Value="#475569" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="14,4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#FFFFFF" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="PRODUCTO" Width="2.3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource InkBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Sku}"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="#8090AD"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="CONTROL" Binding="{Binding TrackingLabel, Mode=OneWay}" Width="1.1*" />
                        <DataGridTextColumn Header="PRECIO" Binding="{Binding PriceLabel, Mode=OneWay}" Width="0.85*" />
                        <DataGridTextColumn Header="DISP." Binding="{Binding Stock.Available, Mode=OneWay}" Width="0.65*" />
                        <DataGridTextColumn Header="RES." Binding="{Binding Stock.Reserved, Mode=OneWay}" Width="0.6*" />
                        <DataGridTextColumn Header="DAÑ." Binding="{Binding Stock.Damaged, Mode=OneWay}" Width="0.6*" />
                        <DataGridTemplateColumn Header="ESTADO" Width="0.9*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                                <Setter Property="Background" Value="#EEF0FF" />
                                                <Setter Property="BorderBrush" Value="#DCE4FF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StockStatusLabel}" Value="Agotado">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                        <Setter Property="BorderBrush" Value="#FECACA" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockStatusLabel}" Value="Stock bajo">
                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                        <Setter Property="BorderBrush" Value="#FDE68A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockStatusLabel}" Value="Disponible">
                                                        <Setter Property="Background" Value="#D1FAE5" />
                                                        <Setter Property="BorderBrush" Value="#A7F3D0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StockStatusLabel}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentStrongBrush}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="0.7*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Button Width="30" Height="30"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="Ver detalle"
                                                Click="ViewProduct_Click">
                                            <materialDesign:PackIcon Kind="EyeOutline"
                                                                     Foreground="{StaticResource AccentBrush}"
                                                                     Width="16" Height="16" />
                                        </Button>
                                        <Button Width="30" Height="30"
                                                Padding="0"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="Editar"
                                                Click="EditProduct_Click">
                                            <materialDesign:PackIcon Kind="PencilOutline"
                                                                     Foreground="#B45309"
                                                                     Width="16" Height="16" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#FBFDFF"
                        BorderBrush="#E6ECF5"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#EEF0FF" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="PackageVariantClosedRemove"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding EmptyStateTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Text="{Binding EmptyStateMessage}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="21"
                                   Margin="0,7,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#B3FFFFFF"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Width="290"
                            Padding="20"
                            Background="#FFFFFF"
                            BorderBrush="#DCE4F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Height="6" />
                            <TextBlock Text="Cargando inventario..."
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="InformationOutline"
                                         Foreground="{StaticResource MutedBrush}"
                                         Width="14" Height="14"
                                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="6,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedProductsLabel}"
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"
                           Visibility="{Binding HasSelectedProducts, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{Binding PaginationLabel}"
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />
                <Button Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                        Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                        IsEnabled="{Binding CanGoPrevious}" Click="PreviousPage_Click"
                        ToolTip="Pagina anterior">
                    <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                </Button>
                <Button Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                        IsEnabled="{Binding CanGoNext}" Click="NextPage_Click"
                        ToolTip="Pagina siguiente">
                    <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
