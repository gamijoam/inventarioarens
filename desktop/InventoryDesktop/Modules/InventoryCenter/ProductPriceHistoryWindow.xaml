<Window x:Class="InventoryDesktop.Modules.InventoryCenter.ProductPriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Historial de precios"
        Width="920"
        Height="560"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#5038F2" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5D6B88" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelStyle}" Padding="18">
            <Grid>
                <StackPanel Margin="0,0,160,0">
                    <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                        <TextBlock Text="PRECIOS" Foreground="#2F24D6" FontSize="10" FontWeight="Black" />
                    </Border>
                    <TextBlock Text="Historial de precios" FontSize="25" FontWeight="Black" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding ProductName}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>

                <Button Content="Recargar"
                        Width="120"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontWeight="Black"
                        Click="Reload_Click" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="0,14,0,0"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None">
            <DataGrid.Columns>
                <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel}" Width="1.25*" />
                <DataGridTextColumn Header="LISTA" Binding="{Binding ListLabel}" Width="1.45*" />
                <DataGridTextColumn Header="ANTES" Binding="{Binding BeforeLabel}" Width="1.15*" />
                <DataGridTextColumn Header="DESPUÃ‰S" Binding="{Binding AfterLabel}" Width="1.15*" />
                <DataGridTextColumn Header="USUARIO" Binding="{Binding UserLabel}" Width="1.2*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}" Padding="12" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Height="40"
                            MinWidth="120"
                            Margin="0,0,8,0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontWeight="Bold"
                            Click="BackToModules_Click"
                            ToolTip="Volver al centro de modulos">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Height="40"
                            MinWidth="100"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontWeight="SemiBold"
                            Click="Close_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Cerrar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


