<UserControl x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryMovementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#4D35FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Listado" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PaginationLabel}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Height="40" MinWidth="120" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Actualizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,12,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="BUSCAR PRODUCTO"
                                   Foreground="#64718C"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="SearchBox"
                             Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             FontSize="13"
                             Padding="10,0"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             KeyDown="SearchBox_KeyDown"
                             ToolTip="Buscar por nombre, SKU o serial/IMEI (Enter para buscar)" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="40"
                        MinWidth="110"
                        Margin="0,22,8,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="ApplyFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Aplicar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="40"
                        MinWidth="110"
                        Margin="0,22,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontWeight="SemiBold"
                        Click="ClearFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,12,0,0">
            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      AlternationCount="2"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="48"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC" />
                        <Setter Property="BorderBrush" Value="#E2E8F0" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Padding" Value="14,12" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="FontSize" Value="10" />
                        <Setter Property="Foreground" Value="#475569" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="14,4" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F8FAFC" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="0,4">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource InkBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Sku}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="#8090AD"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="CONTROL" Binding="{Binding TrackingLabel, Mode=OneWay}" Width="150" />
                    <DataGridTextColumn Header="DISP." Binding="{Binding Stock.Available, Mode=OneWay}" Width="80" />
                    <DataGridTextColumn Header="RES." Binding="{Binding Stock.Reserved, Mode=OneWay}" Width="80" />
                    <DataGridTemplateColumn Header="ACCIONES" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Height="36" MinWidth="100" Margin="0,0,6,0"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Background="#ECFDF5"
                                            BorderBrush="#A7F3D0"
                                            Foreground="#047857"
                                            FontWeight="SemiBold"
                                            Click="Entry_Click"
                                            ToolTip="Registrar entrada de inventario">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowDownBoldBoxOutline" Foreground="#047857" Width="14" Height="14" VerticalAlignment="Center" />
                                            <TextBlock Text="Entrada" Margin="6,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Height="36" MinWidth="100"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Background="#FEF3C7"
                                            BorderBrush="#FDE68A"
                                            Foreground="#B45309"
                                            FontWeight="SemiBold"
                                            Click="Exit_Click"
                                            ToolTip="Registrar salida de inventario">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowUpBoldBoxOutline" Foreground="#B45309" Width="14" Height="14" VerticalAlignment="Center" />
                                            <TextBlock Text="Salida" Margin="6,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="InformationOutline"
                                         Foreground="{StaticResource MutedBrush}"
                                         Width="14" Height="14"
                                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                        Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                        IsEnabled="{Binding CanGoPrevious}" Click="PreviousPage_Click"
                        ToolTip="Pagina anterior">
                    <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                </Button>
                <Button Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderBrush="#CBD5E1" Cursor="Hand"
                        IsEnabled="{Binding CanGoNext}" Click="NextPage_Click"
                        ToolTip="Pagina siguiente">
                    <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource InkBrush}" Width="16" Height="16" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
