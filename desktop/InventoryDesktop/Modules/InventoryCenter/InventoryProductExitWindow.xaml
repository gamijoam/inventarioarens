<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductExitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar salida"
        Width="720"
        Height="720"
        MinWidth="640"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Border Padding="9,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                    <TextBlock Text="SALIDA" Foreground="#B45309" FontSize="10" FontWeight="Black" />
                </Border>
                <TextBlock Text="{Binding ProductName}" FontSize="26" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                <TextBlock Text="{Binding ProductSku}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Almacén" FontWeight="Black" />
                        <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" DisplayMemberPath="WarehouseLabel" Height="38" Margin="0,6,0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Cantidad" FontWeight="Black" />
                                <TextBox x:Name="QuantityBox" Height="38" Margin="0,6,0,14" Text="1" TextChanged="QuantityBox_TextChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Motivo" FontWeight="Black" />
                                <ComboBox x:Name="ReasonBox" ItemsSource="{Binding Reasons}" SelectedItem="{Binding SelectedReason}" DisplayMemberPath="Label" Height="38" Margin="0,6,0,14" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Referencia" FontWeight="Black" />
                        <TextBox x:Name="ReferenceBox" Height="38" Margin="0,6,0,14" />

                        <TextBlock Text="Notas" FontWeight="Black" />
                        <TextBox x:Name="NotesBox" Height="72" Margin="0,6,0,14" TextWrapping="Wrap" AcceptsReturn="True" />

                        <StackPanel x:Name="SerialsPanel">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="IMEI / seriales disponibles" FontWeight="Black" />
                                    <TextBlock Text="Busca y selecciona exactamente los IMEI/seriales que saldrán del inventario."
                                               Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SerialSelectionSummary}"
                                           Foreground="{Binding SerialSelectionBrush}"
                                           FontWeight="Black"
                                           VerticalAlignment="Bottom"
                                           Margin="12,0,0,0" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SerialSearchBox"
                                         Height="38"
                                         Margin="0,0,10,0"
                                         TextChanged="SerialSearchBox_TextChanged"
                                         ToolTip="Buscar por IMEI, almacén o estado" />
                                <Button Grid.Column="1"
                                        Content="Usar selección"
                                        Width="116"
                                        Height="38"
                                        Margin="10,0,0,0"
                                        FontWeight="Black"
                                        Click="UseSelectedCount_Click" />
                                <Button Grid.Column="2"
                                        Content="Limpiar"
                                        Width="86"
                                        Height="38"
                                        Margin="8,0,0,0"
                                        FontWeight="Black"
                                        Click="ClearSerialSelection_Click" />
                            </Grid>

                            <ListBox x:Name="SerialsList"
                                     ItemsSource="{Binding FilteredSerials}"
                                     SelectionMode="Multiple"
                                     SelectionChanged="SerialsList_SelectionChanged"
                                     Height="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" BorderBrush="#EAF0FA" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding SerialNumber}" FontWeight="Black" />
                                                    <TextBlock Text="{Binding WarehouseLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="8,4" Background="#EEF2FF" BorderBrush="#DDE5FF" BorderThickness="1" CornerRadius="7" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Black" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="12" Margin="0,14,0,0" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Cancelar" Width="105" Height="38" FontWeight="Black" Click="Cancel_Click" />
                <Button Grid.Column="2" Content="Guardar salida" Width="135" Height="38" Margin="10,0,0,0" FontWeight="Black" Background="{StaticResource AccentBrush}" Foreground="White" Click="Save_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
