<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductKardexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kardex del producto"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="BorderBrush" Value="#D9E2F1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="KARDEX" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="{Binding ProductSku}" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ProductName}" FontSize="27" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                    <TextBlock Text="Historial cronológico de movimientos, entradas, salidas y saldo acumulado."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Button Content="Cerrar"
                        Width="96"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Close_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="14" Margin="0,14,0,14" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Almacén" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="12" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="WarehouseLabel"
                              Height="36"
                              Margin="0,5,14,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Text="Desde" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="12" />
                    <DatePicker SelectedDate="{Binding DateFrom}" Width="135" Height="36" Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,14,0">
                    <TextBlock Text="Hasta" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="12" />
                    <DatePicker SelectedDate="{Binding DateTo}" Width="135" Height="36" Margin="0,5,0,0" />
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Aplicar"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        VerticalAlignment="Bottom"
                        Click="Apply_Click" />
                <Button Grid.Column="4"
                        Content="Limpiar"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Margin="10,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="Clear_Click" />
                <Button Grid.Column="5"
                        Content="Actualizar"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#FFFFFF"
                        Foreground="#10172F"
                        Margin="10,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="Refresh_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Columns="3" Margin="14">
                    <Border Padding="14,10" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="SALDO INICIAL" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="11" />
                            <TextBlock Text="{Binding OpeningBalance}" FontSize="22" FontWeight="Black" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Padding="14,10" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="SALDO FINAL" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="11" />
                            <TextBlock Text="{Binding ClosingBalance}" FontSize="22" FontWeight="Black" Foreground="#047857" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Padding="14,10" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="9">
                        <StackPanel>
                            <TextBlock Text="MOVIMIENTOS" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="11" />
                            <TextBlock Text="{Binding MovementCount}" FontSize="22" FontWeight="Black" Foreground="#3157C8" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Movements}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="44"
                          Margin="14,0,14,14">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding DateLabel, Mode=OneWay}" Width="145" />
                        <DataGridTextColumn Header="TIPO" Binding="{Binding TypeLabel, Mode=OneWay}" Width="130" />
                        <DataGridTextColumn Header="ALMACÉN" Binding="{Binding WarehouseLabel, Mode=OneWay}" Width="170" />
                        <DataGridTextColumn Header="ENTRA" Binding="{Binding QuantityIn, Mode=OneWay}" Width="80" />
                        <DataGridTextColumn Header="SALE" Binding="{Binding QuantityOut, Mode=OneWay}" Width="80" />
                        <DataGridTextColumn Header="SALDO" Binding="{Binding RunningBalance, Mode=OneWay}" Width="90" />
                        <DataGridTextColumn Header="MOTIVO" Binding="{Binding ReasonLabel, Mode=OneWay}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#F8FAFE" CornerRadius="10" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowEmptyState}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Width="320">
                        <TextBlock Text="{Binding EmptyStateTitle}" FontSize="18" FontWeight="Black" TextAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding EmptyStateMessage}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0" />
    </Grid>
</Window>
