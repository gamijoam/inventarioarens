<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Registrar entrada"
        Width="780"
        Height="780"
        MinWidth="700"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Border Padding="9,5" Background="#ECFDF5" BorderBrush="#B8F0D2" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                    <TextBlock Text="ENTRADA" Foreground="#047857" FontSize="10" FontWeight="Black" />
                </Border>
                <TextBlock Text="{Binding ProductName}" FontSize="26" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                <TextBlock Text="{Binding ProductSku}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <Border Padding="18" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="AlmacÃ©n" FontWeight="Black" />
                    <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" DisplayMemberPath="WarehouseLabel" Height="38" Margin="0,6,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Cantidad" FontWeight="Black" />
                            <TextBox x:Name="QuantityBox" Height="38" Margin="0,6,0,14" Text="1" TextChanged="QuantityBox_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Costo unitario" FontWeight="Black" />
                            <TextBox x:Name="UnitCostBox" Height="38" Margin="0,6,0,14" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Motivo" FontWeight="Black" />
                    <TextBox x:Name="ReasonBox" Height="38" Margin="0,6,0,14" Text="Entrada manual" />

                    <TextBlock Text="Referencia" FontWeight="Black" />
                    <TextBox x:Name="ReferenceBox" Height="38" Margin="0,6,0,14" />

                    <TextBlock Text="Notas" FontWeight="Black" />
                    <TextBox x:Name="NotesBox" Height="72" Margin="0,6,0,14" TextWrapping="Wrap" AcceptsReturn="True" />

                    <StackPanel x:Name="SerialsPanel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="IMEI / seriales" FontWeight="Black" />
                                <TextBlock Text="{Binding SerialSummary}" Foreground="{Binding SerialSummaryBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Usar conteo" Width="112" Height="32" Margin="8,0,0,0" FontWeight="Black" Click="UseSerialCount_Click" />
                            <Button Grid.Column="2" Content="Limpiar duplicados" Width="145" Height="32" Margin="8,0,0,0" FontWeight="Black" Click="RemoveDuplicateSerials_Click" />
                        </Grid>

                        <TextBlock Text="Pega un IMEI o serial por lÃ­nea. Se validan duplicados, lÃ­neas vacÃ­as y coincidencia con la cantidad."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,6" />
                        <TextBox x:Name="SerialsBox"
                                 Height="130"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="SerialsBox_TextChanged" />

                        <DataGrid ItemsSource="{Binding SerialPreview}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Height="160"
                                  Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="55" />
                                <DataGridTextColumn Header="IMEI / SERIAL" Binding="{Binding SerialNumber}" Width="*" />
                                <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="14" Margin="0,14,0,0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Height="40"
                        MinWidth="120"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontWeight="Bold"
                        Click="BackToModules_Click"
                        ToolTip="Volver al centro de modulos">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="14,0" />
                <Button Grid.Column="2" Height="40" MinWidth="110" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Height="40" MinWidth="140" Margin="8,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Guardar entrada" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>


