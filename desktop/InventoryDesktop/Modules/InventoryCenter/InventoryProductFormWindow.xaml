<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryProductFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Producto"
        Width="720"
        Height="720"
        MinWidth="640"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding ModeLabel}" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                </Border>
                <TextBlock Text="{Binding TitleLabel}" FontSize="27" FontWeight="Black" TextWrapping="Wrap" Margin="0,12,0,0" />
                <TextBlock Text="Define datos comerciales, moneda, tasa, garantÃ­a y tipo de control."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <Border Padding="18" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Nombre" FontWeight="Black" />
                    <TextBox x:Name="NameBox" Height="38" Margin="0,6,0,14" />

                    <TextBlock Text="SKU interno (opcional)" FontWeight="Black" />
                    <TextBox x:Name="SkuBox" Height="38" Margin="0,6,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Tipo de control" FontWeight="Black" />
                            <ComboBox x:Name="TrackingBox"
                                      ItemsSource="{Binding TrackingOptions}"
                                      SelectedItem="{Binding SelectedTracking}"
                                      DisplayMemberPath="Label"
                                      Height="38"
                                      Margin="0,6,0,14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Moneda de venta" FontWeight="Black" />
                            <ComboBox x:Name="CurrencyBox"
                                      ItemsSource="{Binding CurrencyOptions}"
                                      SelectedItem="{Binding SelectedCurrency}"
                                      DisplayMemberPath="Label"
                                      Height="38"
                                      Margin="0,6,0,14" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Precio base" FontWeight="Black" />
                    <TextBox x:Name="BasePriceBox" Height="38" Margin="0,6,0,14" />

                    <TextBlock Text="Tipo de tasa" FontWeight="Black" />
                    <ComboBox x:Name="RateTypeBox"
                              ItemsSource="{Binding RateTypes}"
                              SelectedItem="{Binding SelectedRateType}"
                              DisplayMemberPath="Label"
                              Height="38"
                              Margin="0,6,0,14" />

                    <TextBlock Text="PolÃ­tica de garantÃ­a" FontWeight="Black" />
                    <ComboBox x:Name="WarrantyBox"
                              ItemsSource="{Binding WarrantyPolicies}"
                              SelectedItem="{Binding SelectedWarrantyPolicy}"
                              DisplayMemberPath="Label"
                              Height="38"
                              Margin="0,6,0,14" />

                    <CheckBox x:Name="ActiveBox" Content="Producto activo" IsChecked="True" FontWeight="Black" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding TrackingHelpText}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                    <TextBlock Text="Si dejas el SKU vacio, el sistema generara un codigo interno. En telefonos, el POS seguira vendiendo por IMEI."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="14" Margin="0,14,0,0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Height="40"
                        MinWidth="120"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontWeight="Bold"
                        Click="BackToModules_Click"
                        ToolTip="Volver al centro de modulos">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="14,0" />
                <Button Grid.Column="2" Height="40" MinWidth="110" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="Cancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Height="40" MinWidth="140" Margin="8,0,0,0" materialDesign:ButtonAssist.CornerRadius="8" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SaveButtonLabel}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>


