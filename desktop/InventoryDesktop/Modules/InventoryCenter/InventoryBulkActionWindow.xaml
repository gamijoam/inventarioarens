<Window x:Class="InventoryDesktop.Modules.InventoryCenter.InventoryBulkActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acciones masivas"
        Width="880"
        Height="700"
        MinWidth="680"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#5038F2" />
            <Setter Property="BorderBrush" Value="#5038F2" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64718C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                    <TextBlock Text="INVENTARIO" Foreground="#2F24D6" FontSize="10" FontWeight="Black" />
                </Border>
                <TextBlock Text="Acciones masivas" FontSize="26" FontWeight="Black" Margin="0,10,0,0" />
                <TextBlock Text="{Binding SummaryLabel}" Foreground="#5D6B88" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Padding="14" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Productos seleccionados" FontSize="16" FontWeight="Black" />
                        <TextBlock Text="Se aplicará la acción solo a esta selección." Foreground="#5D6B88" FontWeight="SemiBold" Margin="0,3,0,10" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Products}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              RowHeight="42"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUCTO" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="0.8*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Acción a aplicar" FontSize="16" FontWeight="Black" />
                    <TextBlock Text="Confirma bien antes de ejecutar. Cada producto afectado quedará auditado." Foreground="#5D6B88" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,14" />

                    <TextBlock Text="Acción" Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding Actions}"
                              SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              MinHeight="38"
                              SelectionChanged="Action_SelectionChanged" />

                    <StackPanel x:Name="WarrantyPanel" Margin="0,14,0,0" Visibility="Collapsed">
                        <TextBlock Text="Política de garantía" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding WarrantyPolicies}"
                                  SelectedItem="{Binding SelectedWarrantyPolicy, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  MinHeight="38" />
                    </StackPanel>

                    <StackPanel x:Name="RatePanel" Margin="0,14,0,0" Visibility="Collapsed">
                        <TextBlock Text="Tipo de tasa" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding ExchangeRateTypes}"
                                  SelectedItem="{Binding SelectedExchangeRateType, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  MinHeight="38" />
                    </StackPanel>

                    <StackPanel x:Name="PriceListPanel" Margin="0,14,0,0" Visibility="Collapsed">
                        <TextBlock Text="Lista de precio" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding PriceLists}"
                                  SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  MinHeight="38" />

                        <TextBlock Text="Estrategia" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                        <ComboBox ItemsSource="{Binding PriceStrategies}"
                                  SelectedItem="{Binding SelectedPriceStrategy, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  MinHeight="38"
                                  SelectionChanged="PriceStrategy_SelectionChanged" />

                        <TextBlock Text="Moneda" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                        <ComboBox ItemsSource="{Binding CurrencyOptions}"
                                  SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                  MinHeight="38" />

                        <StackPanel x:Name="FixedPricePanel" Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock Text="Monto fijo" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding FixedPriceText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" VerticalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel x:Name="PercentPanel" Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock Text="Porcentaje sobre precio base" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding PercentText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <Border Margin="0,18,0,0" Padding="12" Background="#FFFDF9" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8">
                        <TextBlock Text="{Binding WarningLabel}" Foreground="#B45309" FontWeight="Black" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,16,0,0" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="Cancel_Click" />
            <Button Content="Aplicar acción" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="{Binding CanSubmit}" Click="Submit_Click" />
        </StackPanel>
    </Grid>
</Window>
