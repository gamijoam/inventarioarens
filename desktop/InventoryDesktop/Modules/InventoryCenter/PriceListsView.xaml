<UserControl x:Class="InventoryDesktop.Modules.InventoryCenter.PriceListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="8" Height="8" Fill="#4D35FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Listas" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PriceLists.Count}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Activas" Foreground="#64718C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Height="40" MinWidth="120" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Actualizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Grid Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="48"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionChanged="PriceListsGrid_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC" />
                            <Setter Property="BorderBrush" Value="#E2E8F0" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="14,12" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="Foreground" Value="#475569" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="14,4" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#FFFFFF" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="LISTA" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="0,4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource InkBrush}" />
                                        <TextBlock Text="{Binding Code}"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="#8090AD"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="PREDET." Width="0.8*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3" CornerRadius="6"
                                            Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DefaultLabel}"
                                                   Foreground="#B45309"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ESTADO" Width="0.9*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3" CornerRadius="6"
                                            Background="#D1FAE5" BorderBrush="#A7F3D0" BorderThickness="1"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusLabel}"
                                                   Foreground="#047857"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="POSICION" Binding="{Binding SortOrder}" Width="0.7*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#FBFDFF" BorderBrush="#E6ECF5" BorderThickness="1" CornerRadius="12" Padding="24" Width="420" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasNoPriceLists, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#EEF0FF" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="TagMultiple"
                                                     Foreground="{StaticResource AccentStrongBrush}"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="No hay listas de precio creadas"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,14,0,0" />
                        <TextBlock Text="Completa el formulario de la derecha y presiona Crear lista."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Light"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   LineHeight="20"
                                   Margin="0,7,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PencilOutline"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding FormSubtitle}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="Light"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,6,0,14" />

                    <Border Padding="10,8" CornerRadius="8" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Crea listas como mayor, detal o tecnico. Luego asigna el precio correspondiente dentro de cada producto."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FormatLetterCase"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="NOMBRE"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="NameBox" Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,4,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pound"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="CODIGO"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="CodeBox" Text="{Binding CodeInput, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,4,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TextLong"
                                                 Foreground="{StaticResource MutedBrush}"
                                                 Width="12" Height="12"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="DESCRIPCION"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}" Height="64" FontSize="13" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <CheckBox IsChecked="{Binding IsDefaultInput}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <materialDesign:PackIcon Kind="StarOutline"
                                                 Foreground="#B45309"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center"
                                                 Margin="6,0,0,0" />
                        <TextBlock Text="Lista predeterminada"
                                   Foreground="{StaticResource InkBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox IsChecked="{Binding IsActiveInput}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                 Foreground="#10B981"
                                                 Width="14" Height="14"
                                                 VerticalAlignment="Center"
                                                 Margin="6,0,0,0" />
                        <TextBlock Text="Lista activa"
                                   Foreground="{StaticResource InkBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Margin="0,16,0,0">
                        <Button Height="46" MinHeight="46"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="13"
                                Click="Save_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SaveButtonLabel}" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="40" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="New_Click" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close" Width="12" Height="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Height="40" materialDesign:ButtonAssist.CornerRadius="8" Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold" Click="Deactivate_Click" IsEnabled="{Binding CanDeactivate}" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArchiveArrowDownOutline" Width="12" Height="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Desactivar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Expander Header="Opciones avanzadas" FontWeight="SemiBold" Margin="0,14,0,0">
                        <StackPanel Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="SortNumericAscendingVariant"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="POSICION VISUAL"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Solo define el orden en que se muestran las listas. Si lo dejas en 0, se coloca al final."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Light"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,6" />
                            <TextBox Text="{Binding SortOrderInput, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="13" Padding="10,0" BorderBrush="#E2E8F0" BorderThickness="1" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>

            <Border Grid.ColumnSpan="2" Background="#B3FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="290" Padding="20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="6" />
                        <TextBlock Text="Procesando listas..." FontWeight="Bold" TextAlignment="Center" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="InformationOutline"
                                         Foreground="{Binding StatusBrush}"
                                         Width="14" Height="14"
                                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
