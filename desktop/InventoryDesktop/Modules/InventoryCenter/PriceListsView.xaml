<UserControl x:Class="InventoryDesktop.Modules.InventoryCenter.PriceListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#34415F" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
            <Grid>
                <StackPanel>
                    <Border Padding="9,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Left">
                        <TextBlock Text="PRECIOS" Foreground="{StaticResource AccentStrongBrush}" FontSize="10" FontWeight="Black" />
                    </Border>
                    <TextBlock Text="Listas de precio" FontSize="25" FontWeight="Black" Margin="0,9,0,0" />
                    <TextBlock Text="Crea y edita listas como mayor, detal o técnico para que el POS use precios controlados."
                               Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="Actualizar" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Refresh_Click" />
                    <Button Content="+ Preparar nueva" Style="{StaticResource PrimaryButtonStyle}" Click="New_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0">
                <DataGrid ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="48"
                          BorderThickness="0"
                          SelectionChanged="PriceListsGrid_SelectionChanged">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Black" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="Foreground" Value="#64718C" />
                            <Setter Property="Background" Value="#F7F9FD" />
                            <Setter Property="Padding" Value="12,9" />
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="LISTA" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Black" Foreground="#10172F" />
                                        <TextBlock Text="{Binding Code}" FontSize="11" FontWeight="SemiBold" Foreground="#8090AD" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PREDET." Binding="{Binding DefaultLabel}" Width="0.8*" />
                        <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="0.9*" />
                        <DataGridTextColumn Header="ORDEN" Binding="{Binding SortOrder}" Width="0.7*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Padding="18" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Black" />
                    <TextBlock Text="{Binding FormSubtitle}"
                               Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,16" />

                    <TextBlock Text="Nombre" FontWeight="Black" />
                    <TextBox x:Name="NameBox" Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,12" />

                    <TextBlock Text="Código" FontWeight="Black" />
                    <TextBox x:Name="CodeBox" Text="{Binding CodeInput, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,12" />

                    <TextBlock Text="Descripción" FontWeight="Black" />
                    <TextBox Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}" Height="76" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,12" />

                    <TextBlock Text="Orden" FontWeight="Black" />
                    <TextBox Text="{Binding SortOrderInput, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,12" />

                    <CheckBox Content="Lista predeterminada" IsChecked="{Binding IsDefaultInput}" FontWeight="Black" Margin="0,4,0,8" />
                    <CheckBox Content="Lista activa" IsChecked="{Binding IsActiveInput}" FontWeight="Black" />

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="{Binding SaveButtonLabel}" Style="{StaticResource PrimaryButtonStyle}" Width="136" Click="Save_Click" />
                        <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Width="110" Margin="8,0,0,0" Click="New_Click" />
                        <Button Content="Desactivar" Style="{StaticResource SecondaryButtonStyle}" Width="118" Margin="8,0,0,0" Click="Deactivate_Click" IsEnabled="{Binding CanDeactivate}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.ColumnSpan="2" Background="#99FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="290" Padding="20" Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="6" />
                        <TextBlock Text="Procesando listas..." FontWeight="Black" TextAlignment="Center" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,10,0,0" />
    </Grid>
</UserControl>
