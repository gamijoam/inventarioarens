<UserControl x:Class="InventoryDesktop.Modules.InventoryCenter.PriceListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FormFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12">
            <Grid Margin="20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TagMultiple"
                                                 Foreground="{StaticResource AccentStrongBrush}"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Listas de precio"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding PriceLists.Count}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="listas"
                                   FontSize="11"
                                   Foreground="#64748B"
                                   FontWeight="Medium"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Height="40" MinWidth="120" Style="{StaticResource SecondaryActionButton}" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Actualizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.25*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,12,0">
                <Grid>
                    <DataGrid ItemsSource="{Binding PriceLists}"
                              SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowHeight="56"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionChanged="PriceListsGrid_SelectionChanged">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="20,16" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="#475569" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="20,10" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="LISTA" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="#1E293B" />
                                            <TextBlock Text="{Binding Code}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="#94A3B8"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="PREDETERMINADA" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon Kind="Star"
                                                                 Width="22"
                                                                 Height="22"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Foreground" Value="#CBD5E1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="Foreground" Value="#FBBF24" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ESTADO" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,4"
                                                CornerRadius="12"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FEE2E2" />
                                                    <Setter Property="BorderBrush" Value="#FECACA" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#D1FAE5" />
                                                            <Setter Property="BorderBrush" Value="#A7F3D0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#B91C1C" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="#047857" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="POSICION" Binding="{Binding SortOrder}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="32" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasNoPriceLists, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Width="56" Height="56" CornerRadius="14" Background="#EEF0FF" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="TagMultiple"
                                                         Foreground="{StaticResource AccentStrongBrush}"
                                                         Width="28" Height="28"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="No hay listas de precio creadas"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Foreground="#1E293B"
                                       Margin="0,14,0,0" />
                            <TextBlock Text="Completa el formulario de la derecha y presiona Crear lista para empezar."
                                       Foreground="#64748B"
                                       FontWeight="Light"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       LineHeight="18"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    MinWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.30" Color="#94A3B8" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">

                            <Button Style="{StaticResource BackButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,16"
                                    Click="BackToModules_Click"
                                    ToolTip="Volver al centro de modulos">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="Volver al centro de modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="PencilOutline"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         Width="18" Height="18"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding FormTitle}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding FormSubtitle}"
                                       Foreground="#64748B"
                                       FontWeight="Light"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="18"
                                       Margin="0,0,0,24" />

                            <Border Background="#EBF8FF"
                                    BorderBrush="#BAE6FD"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14,12"
                                    Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="InformationOutline"
                                                             Foreground="#0284C7"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Top"
                                                             Margin="0,2,0,0" />
                                    <TextBlock Text="Crea listas como mayor, detal o tecnico. Luego asigna el precio correspondiente dentro de cada producto."
                                               Foreground="#0C4A6E"
                                               FontWeight="Light"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               LineHeight="18"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBox x:Name="NameBox"
                                     materialDesign:HintAssist.Hint="Nombre de la lista"
                                     materialDesign:HintAssist.IsFloating="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="FormatLetterCase"
                                     materialDesign:TextFieldAssist.LeadingIconSize="20"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="14"
                                     Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16" />

                            <TextBox x:Name="CodeBox"
                                     materialDesign:HintAssist.Hint="Codigo"
                                     materialDesign:HintAssist.IsFloating="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="Pound"
                                     materialDesign:TextFieldAssist.LeadingIconSize="20"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="14"
                                     Text="{Binding CodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16" />

                            <TextBox materialDesign:HintAssist.Hint="Descripcion"
                                     materialDesign:HintAssist.IsFloating="True"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="TextLong"
                                     materialDesign:TextFieldAssist.LeadingIconSize="20"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="14"
                                     Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="80"
                                     VerticalContentAlignment="Top"
                                     Padding="8,8"
                                     Margin="0,0,0,16" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox IsChecked="{Binding IsDefaultInput}" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="Star"
                                                         Foreground="#FBBF24"
                                                         Width="16" Height="16"
                                                         VerticalAlignment="Center"
                                                         Margin="8,0,0,0" />
                                <TextBlock Text="Lista predeterminada"
                                           Foreground="#1E293B"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <CheckBox IsChecked="{Binding IsActiveInput}" VerticalAlignment="Center" />
                                <Border Padding="8,3" CornerRadius="12"
                                        Background="#D1FAE5" BorderBrush="#A7F3D0" BorderThickness="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Activa"
                                               Foreground="#047857"
                                               FontWeight="Bold"
                                               FontSize="10"
                                               VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>

                            <Expander Header="Opciones avanzadas" FontWeight="SemiBold" Margin="0,24,0,0">
                                <StackPanel Margin="0,12,0,0">
                                    <TextBox materialDesign:HintAssist.Hint="Posicion visual"
                                             materialDesign:HintAssist.IsFloating="True"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             FontSize="14"
                                             Text="{Binding SortOrderInput, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,0" />
                                    <TextBlock Text="Solo define el orden en que se muestran las listas. Si lo dejas en 0, se coloca al final."
                                               Foreground="#64748B"
                                               FontWeight="Light"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,1,0,0"
                            Padding="24,20"
                            CornerRadius="0,0,12,12">
                        <StackPanel>
                            <Button Height="48"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="{StaticResource AccentBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Click="Save_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Foreground="White" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SaveButtonLabel}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <UniformGrid Rows="1" Columns="2" Margin="0,12,0,0">
                                <Button Grid.Column="0" Height="40" Margin="0,0,4,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        Click="New_Click"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Limpiar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Height="40" Margin="4,0,0,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        Click="Deactivate_Click"
                                        IsEnabled="{Binding CanDeactivate}"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ArchiveArrowDownOutline" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Desactivar" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.ColumnSpan="2" Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <Border Width="320" Padding="24" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="6" />
                        <TextBlock Text="Procesando listas..." FontWeight="Bold" Foreground="#1E293B" TextAlignment="Center" Margin="0,14,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
