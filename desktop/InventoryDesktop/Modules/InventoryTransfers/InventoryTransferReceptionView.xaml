<UserControl x:Class="InventoryDesktop.Modules.InventoryTransfers.InventoryTransferReceptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="StageButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Background" Value="#F7F9FD" />
            <Setter Property="Foreground" Value="#10182F" />
            <Setter Property="BorderBrush" Value="#CBD7EA" />
        </Style>

        <Style x:Key="TransferGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="CellTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Margin="24,22,24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                            <TextBlock Text="TRASLADOS" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                        </Border>
                        <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                            <TextBlock Text="{Binding CountLabel}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StageTitle}" FontSize="28" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="{Binding StageDescription}"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Preparar"
                            Width="104"
                            Style="{StaticResource StageButtonStyle}"
                            Click="Preparation_Click" />
                    <Button Content="Despachar"
                            Width="108"
                            Margin="8,0,0,0"
                            Style="{StaticResource StageButtonStyle}"
                            Click="DispatchStage_Click" />
                    <Button Content="Recibir"
                            Width="96"
                            Margin="8,0,0,0"
                            Style="{StaticResource StageButtonStyle}"
                            Click="Reception_Click" />
                    <Button Content="Actualizar"
                            Width="112"
                            Margin="14,0,0,0"
                            Style="{StaticResource CompactButtonStyle}"
                            Click="Refresh_Click" />
                    <Button Content="Completo"
                            Width="104"
                            Margin="8,0,0,0"
                            Style="{StaticResource CompactButtonStyle}"
                            IsEnabled="{Binding CanComplete}"
                            Click="CompleteCurrentStage_Click" />
                    <Button Content="Preparar"
                            Width="112"
                            Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanPrepare}"
                            Click="ConfirmPreparation_Click" />
                    <Button Content="Despachar"
                            Width="118"
                            Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanDispatch}"
                            Click="ConfirmDispatch_Click" />
                    <Button Content="Recibir"
                            Width="104"
                            Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanReceive}"
                            Click="ConfirmReception_Click" />
                    <Button Content="+ Crear nuevo"
                            Width="140"
                            Margin="20,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CreateTransfer_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ListTitle}" FontSize="20" FontWeight="Black" />
                        <TextBlock Text="{Binding ListHelp}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,12" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding Transfers}"
                                  SelectedItem="{Binding SelectedTransfer, Mode=TwoWay}"
                                  Style="{StaticResource TransferGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="GUÍA" Binding="{Binding GuideNumber}" Width="110" />
                                <DataGridTextColumn Header="RUTA" Binding="{Binding RouteLabel}" Width="*" />
                                <DataGridTextColumn Header="ITEMS" Binding="{Binding ItemsLabel}" Width="72" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#FFFFFF"
                                Visibility="{Binding HasNoTransfers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding EmptyMessage}"
                                           FontSize="18"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding EmptyHelp}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Width="260"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="#F8FAFE" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTitle}" FontSize="22" FontWeight="Black" />
                            <TextBlock Text="{Binding SelectedRoute}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding SelectedSummary}" Foreground="#64748B" FontWeight="SemiBold" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Lines}"
                              Style="{StaticResource TransferGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUCTO" Binding="{Binding ProductName}" Width="2*" IsReadOnly="True" />
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="CONTROL" Binding="{Binding TrackingLabel}" Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedLabel}" Width="86" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="CANT." Width="96">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding WorkQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellTextBoxStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="DIF." Binding="{Binding DifferenceQuantity}" Width="70" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="MOTIVO DIF." Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding DifferenceReason, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellTextBoxStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="NOTAS" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding DifferenceNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellTextBoxStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="IMEIs" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SerialsSelectionLabel}" FontWeight="Black" FontSize="12" />
                                                <TextBlock Text="{Binding SerialSummary}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Seleccionar"
                                                    Margin="8,0,8,0"
                                                    Padding="12,0"
                                                    Height="30"
                                                    Click="ImeiPicker_Click"
                                                    Tag="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanConfigureSerials}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,1,0,0" Padding="24,12">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusBrush}"
                       FontWeight="Black"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
