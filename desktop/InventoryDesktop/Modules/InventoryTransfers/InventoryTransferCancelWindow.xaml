<Window x:Class="InventoryDesktop.Modules.InventoryTransfers.InventoryTransferCancelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cancelar traslado"
        Width="560"
        SizeToContent="Height"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="#D9365C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#CBD7EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#51617F" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <Border Padding="10,5" Background="#FFEDF1" BorderBrush="#F2C0CB" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                    <TextBlock Text="CANCELAR TRASLADO" Foreground="#A1164B" FontSize="11" FontWeight="Black" />
                </Border>
                <TextBlock x:Name="TitleText" Text="Cancelar traslado" FontSize="22" FontWeight="Black" Margin="0,10,0,0" />
                <TextBlock x:Name="GuideText"
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
                <TextBlock Text="Si la guia ya esta en transito esta accion se rechazara. Indica el motivo para registrar la cancelacion en el historial."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="0,12,0,12">
            <StackPanel>
                <TextBlock Text="Motivo de cancelacion" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="ReasonBox"
                         Height="120"
                         FontSize="14"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="ReasonBox_TextChanged" />
                <TextBlock x:Name="CounterText"
                           Text="0 / 1000 caracteres"
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Cerrar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Close_Click" />

            <Button Grid.Column="2"
                    x:Name="ConfirmButton"
                    Content="Cancelar traslado"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="False"
                    Click="Confirm_Click" />
        </Grid>
    </Grid>
</Window>
