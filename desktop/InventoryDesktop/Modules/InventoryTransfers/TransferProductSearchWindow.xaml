<Window x:Class="InventoryDesktop.Modules.InventoryTransfers.TransferProductSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar producto"
        Width="780"
        Height="620"
        MinWidth="700"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#CBD7EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#51617F" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                        <TextBlock Text="AGREGAR PRODUCTO" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                    </Border>
                    <TextBlock Text="Buscar producto" FontSize="24" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock x:Name="WarehouseHint"
                               Text="Productos disponibles"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1" Content="Cerrar" Width="108" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="0,14,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="118" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Buscar" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="ProductSearchBox"
                             Height="42"
                             FontSize="14"
                             KeyDown="ProductSearchBox_KeyDown" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Tipo" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="TrackingTypeBox" Height="42" FontSize="14" SelectionChanged="TrackingType_Changed">
                        <ComboBoxItem Content="Todos" Tag="" IsSelected="True" />
                        <ComboBoxItem Content="Por cantidad" Tag="quantity" />
                        <ComboBoxItem Content="Serializado / IMEI" Tag="serialized" />
                    </ComboBox>
                </StackPanel>

                <Button Grid.Column="2" Content="Buscar" Height="42" Margin="0,18,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="Search_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="0">
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F7F9FD">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                        <ColumnDefinition Width="120" SharedSizeGroup="SkuColumn" />
                        <ColumnDefinition Width="160" SharedSizeGroup="TypeColumn" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="PRODUCTO" FontWeight="Black" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="SKU" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="TIPO" FontWeight="Black" Margin="10,0" VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="ProductsList"
                         Grid.Row="1"
                         BorderThickness="0"
                         MouseDoubleClick="ProductsList_MouseDoubleClick"
                         SelectionChanged="ProductsList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="48" Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" SharedSizeGroup="ProductColumn" />
                                    <ColumnDefinition Width="120" SharedSizeGroup="SkuColumn" />
                                    <ColumnDefinition Width="160" SharedSizeGroup="TypeColumn" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="13" TextWrapping="Wrap" Margin="14,8" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Sku}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="10,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding TrackingLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="10,8" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="Escribe un termino y presiona Buscar o Enter."
                           Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Cantidad" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="QuantityBox" Text="1" FontSize="14" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Cancelar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,18,0,0"
                        Click="Cancel_Click" />

                <Button Grid.Column="3"
                        x:Name="SelectButton"
                        Content="Agregar"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="12,18,0,0"
                        IsEnabled="False"
                        Click="Select_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
