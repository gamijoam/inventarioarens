<Window x:Class="InventoryDesktop.Modules.InventoryTransfers.InventoryTransferImeiPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar IMEI / serial"
        Width="640"
        Height="600"
        MinWidth="560"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE4F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#CBD7EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#51617F" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                        <TextBlock Text="IMEI / SERIAL" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                    </Border>
                    <TextBlock x:Name="TitleText" Text="Seleccionar seriales" FontSize="22" FontWeight="Black" Margin="0,10,0,0" />
                    <TextBlock x:Name="SubtitleText"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="AutoFillButton"
                        Content="Auto-rellenar"
                        Width="148"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="AutoFill_Click"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="0,12,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Buscar IMEI / serial" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="SearchBox"
                             Height="38"
                             FontSize="14"
                             KeyDown="SearchBox_KeyDown" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Buscar"
                        Height="38"
                        Margin="0,18,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Search_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="#F7F9FD">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="✔" FontWeight="Black" Margin="14,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="IMEI / SERIAL" FontWeight="Black" Margin="6,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="ALMACEN" FontWeight="Black" Margin="6,0" VerticalAlignment="Center" />
                </Grid>

                <ListBox x:Name="ItemsList"
                         Grid.Row="1"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="48" Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Margin="14,0,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayLabel}"
                                           FontWeight="Black"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="6,8"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding MetaLabel}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           Margin="6,8"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#F7F9FD"
                BorderBrush="#DCE4F2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="CounterText"
                               Text="0 seleccionados"
                               FontSize="14"
                               FontWeight="Black" />
                    <TextBlock x:Name="StatusText"
                               Text="Cargando seriales disponibles..."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Limpiar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="Clear_Click" />

                <Button Grid.Column="2"
                        Content="Confirmar"
                        x:Name="ConfirmButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Confirm_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
