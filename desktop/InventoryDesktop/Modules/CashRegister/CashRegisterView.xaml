<UserControl x:Class="InventoryDesktop.Modules.CashRegister.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="CAJA" Foreground="#B45309" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="Turnos y arqueo" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Gestion de caja" FontSize="28" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="Abre tu turno, revisa cajas abiertas y cierra con conteo real. Las cajas fisicas se administran en una ventana aparte."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="Administrar cajas"
                            Width="150"
                            Height="40"
                            FontWeight="Black"
                            Click="ManageRegisters_Click" />
                    <Button Content="Actualizar"
                            Width="118"
                            Height="40"
                            Margin="10,0,0,0"
                            FontWeight="Black"
                            Click="Refresh_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="14">
                <TabControl>
                    <TabItem Header="Abrir turno">
                        <StackPanel Margin="8,14,8,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="136" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Abrir mi turno" FontSize="22" FontWeight="Black" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Abrir"
                                        Height="38"
                                        Background="#F59E0B"
                                        Foreground="White"
                                        FontWeight="Black"
                                        IsEnabled="{Binding CanOpenCashRegister}"
                                        Click="Open_Click" />
                            </Grid>
                            <TextBlock Text="Selecciona almacen y caja fisica activa."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <TextBlock Text="Almacen de trabajo" FontWeight="Black" />
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedItem="{Binding SelectedWarehouse}"
                                      DisplayMemberPath="WarehouseLabel"
                                      Height="38"
                                      Margin="0,5,0,8" />

                            <Border Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <TextBlock Text="{Binding SelectedBranchLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="Caja fisica" FontWeight="Black" />
                            <ComboBox ItemsSource="{Binding ActiveCashRegisters}"
                                      SelectedItem="{Binding SelectedCashRegister}"
                                      DisplayMemberPath="RegisterLabel"
                                      Height="38"
                                      Margin="0,5,0,5" />
                            <TextBlock Text="{Binding SelectedCashRegisterLabel}"
                                       Foreground="#058561"
                                       FontWeight="Black"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Monto inicial" FontWeight="Black" />
                                    <TextBox Text="{Binding OpeningAmount, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,5,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Moneda" FontWeight="Black" />
                                    <ComboBox ItemsSource="{Binding CurrencyOptions}"
                                              SelectedItem="{Binding OpeningCurrency}"
                                              Height="38"
                                              Margin="0,5,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Notas de apertura" FontWeight="Black" Margin="0,10,0,0" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="42"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Cerrar turno">
                        <StackPanel Margin="8,14,8,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="136" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cierre y arqueo" FontSize="22" FontWeight="Black" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Cerrar"
                                        Height="38"
                                        Background="#D9365C"
                                        Foreground="White"
                                        FontWeight="Black"
                                        IsEnabled="{Binding CanCloseCashRegister}"
                                        Click="Close_Click" />
                            </Grid>

                            <TextBlock Text="{Binding SelectedSessionLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <Border Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding ExpectedCloseLabel}" Foreground="#058561" FontWeight="Black" />
                                    <TextBlock Text="{Binding DifferencePreviewLabel}" Foreground="#B45309" FontWeight="Black" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Monto contado" FontWeight="Black" />
                                    <TextBox Text="{Binding CountedAmount, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,5,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Moneda" FontWeight="Black" />
                                    <ComboBox ItemsSource="{Binding CurrencyOptions}"
                                              SelectedItem="{Binding ClosingCurrency}"
                                              Height="38"
                                              Margin="0,5,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding CountedHelpLabel}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />

                            <TextBlock Text="Notas de cierre" FontWeight="Black" Margin="0,10,0,0" />
                            <TextBox Text="{Binding ClosingNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="62"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Margin="0,5,0,0" />
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="190" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Turnos abiertos" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Selecciona un turno para revisar movimientos, pagos y cerrar con conteo real."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,12" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sessions}"
                              SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="48">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CAJA" Binding="{Binding SessionLabel}" Width="230" />
                            <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="95" />
                            <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedLabel}" Width="180" />
                            <DataGridTextColumn Header="ABIERTA" Binding="{Binding OpenedAtLabel}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,14,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding SessionTotalsLabel}" FontWeight="Black" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />

                            <UniformGrid Grid.Row="1" Columns="5" Margin="0,12,0,0">
                                <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="APERTURA" Foreground="{StaticResource MutedBrush}" FontWeight="Black" FontSize="10" />
                                        <TextBlock Text="{Binding OpeningSummaryLabel}" FontWeight="Black" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="PAGOS POS" Foreground="#047857" FontWeight="Black" FontSize="10" />
                                        <TextBlock Text="{Binding PosPaymentsSummaryLabel}" FontWeight="Black" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="ENTRADAS" Foreground="#1D4ED8" FontWeight="Black" FontSize="10" />
                                        <TextBlock Text="{Binding ManualInflowsSummaryLabel}" FontWeight="Black" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="SALIDAS" Foreground="#B45309" FontWeight="Black" FontSize="10" />
                                        <TextBlock Text="{Binding ManualOutflowsSummaryLabel}" FontWeight="Black" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="ESPERADO" Foreground="#3B2CF6" FontWeight="Black" FontSize="10" />
                                        <TextBlock Text="{Binding ExpectedSummaryLabel}" FontWeight="Black" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Movimientos del turno" FontSize="18" FontWeight="Black" Margin="0,0,0,10" />

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Movements}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="46">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="FECHA" Binding="{Binding CreatedAtLabel}" Width="130" />
                                <DataGridTextColumn Header="TIPO" Binding="{Binding TypeLabel}" Width="95" />
                                <DataGridTextColumn Header="METODO" Binding="{Binding MethodLabel}" Width="110" />
                                <DataGridTextColumn Header="RECIBIDO" Binding="{Binding AmountLabel}" Width="105" />
                                <DataGridTextColumn Header="BASE" Binding="{Binding BaseLabel}" Width="95" />
                                <DataGridTextColumn Header="LOCAL" Binding="{Binding LocalLabel}" Width="110" />
                                <DataGridTextColumn Header="REFERENCIA" Binding="{Binding ReferenceLabel}" Width="120" />
                                <DataGridTextColumn Header="NOTA" Binding="{Binding NotesLabel}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />
    </Grid>
</UserControl>
