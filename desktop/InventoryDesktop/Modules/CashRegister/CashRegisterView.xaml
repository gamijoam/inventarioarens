<UserControl x:Class="InventoryDesktop.Modules.CashRegister.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="OpenTurnoButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#E67E22" />
            <Setter Property="BorderBrush" Value="#D35400" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CloseTurnoButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#E74C3C" />
            <Setter Property="BorderBrush" Value="#C0392B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource BackButtonStyle}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        ToolTip="Volver al centro de modulos"
                        Click="BackToModules_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="Modulos" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashRegister"
                                                 Foreground="{StaticResource AccentStrongBrush}"
                                                 Width="18" Height="18"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Caja"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Height="36" MinWidth="130" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButton}" Click="ManageRegisters_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CogOutline" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Administrar cajas" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Height="36" MinWidth="110" Style="{StaticResource PrimaryActionButton}" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Actualizar" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,0,16,0"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.20" Color="#94A3B8" />
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="CashRegister"
                                                     Foreground="#E67E22"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Operacion de turno"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabItem Header="Abrir turno">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Almacen de trabajo"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding Warehouses}"
                                              SelectedItem="{Binding SelectedWarehouse}"
                                              DisplayMemberPath="WarehouseLabel"
                                              Height="40"
                                              FontSize="13"
                                              VerticalContentAlignment="Center"
                                              Margin="0,8,0,8" />

                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="InformationOutline"
                                                                     Foreground="#4D35FF"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedBranchLabel}"
                                                       Foreground="#475569"
                                                       FontWeight="Medium"
                                                       FontSize="11"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Caja fisica"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding ActiveCashRegisters}"
                                              SelectedItem="{Binding SelectedCashRegister}"
                                              DisplayMemberPath="RegisterLabel"
                                              Height="40"
                                              FontSize="13"
                                              VerticalContentAlignment="Center"
                                              Margin="0,8,0,8" />

                                    <TextBlock Text="Monto inicial"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding OpeningAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="44"
                                                 FontSize="18"
                                                 FontWeight="Bold"
                                                 FontFamily="Consolas, Cascadia Mono, Courier New"
                                                 HorizontalContentAlignment="Right"
                                                 VerticalContentAlignment="Center"
                                                 Padding="10,0"
                                                 BorderBrush="#E2E8F0"
                                                 BorderThickness="1"
                                                 MinWidth="100"
                                                 Margin="0,8,0,8" />
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding CurrencyOptions}"
                                                  SelectedItem="{Binding OpeningCurrency}"
                                                  Height="44"
                                                  FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  Margin="0,8,0,8" />
                                    </Grid>

                                    <Button Style="{StaticResource OpenTurnoButton}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,24,0,0"
                                            IsEnabled="{Binding CanOpenCashRegister}"
                                            Click="Open_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LockOpenVariantOutline" Foreground="White" Width="18" Height="18" VerticalAlignment="Center" />
                                            <TextBlock Text="Abrir turno" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Cerrar turno">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Sesion activa"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,8,0,8">
                                        <TextBlock Text="{Binding SelectedSessionLabel}"
                                                   Foreground="#047857"
                                                   FontWeight="Bold"
                                                   FontSize="12" />
                                    </Border>

                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Esperado al cierre"
                                                       Foreground="#64748B"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding ExpectedCloseLabel}"
                                                       Foreground="#2C3E50"
                                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding DifferencePreviewLabel}"
                                                       Foreground="#B45309"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Monto contado"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding CountedAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="44"
                                                 FontSize="18"
                                                 FontWeight="Bold"
                                                 FontFamily="Consolas, Cascadia Mono, Courier New"
                                                 HorizontalContentAlignment="Right"
                                                 VerticalContentAlignment="Center"
                                                 Padding="10,0"
                                                 BorderBrush="#E2E8F0"
                                                 BorderThickness="1"
                                                 MinWidth="100"
                                                 Margin="0,8,0,8" />
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding CurrencyOptions}"
                                                  SelectedItem="{Binding ClosingCurrency}"
                                                  Height="44"
                                                  FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  Margin="0,8,0,8" />
                                    </Grid>

                                    <TextBlock Text="Notas de cierre"
                                               Foreground="#64748B"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding ClosingNotes, UpdateSourceTrigger=PropertyChanged}"
                                             Height="48"
                                             FontSize="12"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Padding="10,8"
                                             BorderBrush="#E2E8F0"
                                             BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto"
                                             MinWidth="100"
                                             Margin="0,8,0,8" />

                                    <Button Style="{StaticResource CloseTurnoButton}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,24,0,0"
                                            IsEnabled="{Binding CanCloseCashRegister}"
                                            Click="Close_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LockOutline" Foreground="White" Width="18" Height="18" VerticalAlignment="Center" />
                                            <TextBlock Text="Cerrar turno" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.20" Color="#94A3B8" />
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Resumen del turno"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B" />
                        <TextBlock Text="Selecciona un turno abierto para revisar movimientos, pagos y cerrar con conteo real."
                                   Foreground="#64748B"
                                   FontWeight="Light"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="18"
                                   Margin="0,4,0,16" />

                        <ItemsControl ItemsSource="{Binding SessionMetricItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14,10"
                                            MinWidth="150"
                                            MinHeight="64"
                                            Margin="0,0,10,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                         Foreground="{Binding IconColor}"
                                                                         Width="14" Height="14"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="#64748B"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Value}"
                                                       FontFamily="Consolas, Cascadia Mono, Courier New"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="#2C3E50"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <DataGrid ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  AlternationCount="2"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  RowHeight="48"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionMode="Single"
                                  Margin="0,8,0,0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="10,5" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="Foreground" Value="#475569" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="10,5" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F8FAFC" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CAJA" Binding="{Binding SessionLabel}" Width="230" />
                                <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="*" />
                                <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="110" />
                                <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedLabel}" Width="190" />
                                <DataGridTextColumn Header="ABIERTA" Binding="{Binding OpenedAtLabel}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Movimientos del turno"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="0,24,0,12" />

                        <ItemsControl ItemsSource="{Binding MovementTimeline}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32"
                                                CornerRadius="16"
                                                Background="{Binding IconBackground}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top"
                                                Margin="0,2,0,0">
                                            <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                     Foreground="White"
                                                                     Width="16" Height="16"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center" />
                                        </Border>
                                        <Border Grid.Column="1"
                                                Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="14,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               Foreground="#1E293B" />
                                                    <TextBlock Text="{Binding MethodLabel}"
                                                               Foreground="#64748B"
                                                               FontSize="11"
                                                               FontWeight="Light"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding NotesLabel}"
                                                               Foreground="#94A3B8"
                                                               FontSize="10"
                                                               FontWeight="Light"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AmountLabel}"
                                                               FontFamily="Consolas, Cascadia Mono, Courier New"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Foreground="{Binding AmountColor}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding CreatedAtLabel}"
                                                               Foreground="#94A3B8"
                                                               FontSize="10"
                                                               FontWeight="Light"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
