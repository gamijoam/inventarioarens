<UserControl x:Class="InventoryDesktop.Modules.CashRegister.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="CAJA" Foreground="#B45309" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="Apertura operativa" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Gestión de caja" FontSize="27" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="Abre tu caja para poder cobrar en POS. Cada cajero trabaja con su propia caja abierta."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Button Content="Actualizar"
                        Width="118"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Refresh_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="18">
                <StackPanel>
                    <TextBlock Text="Abrir mi caja" FontSize="22" FontWeight="Black" />
                    <TextBlock Text="Selecciona el almacén de trabajo. La caja se abre para la sucursal de ese almacén."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,5,0,18" />

                    <TextBlock Text="Almacén" FontWeight="Black" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="WarehouseLabel"
                              Height="40"
                              Margin="0,6,0,10" />

                    <Border Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14">
                        <TextBlock Text="{Binding SelectedBranchLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Moneda inicial" FontWeight="Black" />
                    <ComboBox ItemsSource="{Binding CurrencyOptions}"
                              SelectedItem="{Binding OpeningCurrency}"
                              Height="40"
                              Margin="0,6,0,10" />

                    <TextBlock Text="Monto inicial" FontWeight="Black" />
                    <TextBox Text="{Binding OpeningAmount, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,6,0,10" />

                    <TextBlock Text="Notas" FontWeight="Black" />
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="76"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Margin="0,6,0,18" />

                    <Button Content="Abrir caja"
                            Height="44"
                            Background="#F59E0B"
                            Foreground="White"
                            FontWeight="Black"
                            IsEnabled="{Binding CanOpenCashRegister}"
                            Click="Open_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Cajas abiertas" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Estas son las cajas abiertas de la empresa. El POS solo usará la caja abierta del cajero actual."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,14" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sessions}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="54">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CAJA" Binding="{Binding SessionLabel}" Width="100" />
                            <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="110" />
                            <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedLabel}" Width="170" />
                            <DataGridTextColumn Header="ABIERTA" Binding="{Binding OpenedAtLabel}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />
    </Grid>
</UserControl>
