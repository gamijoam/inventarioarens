<UserControl x:Class="InventoryDesktop.Modules.CashRegister.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="9,5" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="CAJA" Foreground="#B45309" FontSize="10" FontWeight="Black" />
                        </Border>
                        <Border Margin="8,0,0,0" Padding="9,5" Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="7">
                            <TextBlock Text="Multicaja" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Gestion de cajas" FontSize="27" FontWeight="Black" Margin="0,12,0,0" />
                    <TextBlock Text="Crea cajas fisicas por sucursal, abre tu turno y controla cierres sin mezclar cajeros."
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Button Content="Actualizar"
                        Width="118"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontWeight="Black"
                        Click="Refresh_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Caja fisica" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Primero selecciona la sucursal por almacen. Luego crea o selecciona la caja que usara el cajero."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,18" />

                        <TextBlock Text="Almacen de trabajo" FontWeight="Black" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedWarehouse}"
                                  DisplayMemberPath="WarehouseLabel"
                                  Height="40"
                                  Margin="0,6,0,10" />

                        <Border Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14">
                            <TextBlock Text="{Binding SelectedBranchLabel}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Text="Caja para abrir turno" FontWeight="Black" />
                        <ComboBox ItemsSource="{Binding CashRegisters}"
                                  SelectedItem="{Binding SelectedCashRegister}"
                                  DisplayMemberPath="RegisterLabel"
                                  Height="40"
                                  Margin="0,6,0,6" />
                        <TextBlock Text="{Binding SelectedCashRegisterLabel}"
                                   Foreground="#058561"
                                   FontWeight="Black"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />

                        <Border Background="#F8FAFE" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Crear nueva caja" FontSize="17" FontWeight="Black" />
                                <TextBlock Text="Ejemplo: Caja Mostrador 1, Caja Mostrador 2 o Caja Repuestos."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,12" />

                                <TextBlock Text="Nombre" FontWeight="Black" />
                                <TextBox Text="{Binding NewCashRegisterName, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,10" />

                                <TextBlock Text="Codigo" FontWeight="Black" />
                                <TextBox Text="{Binding NewCashRegisterCode, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,10" />

                                <TextBlock Text="Notas" FontWeight="Black" />
                                <TextBox Text="{Binding NewCashRegisterNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Height="50"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Margin="0,6,0,12" />

                                <Button Content="Crear caja fisica"
                                        Height="40"
                                        FontWeight="Black"
                                        IsEnabled="{Binding CanCreateCashRegister}"
                                        Click="CreateRegister_Click" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Apertura de turno" FontSize="18" FontWeight="Black" />
                        <TextBlock Text="Moneda inicial" FontWeight="Black" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding CurrencyOptions}"
                                  SelectedItem="{Binding OpeningCurrency}"
                                  Height="40"
                                  Margin="0,6,0,10" />

                        <TextBlock Text="Monto inicial" FontWeight="Black" />
                        <TextBox Text="{Binding OpeningAmount, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,6,0,10" />

                        <TextBlock Text="Notas de apertura" FontWeight="Black" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="58"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Margin="0,6,0,18" />

                        <Button Content="Abrir turno en esta caja"
                                Height="44"
                                Background="#F59E0B"
                                Foreground="White"
                                FontWeight="Black"
                                IsEnabled="{Binding CanOpenCashRegister}"
                                Click="Open_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Turnos abiertos" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Cada fila representa una caja fisica abierta por un cajero. El POS usara la del usuario actual."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,14" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sessions}"
                              SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="54">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CAJA" Binding="{Binding SessionLabel}" Width="220" />
                            <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchLabel}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="100" />
                            <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedLabel}" Width="170" />
                            <DataGridTextColumn Header="ABIERTA" Binding="{Binding OpenedAtLabel}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Background="#F8FAFE"
                            BorderBrush="#E1E7F3"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Cerrar turno seleccionado" FontSize="18" FontWeight="Black" />
                                <TextBlock Text="{Binding SelectedSessionLabel}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="{Binding ExpectedCloseLabel}"
                                           Foreground="#058561"
                                           FontWeight="Black"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding DifferencePreviewLabel}"
                                           Foreground="#B45309"
                                           FontWeight="Black"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="Moneda contada" FontWeight="Black" />
                                <ComboBox ItemsSource="{Binding CurrencyOptions}"
                                          SelectedItem="{Binding ClosingCurrency}"
                                          Height="38"
                                          Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                <TextBlock Text="Monto contado" FontWeight="Black" />
                                <TextBox Text="{Binding CountedAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Height="38"
                                         Margin="0,6,0,0" />
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Content="Cerrar turno"
                                    Height="42"
                                    VerticalAlignment="Bottom"
                                    Background="#D9365C"
                                    Foreground="White"
                                    FontWeight="Black"
                                    IsEnabled="{Binding CanCloseCashRegister}"
                                    Click="Close_Click" />

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Margin="0,12,0,0">
                                <TextBlock Text="{Binding CountedHelpLabel}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBox Text="{Binding ClosingNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusBrush}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />
    </Grid>
</UserControl>
