<UserControl x:Class="InventoryDesktop.Modules.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380" />
            <ColumnDefinition Width="520" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4D35FF" Offset="0" />
                    <GradientStop Color="#3524DF" Offset="0.55" />
                    <GradientStop Color="#1A0F8F" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="420" Height="420" Opacity="0.16"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-140,-140,0,0">
                <Ellipse.Fill>
                    <SolidColorBrush Color="White" />
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="320" Height="320" Opacity="0.12"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-100,-100">
                <Ellipse.Fill>
                    <SolidColorBrush Color="White" />
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" Margin="64,0,48,0">
                <Border Width="76" Height="76" CornerRadius="22" Background="White" HorizontalAlignment="Left">
                    <TextBlock Text="I" Foreground="#4D35FF" FontWeight="Black" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Sistema de Inventario"
                           Foreground="White"
                           FontSize="44"
                           FontWeight="Black"
                           LineHeight="52"
                           Margin="0,32,0,0"
                           TextWrapping="Wrap" />

                <TextBlock Text="Tu punto de venta e inventario, en sincronía con la nube."
                           Foreground="#D9FFFFFF"
                           FontSize="16"
                           FontWeight="Light"
                           LineHeight="24"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           MaxWidth="380" />

                <StackPanel Margin="0,40,0,0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCheckOutline" Foreground="#B3FFFFFF" Width="18" Height="18" VerticalAlignment="Center" />
                    <TextBlock Text="Acceso multi-tenant seguro"
                               Foreground="#B3FFFFFF"
                               FontSize="13"
                               FontWeight="Light"
                               Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Margin="64,0,48,32">
                <TextBlock Text="v1.0 · Multi-tenant · Multi-moneda"
                           Foreground="#80FFFFFF"
                           FontSize="11"
                           FontWeight="Light" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource PageBrush}">
            <StackPanel VerticalAlignment="Center" Margin="56,40,56,40">
                <TextBlock Text="BIENVENIDO DE VUELTA"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           FontWeight="Black" />

                <TextBlock Text="Iniciar sesión"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}"
                           Margin="0,6,0,0" />

                <TextBlock Text="Escribe tu correo, selecciona la empresa y confirma tu contraseña."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13"
                           FontWeight="Light"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Margin="0,8,0,20" />

                <TextBox x:Name="EmailInput"
                         materialDesign:HintAssist.Hint="Correo electrónico"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="EmailInput_TextChanged"
                         FontSize="14"
                         Margin="0,0,0,4" />

                <Grid Margin="0,16,0,4">
                    <PasswordBox x:Name="PasswordInput"
                                 materialDesign:HintAssist.Hint="Contraseña"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 FontSize="14"
                                 PasswordChanged="PasswordInput_PasswordChanged" />
                    <TextBox x:Name="PasswordVisibleInput"
                             materialDesign:HintAssist.Hint="Contraseña"
                             materialDesign:HintAssist.IsFloating="True"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14"
                             Visibility="Collapsed"
                             TextChanged="PasswordVisibleInput_TextChanged" />
                    <Button x:Name="TogglePasswordButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Width="32" Height="32"
                            Padding="0"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Click="TogglePassword_Click"
                            ToolTip="Mostrar u ocultar contraseña">
                        <materialDesign:PackIcon x:Name="TogglePasswordIcon" Kind="EyeOutline" Width="18" Height="18" />
                    </Button>
                </Grid>

                <ComboBox materialDesign:HintAssist.Hint="Empresa"
                          materialDesign:HintAssist.IsFloating="True"
                          materialDesign:TextFieldAssist.HasLeadingIcon="True"
                          materialDesign:TextFieldAssist.LeadingIcon="Domain"
                          materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                          ItemsSource="{Binding Tenants}"
                          SelectedItem="{Binding SelectedTenant}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          FontSize="14"
                          Margin="0,16,0,4" />

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                            Visibility="{Binding HasStatusInfo, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               FontWeight="Light"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>

                <Border Background="#FFF1F4"
                        BorderBrush="#FFD0DC"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,8,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                 Foreground="#B3133F"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#B3133F"
                                   FontWeight="Medium"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </Border>

                <Button Content="Ingresar"
                        Height="50"
                        Margin="0,28,0,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        IsEnabled="{Binding IsLoginEnabled}"
                        Click="Login_Click"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        FontWeight="Bold"
                        FontSize="15" />

                <Expander Margin="0,16,0,0" Foreground="{StaticResource MutedBrush}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ServerNetwork"
                                                     Foreground="{StaticResource MutedBrush}"
                                                     Width="14" Height="14"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Configuración de conexión"
                                       Margin="6,0,0,0"
                                       FontSize="12"
                                       FontWeight="Medium" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Servidor"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBox materialDesign:HintAssist.Hint="URL base"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="LinkVariant"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" />
                    </StackPanel>
                </Expander>

                <TextBlock Text="Conexión cifrada · Token local con DPAPI"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
