<Window x:Class="InventoryDesktop.Modules.Auth.ProgrammerLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Modo programador - Login SaaS Master"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ShieldKeyOutline" Foreground="#7C3AED" Width="22" Height="22" VerticalAlignment="Center" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Modo programador" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Acceso exclusivo para Platform Admins (SaaS Master)."
                               FontSize="11" Foreground="#64748B" FontWeight="Light" TextWrapping="Wrap" MaxWidth="380" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,16,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="SERVIDOR DE LA API" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ServerNetwork" Foreground="#475569" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock x:Name="ApiBaseUrlDisplay"
                                   FontSize="12"
                                   FontFamily="Consolas, Cascadia Mono, monospace"
                                   Foreground="#1E293B"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="CORREO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="EmailInput"
                         materialDesign:HintAssist.Hint="Correo del Platform Admin"
                         materialDesign:HintAssist.IsFloating="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="12" Height="12" VerticalAlignment="Center" />
                    <TextBlock Text="CONTRASENA" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <PasswordBox x:Name="PasswordInput"
                             materialDesign:HintAssist.Hint="Contrasena"
                             materialDesign:HintAssist.IsFloating="True"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             FontSize="14" />

                <Border Background="#FEF3C7"
                        BorderBrush="#FBBF24"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="InformationOutline" Foreground="#92400E" Width="14" Height="14" VerticalAlignment="Top" Margin="0,2,0,0" />
                        <TextBlock x:Name="StatusBar"
                                   Text=""
                                   Foreground="#92400E"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Margin="8,0,0,0"
                                   TextWrapping="Wrap"
                                   MaxWidth="380" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="110"
                        Height="40"
                        Margin="0,0,8,0"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="Cancel_Click"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button MinWidth="160"
                        Height="40"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#7C3AED"
                        BorderBrush="#7C3AED"
                        Foreground="White"
                        Click="Accept_Click"
                        IsEnabled="{Binding CanAccept, RelativeSource={RelativeSource AncestorType=Window}}"
                        FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LoginVariant" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Ingresar" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>