<Window x:Class="InventoryDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Inventario"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F9">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FBFF" Offset="0" />
                <GradientStop Color="#EEF3F9" Offset="0.55" />
                <GradientStop Color="#F1EEFF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" Margin="24,0,56,0">
                <Border Width="58" Height="58" CornerRadius="16" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                    <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Sistema de Inventario"
                           Margin="0,24,0,0"
                           FontSize="44"
                           FontWeight="Black"
                           LineHeight="48" />
                <TextBlock Text="Aplicacion de escritorio conectada al backend Laravel para inventario, POS, caja, reportes y operaciones multiempresa."
                           Margin="0,16,0,0"
                           FontSize="17"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"
                           LineHeight="28" />

                <UniformGrid Columns="3" Margin="0,34,0,0">
                    <Border Margin="0,0,12,0" Padding="16" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="API" FontWeight="Black" />
                            <TextBlock Text="Laravel" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="16" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="BD" FontWeight="Black" />
                            <TextBlock Text="PostgreSQL" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Padding="16" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="UI" FontWeight="Black" />
                            <TextBlock Text="WPF" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="430"
                    Padding="34"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#DCE4F2"
                    BorderThickness="1"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.14" Color="#1F2937" />
                </Border.Effect>

                <StackPanel>
                    <Border HorizontalAlignment="Left" Padding="12,8" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                        <TextBlock Text="Acceso protegido" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" FontSize="13" />
                    </Border>

                    <TextBlock Text="Iniciar sesion" FontSize="34" FontWeight="Black" Margin="0,28,0,0" />
                    <TextBlock Text="Conecta con tu backend Laravel y selecciona la empresa de trabajo."
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               FontSize="15"
                               LineHeight="23"
                               Margin="0,8,0,28" />

                    <TextBlock Text="API base" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Correo" FontWeight="Bold" Margin="0,18,0,8" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Contrasena" FontWeight="Bold" Margin="0,18,0,8" />
                    <PasswordBox x:Name="PasswordInput" />

                    <TextBlock Text="Empresa" FontWeight="Bold" Margin="0,18,0,8" />
                    <ComboBox ItemsSource="{Binding Tenants}"
                              SelectedItem="{Binding SelectedTenant}"
                              DisplayMemberPath="Name"
                              MinHeight="44"
                              Padding="10,0" />

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#D9365C"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0" />

                    <Button Content="Buscar empresas"
                            Height="46"
                            Margin="0,22,0,0"
                            FontWeight="Black"
                            Click="FindTenants_Click" />

                    <Button Content="Ingresar"
                            Height="48"
                            Margin="0,12,0,0"
                            Foreground="White"
                            FontWeight="Black"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Click="Login_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
