<Window x:Class="InventoryDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Inventario"
        Width="1160"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F9">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FBFF" Offset="0" />
                <GradientStop Color="#EEF3F9" Offset="0.55" />
                <GradientStop Color="#F1EEFF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="52,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="500" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" Margin="14,0,58,0">
                <Border Width="62" Height="62" CornerRadius="18" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                    <TextBlock Text="I" Foreground="White" FontWeight="Black" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Sistema de Inventario"
                           Margin="0,24,0,0"
                           FontSize="42"
                           FontWeight="Black"
                           LineHeight="48" />
                <TextBlock Text="Control empresarial para inventario, ventas, caja y reportes en una sola aplicación de escritorio."
                           Margin="0,16,0,0"
                           FontSize="17"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"
                           LineHeight="28" />

                <StackPanel Margin="0,34,0,0">
                    <Border Padding="18" Margin="0,0,0,12" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
                        <TextBlock Text="Inventario por empresa, almacén y seriales/IMEIs." FontWeight="Black" Foreground="{StaticResource InkBrush}" />
                    </Border>
                    <Border Padding="18" Margin="0,0,0,12" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
                        <TextBlock Text="Ventas, caja y reportes preparados para operación diaria." FontWeight="Black" Foreground="{StaticResource InkBrush}" />
                    </Border>
                    <Border Padding="18" Background="#FFFFFFFF" BorderBrush="#E1E7F3" BorderThickness="1" CornerRadius="12">
                        <TextBlock Text="Acceso seguro por usuario, permisos y empresa." FontWeight="Black" Foreground="{StaticResource InkBrush}" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="460"
                    Padding="32"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#DCE4F2"
                    BorderThickness="1"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.14" Color="#1F2937" />
                </Border.Effect>

                <StackPanel>
                    <Border HorizontalAlignment="Left" Padding="12,8" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                        <TextBlock Text="Acceso seguro" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" FontSize="13" />
                    </Border>

                    <TextBlock Text="Iniciar sesión" FontSize="34" FontWeight="Black" Margin="0,26,0,0" />
                    <TextBlock Text="Ingresa con tu usuario para abrir el panel de trabajo de tu empresa."
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               FontSize="15"
                               LineHeight="23"
                               Margin="0,8,0,24" />

                    <TextBlock Text="Correo" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Contraseña" FontWeight="Bold" Margin="0,16,0,8" />
                    <PasswordBox x:Name="PasswordInput" />

                    <TextBlock Text="Empresa" FontWeight="Bold" Margin="0,16,0,8" />
                    <ComboBox ItemsSource="{Binding Tenants}"
                              SelectedItem="{Binding SelectedTenant}"
                              DisplayMemberPath="Name"
                              MinHeight="42"
                              Padding="10,0" />

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#D9365C"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />

                    <Button Content="Ingresar"
                            Height="50"
                            Margin="0,20,0,0"
                            Foreground="White"
                            FontWeight="Black"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Click="Login_Click" />

                    <Button Content="Buscar empresas"
                            Height="42"
                            Margin="0,10,0,0"
                            FontWeight="Bold"
                            Click="FindTenants_Click" />

                    <Expander Header="Configuración de conexión" Margin="0,16,0,0" Foreground="{StaticResource MutedBrush}">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Servidor" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
