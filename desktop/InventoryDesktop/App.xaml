<Application x:Class="InventoryDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Indigo" SecondaryColor="Purple" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AccentColor">#4D35FF</Color>
            <Color x:Key="AccentStrongColor">#3524DF</Color>
            <Color x:Key="AccentSoftColor">#EEF0FF</Color>
            <Color x:Key="PanelColor">#FFFFFFFF</Color>
            <Color x:Key="SoftColor">#F7F9FD</Color>
            <Color x:Key="PageColor">#F6F8FC</Color>
            <Color x:Key="InkColor">#10172F</Color>
            <Color x:Key="MutedColor">#64718C</Color>
            <Color x:Key="LineColor">#DCE4F2</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
            <SolidColorBrush x:Key="SoftBrush" Color="{StaticResource SoftColor}" />
            <SolidColorBrush x:Key="PageBrush" Color="{StaticResource PageColor}" />
            <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
            <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
            <SolidColorBrush x:Key="LineBrush" Color="{StaticResource LineColor}" />

            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.HueLightBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.HueMidBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.HueDarkBrush" Color="{StaticResource AccentStrongColor}" />
            <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary.HueMidBrush" Color="{StaticResource AccentStrongColor}" />
            <SolidColorBrush x:Key="MaterialDesign.Brush.ValidationError" Color="#D72F5E" />

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            </Style>

            <Style TargetType="TextBox" x:Key="AppTextBoxStyle" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Padding" Value="18" />
                <Setter Property="Background" Value="#FFFFFFFF" />
                <Setter Property="BorderBrush" Value="#E1E7F3" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

            <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#64718C" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Black" />
            </Style>

            <Style x:Key="MetricValueStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#10172F" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Black" />
                <Setter Property="Margin" Value="0,8,0,0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
