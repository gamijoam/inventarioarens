<UserControl x:Class="InventoryDesktop.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:InventoryDesktop.Modules.Admin"
             xmlns:cash="clr-namespace:InventoryDesktop.Modules.CashRegister"
             xmlns:currency="clr-namespace:InventoryDesktop.Modules.Currency"
             xmlns:customers="clr-namespace:InventoryDesktop.Modules.Customers"
             xmlns:inventory="clr-namespace:InventoryDesktop.Modules.InventoryCenter"
             xmlns:transfers="clr-namespace:InventoryDesktop.Modules.InventoryTransfers"
             xmlns:pos="clr-namespace:InventoryDesktop.Modules.POS"
             xmlns:sync="clr-namespace:InventoryDesktop.Modules.Sync">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DashboardCardButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="280" />
            <Setter Property="MinHeight" Value="170" />
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="DashboardCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="HomeOutline"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Inicio"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               FontWeight="Medium"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                    <materialDesign:PackIcon Kind="ChevronRight"
                                             Foreground="{StaticResource MutedBrush}"
                                             Width="14" Height="14"
                                             VerticalAlignment="Center"
                                             Margin="8,0" />
                    <TextBlock x:Name="BreadcrumbSection"
                               Text="Centro de modulos"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="10,6" CornerRadius="20" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" />
                            <TextBlock Text="Sesion activa"
                                       Foreground="#047857"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button x:Name="SwitchTenantButton"
                            Height="36"
                            MinWidth="130"
                            Margin="0,0,8,0"
                            Padding="12,0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="SwitchTenant_Click"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SwapHorizontal" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Cambiar empresa" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SaasMasterButton"
                            Height="36"
                            MinWidth="140"
                            Margin="0,0,8,0"
                            Padding="12,0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Background="#7C3AED"
                            BorderBrush="#7C3AED"
                            Foreground="White"
                            Click="SaasMaster_Click"
                            Visibility="{Binding IsPlatformAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Foreground="White" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Modo programador" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Border Padding="14,8" CornerRadius="20" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="28" Height="28" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding UserName}"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellHeader" Grid.Row="1" Margin="28,24,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,16">
                <Border DockPanel.Dock="Right"
                        Background="#FFFFFF"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,18,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="SyncStatusDot"
                                         Width="10"
                                         Height="10"
                                         Fill="#94A3B8"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="SINCRONIZACION"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="SyncStatusText"
                                       Text="Sin consultar"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <Button x:Name="RefreshHomeButton"
                                Content="Actualizar"
                                Width="110"
                                Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="RefreshHome_Click"
                                FontWeight="SemiBold"
                                FontSize="13" />

                        <Button x:Name="RunSyncButton"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                Click="RunSyncNow_Click"
                                FontWeight="SemiBold"
                                FontSize="13">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CloudSyncOutline" Width="16" Height="16" VerticalAlignment="Center" />
                                <TextBlock Text="Sincronizar" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Bienvenido de vuelta"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               FontWeight="Light" />
                    <TextBlock x:Name="SectionTitle"
                               Text="Centro de modulos"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="SectionSubtitle"
                               Text="Elige el modulo que vas a usar. Las opciones se habilitan segun los permisos del usuario."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               FontWeight="Light"
                               TextWrapping="Wrap"
                               MaxWidth="640"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Grid>

        <Grid Grid.Row="2">
            <ScrollViewer x:Name="HomeContent" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,28,32">
                    <Border x:Name="InitialSyncNotice"
                            Visibility="Collapsed"
                            Background="#FFF7ED"
                            BorderBrush="#FDBA74"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,20">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Margin="18,0,0,0"
                                    Padding="16,10"
                                    VerticalAlignment="Center"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="#EA580C"
                                    Foreground="White"
                                    BorderBrush="#EA580C"
                                    Click="RunSyncNow_Click"
                                    FontWeight="SemiBold">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CloudDownloadOutline" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="Sincronizar empresa" Margin="6,0,0,0" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <StackPanel>
                                <TextBlock x:Name="InitialSyncTitle"
                                           Text="Esta empresa necesita sincronizacion inicial"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           FontWeight="Bold"
                                           Foreground="#9A3412" />
                                <TextBlock x:Name="InitialSyncDetail"
                                           Text="Sincroniza esta instalacion para descargar productos, precios, cajas y permisos antes de operar."
                                           Foreground="#7C2D12"
                                           FontSize="13"
                                           FontWeight="Light"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding ModuleCards, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource DashboardCardButtonStyle}"
                                        Click="ModuleCard_Click"
                                        IsEnabled="{Binding IsClickable}"
                                        Opacity="{Binding Opacity}">
                                    <Border Style="{StaticResource DashboardCardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="48" Height="48" CornerRadius="12"
                                                        Background="{Binding IconBrush}">
                                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                             Foreground="White"
                                                                             Width="24" Height="24"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxWidth="170" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="10"
                                                               FontWeight="Medium"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="10"
                                                       FontWeight="Light"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,12,0,0" />

                                            <Border Grid.Row="1"
                                                    Background="#FFF7ED"
                                                    BorderBrush="#FDBA74"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,30,0,0"
                                                    Visibility="{Binding ComingSoonVisibility}">
                                                <TextBlock Text="Proximamente"
                                                           Foreground="#9A3412"
                                                           FontSize="9"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="BackToModulesButton"
                            Padding="16,10"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Visibility="Collapsed"
                            Click="Home_Click"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Volver a modulos" Margin="6,0,0,0" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <inventory:InventoryCenterView x:Name="InventoryCenterContent" Visibility="Collapsed" />
            <inventory:InventoryMovementsView x:Name="InventoryMovementsContent" Visibility="Collapsed" />
            <inventory:PriceListsView x:Name="PriceListsContent" Visibility="Collapsed" />
            <currency:CurrencyRatesView x:Name="CurrencyRatesContent" Visibility="Collapsed" />
            <transfers:InventoryTransferReceptionView x:Name="TransferReceptionContent" Visibility="Collapsed" />
            <cash:CashRegisterView x:Name="CashRegisterContent" Visibility="Collapsed" />
            <customers:CustomersView x:Name="CustomersContent" Visibility="Collapsed" />
            <sync:SyncWorkerView x:Name="SyncWorkerContent" Visibility="Collapsed" />
        </Grid>

        <pos:PosView x:Name="PosContent" Grid.RowSpan="3" Visibility="Collapsed" />
    </Grid>
</UserControl>
