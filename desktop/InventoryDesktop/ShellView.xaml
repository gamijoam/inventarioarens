<UserControl x:Class="InventoryDesktop.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cash="clr-namespace:InventoryDesktop.Modules.CashRegister"
             xmlns:currency="clr-namespace:InventoryDesktop.Modules.Currency"
             xmlns:customers="clr-namespace:InventoryDesktop.Modules.Customers"
             xmlns:inventory="clr-namespace:InventoryDesktop.Modules.InventoryCenter"
             xmlns:transfers="clr-namespace:InventoryDesktop.Modules.InventoryTransfers"
             xmlns:pos="clr-namespace:InventoryDesktop.Modules.POS"
             xmlns:sync="clr-namespace:InventoryDesktop.Modules.Sync">
    <UserControl.Resources>
        <Style x:Key="ModuleCardButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="292" />
            <Setter Property="Height" Value="176" />
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="86" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ShellHeader" Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Sistema de Inventario" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="{Binding TenantName}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="34,0,0,0">
                    <TextBlock x:Name="SectionTitle" Text="Centro de módulos" FontSize="24" FontWeight="Black" />
                    <TextBlock x:Name="SectionSubtitle" Text="Selecciona el área de trabajo" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BackToModulesButton"
                            Content="Módulos"
                            Width="108"
                            Height="40"
                            Margin="0,0,12,0"
                            FontWeight="Black"
                            Visibility="Collapsed"
                            Click="Home_Click" />
                    <Border Padding="14,9" CornerRadius="10" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1">
                        <TextBlock Text="{Binding UserName}" FontWeight="Black" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer x:Name="HomeContent" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="36,30,36,34">
                    <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Padding="10,5" Background="#EEF0FF" BorderBrush="#DCE4FF" BorderThickness="1" CornerRadius="8">
                                        <TextBlock Text="INICIO" Foreground="{StaticResource AccentStrongBrush}" FontSize="11" FontWeight="Black" />
                                    </Border>
                                    <Border Padding="10,5" Background="#F7F9FD" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding TenantName}" Foreground="#51617F" FontSize="11" FontWeight="Black" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Centro de módulos" FontSize="32" FontWeight="Black" Margin="0,14,0,0" />
                                <TextBlock Text="Elige el módulo que vas a usar. Las opciones se habilitan según los permisos del usuario."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Padding="12,9"
                                        CornerRadius="10"
                                        Background="#F8FAFE"
                                        BorderBrush="#DCE4F2"
                                        BorderThickness="1"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="SyncStatusDot"
                                                 Width="12"
                                                 Height="12"
                                                 Fill="#94A3B8"
                                                 Margin="0,0,8,0" />
                                        <StackPanel>
                                            <TextBlock Text="Sincronizacion" FontSize="11" FontWeight="Black" Foreground="#51617F" />
                                            <TextBlock x:Name="SyncStatusText" Text="Sin consultar" FontWeight="Black" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="RunSyncButton"
                                        Content="Sincronizar ahora"
                                        Width="150"
                                        Height="42"
                                        Margin="0,0,10,0"
                                        FontWeight="Black"
                                        Click="RunSyncNow_Click" />
                                <Button Grid.Column="1"
                                        Content="Actualizar"
                                        Width="120"
                                        Height="42"
                                        VerticalAlignment="Center"
                                        FontWeight="Black"
                                        Click="RefreshHome_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="InitialSyncNotice"
                            Visibility="Collapsed"
                            Margin="0,16,0,0"
                            Background="#FFF7ED"
                            BorderBrush="#FDBA74"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="InitialSyncTitle"
                                           Text="Esta empresa necesita sincronizacion inicial"
                                           FontSize="18"
                                           FontWeight="Black"
                                           Foreground="#9A3412" />
                                <TextBlock x:Name="InitialSyncDetail"
                                           Text="Sincroniza esta instalacion para descargar productos, precios, cajas y permisos antes de operar."
                                           Margin="0,5,0,0"
                                           Foreground="#7C2D12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Sincronizar empresa"
                                    Width="170"
                                    Height="42"
                                    Margin="18,0,0,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Black"
                                    Click="RunSyncNow_Click" />
                        </Grid>
                    </Border>

                    <WrapPanel Margin="0,24,0,0">
                        <Button x:Name="HomePosCard" Style="{StaticResource ModuleCardButtonStyle}" Click="Pos_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                                        <TextBlock Text="POS" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="POS" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="Venta rápida, carrito, caja y métodos de pago." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir módulo" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomeInventoryCard" Style="{StaticResource ModuleCardButtonStyle}" Click="InventoryCenter_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#0EA5A4">
                                        <TextBlock Text="INV" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="Centro de Inventario" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="Productos, stock, seriales, precios y detalle." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir módulo" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomeMovementsCard" Style="{StaticResource ModuleCardButtonStyle}" Click="InventoryMovements_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#2563EB">
                                        <TextBlock Text="ES" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="Entradas y salidas" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="Movimientos operativos de productos y seriales." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir módulo" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomeTransfersCard" Style="{StaticResource ModuleCardButtonStyle}" Click="InventoryTransfers_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#16A34A">
                                        <TextBlock Text="TR" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="Traslados" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="Guías, despacho y recepción logística." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir módulo" Foreground="#15803D" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomePriceListsCard" Style="{StaticResource ModuleCardButtonStyle}" Click="PriceLists_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#7C3AED">
                                        <TextBlock Text="$" Foreground="White" FontWeight="Black" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="Listas de precio" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="Detal, mayor, técnico y reglas de cobro." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir módulo" Foreground="{StaticResource AccentStrongBrush}" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomeCurrencyCard" Style="{StaticResource ModuleCardButtonStyle}" Click="CurrencyRates_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#0891B2">
                                        <TextBlock Text="TC" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                        <TextBlock Text="Tasas" FontSize="22" FontWeight="Black" />
                                        <TextBlock Text="BCV, paralelo y tasas vigentes sincronizadas." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="2" Text="Abrir modulo" Foreground="#0E7490" FontWeight="Black" />
                                </Grid>
                            </Border>
                        </Button>

                        <Button x:Name="HomeCashCard" Style="{StaticResource ModuleCardButtonStyle}" Click="CashRegister_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#F59E0B">
                                        <TextBlock Text="CJ" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Caja" FontSize="22" FontWeight="Black" Margin="0,15,0,0" />
                                    <TextBlock Text="Aperturas, movimientos y cierre de caja." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Abrir módulo" Foreground="#B45309" FontWeight="Black" Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button x:Name="HomeCustomersCard" Style="{StaticResource ModuleCardButtonStyle}" Click="Customers_Click">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#14B8A6">
                                        <TextBlock Text="CL" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Clientes" FontSize="22" FontWeight="Black" Margin="0,15,0,0" />
                                    <TextBlock Text="Datos fiscales, contacto e historial POS." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Abrir módulo" Foreground="#0F766E" FontWeight="Black" Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button x:Name="HomeSyncCard" Style="{StaticResource ModuleCardButtonStyle}" Click="Sync_Click" Visibility="Collapsed">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#0891B2">
                                        <TextBlock Text="SY" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Sincronizacion" FontSize="22" FontWeight="Black" Margin="0,15,0,0" />
                                    <TextBlock Text="Estado, inicio y parada del worker local-nube." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Abrir modulo" Foreground="#0E7490" FontWeight="Black" Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button x:Name="HomeReportsCard" Style="{StaticResource ModuleCardButtonStyle}" IsEnabled="False">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18" Opacity="0.72">
                                <StackPanel>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#DC2626">
                                        <TextBlock Text="RP" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Reportes" FontSize="22" FontWeight="Black" Margin="0,15,0,0" />
                                    <TextBlock Text="Indicadores, ventas, inventario y finanzas." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Próximamente" Foreground="#B45309" FontWeight="Black" Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button x:Name="HomeSettingsCard" Style="{StaticResource ModuleCardButtonStyle}" IsEnabled="False">
                            <Border Background="#FFFFFF" BorderBrush="#DCE4F2" BorderThickness="1" CornerRadius="14" Padding="18" Opacity="0.72">
                                <StackPanel>
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Left" Background="#475569">
                                        <TextBlock Text="CFG" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Configuración" FontSize="22" FontWeight="Black" Margin="0,15,0,0" />
                                    <TextBlock Text="Usuarios, permisos, empresa y parámetros." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
                                    <TextBlock Text="Próximamente" Foreground="#B45309" FontWeight="Black" Margin="0,16,0,0" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <inventory:InventoryCenterView x:Name="InventoryCenterContent" Visibility="Collapsed" />
            <inventory:InventoryMovementsView x:Name="InventoryMovementsContent" Visibility="Collapsed" />
            <inventory:PriceListsView x:Name="PriceListsContent" Visibility="Collapsed" />
            <currency:CurrencyRatesView x:Name="CurrencyRatesContent" Visibility="Collapsed" />
            <transfers:InventoryTransferReceptionView x:Name="TransferReceptionContent" Visibility="Collapsed" />
            <cash:CashRegisterView x:Name="CashRegisterContent" Visibility="Collapsed" />
            <customers:CustomersView x:Name="CustomersContent" Visibility="Collapsed" />
            <sync:SyncWorkerView x:Name="SyncWorkerContent" Visibility="Collapsed" />
        </Grid>

        <pos:PosView x:Name="PosContent" Grid.RowSpan="2" Visibility="Collapsed" />
    </Grid>
</UserControl>
