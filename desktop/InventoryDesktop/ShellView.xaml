<UserControl x:Class="InventoryDesktop.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inventory="clr-namespace:InventoryDesktop.Modules.InventoryCenter">
    <Grid Background="#F4F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="24">
                    <Border Width="52" Height="52" CornerRadius="14" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Sistema de Inventario" FontSize="22" FontWeight="Black" Margin="0,16,0,0" />
                    <TextBlock Text="{Binding TenantName}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Margin="16,132,16,0">
                    <TextBlock Text="OPERACION" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,0,0,10" />
                    <Button Content="Resumen" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                    <Button Content="Centro de Ventas" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                    <Button Content="POS" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />

                    <TextBlock Text="INVENTARIO" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,22,0,10" />
                    <Button Content="Centro de Inventario" Height="46" Margin="0,0,0,8" FontWeight="Black" Background="#EEF0FF" Foreground="{StaticResource AccentStrongBrush}" BorderBrush="#DCE4FF" />
                    <Button Content="Entradas y salidas" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                    <Button Content="Kardex" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />

                    <TextBlock Text="ADMINISTRACION" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,22,0,10" />
                    <Button Content="Configuracion" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="82" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Centro de Inventario" FontSize="24" FontWeight="Black" />
                        <TextBlock Text="Datos reales desde el servidor" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Padding="14,9" CornerRadius="10" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1">
                            <TextBlock Text="{Binding UserName}" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <inventory:InventoryCenterView x:Name="InventoryCenterContent" Grid.Row="1" />
        </Grid>
    </Grid>
</UserControl>
