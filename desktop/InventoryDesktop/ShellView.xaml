<UserControl x:Class="InventoryDesktop.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inventory="clr-namespace:InventoryDesktop.Modules.InventoryCenter"
             xmlns:pos="clr-namespace:InventoryDesktop.Modules.POS">
    <Grid Background="#F4F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="24,24,24,18">
                    <Border Width="52" Height="52" CornerRadius="14" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="SI" Foreground="White" FontWeight="Black" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Sistema de Inventario" FontSize="22" FontWeight="Black" Margin="0,16,0,0" />
                    <TextBlock Text="{Binding TenantName}" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,0,12,18">
                    <StackPanel>
                        <TextBlock Text="OPERACIÓN" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,0,0,10" />
                        <Button Content="Resumen" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                        <Button Content="Centro de Ventas" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                        <Button x:Name="PosButton" Content="POS" Height="44" Margin="0,0,0,8" FontWeight="Bold" Click="Pos_Click" />

                        <TextBlock Text="INVENTARIO" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,22,0,10" />
                        <Button x:Name="InventoryCenterButton" Content="Centro de Inventario" Height="46" Margin="0,0,0,8" FontWeight="Black" Background="#EEF0FF" Foreground="{StaticResource AccentStrongBrush}" BorderBrush="#DCE4FF" Click="InventoryCenter_Click" />
                        <Button x:Name="InventoryMovementsButton" Content="Entradas y salidas" Height="44" Margin="0,0,0,8" FontWeight="Bold" Click="InventoryMovements_Click" />
                        <Button x:Name="PriceListsButton" Content="Listas de precio" Height="44" Margin="0,0,0,8" FontWeight="Bold" Click="PriceLists_Click" />
                        <Button Content="Kardex" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />

                        <TextBlock Text="ADMINISTRACIÓN" Foreground="#94A3B8" FontSize="12" FontWeight="Black" Margin="10,22,0,10" />
                        <Button Content="Configuración" Height="44" Margin="0,0,0,8" FontWeight="Bold" IsEnabled="False" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="82" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#E1E7F3" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="SectionTitle" Text="Centro de Inventario" FontSize="24" FontWeight="Black" />
                        <TextBlock x:Name="SectionSubtitle" Text="Datos reales desde el servidor" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Padding="14,9" CornerRadius="10" Background="#F7F9FD" BorderBrush="#E1E7F3" BorderThickness="1">
                            <TextBlock Text="{Binding UserName}" FontWeight="Black" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <inventory:InventoryCenterView x:Name="InventoryCenterContent" />
                <inventory:InventoryMovementsView x:Name="InventoryMovementsContent" Visibility="Collapsed" />
                <inventory:PriceListsView x:Name="PriceListsContent" Visibility="Collapsed" />
                <pos:PosView x:Name="PosContent" Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
