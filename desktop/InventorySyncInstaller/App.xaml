<Application x:Class="InventorySyncInstaller.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F36F5" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF0FF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE5F5" />
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Application.Resources>
</Application>
