<Window x:Class="InventorySyncInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurador del Sistema de Inventario"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F4" BorderThickness="0,0,0,1" Padding="28,22">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left" Width="54" Height="54" CornerRadius="14" Background="{StaticResource AccentBrush}" Margin="0,0,18,0">
                    <TextBlock Text="SI" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="Configurador del Sistema de Inventario" FontSize="30" FontWeight="Black" Foreground="#07142F" />
                    <TextBlock Text="Prepara esta computadora para trabajar con una empresa en la nube." FontSize="15" FontWeight="SemiBold" Foreground="#5B6B8A" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="12" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="#D8DEFF" BorderThickness="1" CornerRadius="8" Padding="12,7" HorizontalAlignment="Left">
                            <TextBlock Text="INSTALACION" Foreground="#2E22E8" FontWeight="Bold" />
                        </Border>

                        <TextBlock Text="Conexion con la nube" FontSize="24" FontWeight="Black" Foreground="#07142F" Margin="0,20,0,4" />
                        <TextBlock Text="Usa esta herramienta solo en instalaciones nuevas, cambios de empresa o soporte tecnico." TextWrapping="Wrap" Foreground="#5B6B8A" FontWeight="SemiBold" />

                        <TextBlock Text="URL del servidor" FontWeight="Bold" Margin="0,22,0,5" />
                        <TextBox x:Name="CloudUrlBox" Text="https://app.miinventariofacil.com/api" />

                        <TextBlock Text="Correo del administrador" FontWeight="Bold" Margin="0,14,0,5" />
                        <TextBox x:Name="EmailBox" />

                        <TextBlock Text="Contrasena" FontWeight="Bold" Margin="0,14,0,5" />
                        <PasswordBox x:Name="PasswordBox" />

                        <Button x:Name="SearchCompaniesButton" Content="Buscar empresas disponibles" Margin="0,18,0,0" Click="SearchCompanies_Click" />

                        <TextBlock Text="Empresa a configurar" FontWeight="Bold" Margin="0,18,0,5" />
                        <ComboBox x:Name="TenantBox" DisplayMemberPath="Name" SelectedValuePath="Slug" />

                        <TextBlock Text="Nombre de esta computadora" FontWeight="Bold" Margin="0,18,0,5" />
                        <TextBox x:Name="NodeNameBox" />

                        <TextBlock Text="Frecuencia de sincronizacion" FontWeight="Bold" Margin="0,14,0,5" />
                        <ComboBox x:Name="IntervalBox" SelectedIndex="1">
                            <ComboBoxItem Content="Cada 15 segundos" Tag="15" />
                            <ComboBoxItem Content="Cada 30 segundos" Tag="30" />
                            <ComboBoxItem Content="Cada 60 segundos" Tag="60" />
                        </ComboBox>

                        <Button x:Name="ValidateRequirementsButton" Content="Validar requisitos de esta PC" Margin="0,18,0,0" Click="ValidateRequirements_Click" />
                        <Button x:Name="PrepareButton" Content="Configurar e instalar sincronización" Background="{StaticResource AccentBrush}" Foreground="White" Margin="0,22,0,0" Click="Prepare_Click" />

                        <Border Background="#F8FAFE" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Soporte de sincronización" FontWeight="Black" FontSize="17" Foreground="#07142F" />
                                <TextBlock Text="El botón principal ya instala el worker automático. Usa estas opciones solo para reparar, iniciar, detener o revisar el estado." TextWrapping="Wrap" Foreground="#5B6B8A" FontWeight="SemiBold" Margin="0,4,0,10" />
                                <Button x:Name="InstallTaskButton" Content="Reinstalar automático en Windows" Background="{StaticResource AccentBrush}" Foreground="White" Click="InstallTask_Click" />
                                <UniformGrid Columns="3" Margin="0,10,0,0">
                                    <Button x:Name="StartTaskButton" Content="Iniciar" Margin="0,0,6,0" Click="StartTask_Click" />
                                    <Button x:Name="StopTaskButton" Content="Detener" Margin="3,0,3,0" Click="StopTask_Click" />
                                    <Button x:Name="TaskStatusButton" Content="Estado" Margin="6,0,0,0" Click="TaskStatus_Click" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="12" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="190" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Background="#EEF2FF" BorderBrush="#D8DEFF" BorderThickness="1" CornerRadius="8" Padding="12,7" HorizontalAlignment="Left">
                                <TextBlock x:Name="StateBadge" Text="Pendiente" Foreground="#2E22E8" FontWeight="Bold" />
                            </Border>
                            <TextBlock x:Name="StateTitle" Text="Listo para comenzar" FontSize="32" FontWeight="Black" Foreground="#07142F" Margin="0,18,0,6" />
                            <TextBlock x:Name="StateDetail" Text="Coloca el correo, busca las empresas y configura esta computadora." TextWrapping="Wrap" Foreground="#5B6B8A" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                        <ProgressBar x:Name="BusyBar" Grid.Column="1" IsIndeterminate="True" Visibility="Collapsed" Height="12" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,24,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Pasos de configuracion" FontSize="24" FontWeight="Black" Foreground="#07142F" />
                            <TextBlock Text="El configurador hace todo en orden: valida, prepara la base, sincroniza e instala el worker automático." TextWrapping="Wrap" Foreground="#5B6B8A" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,18,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Requisitos" FontWeight="Black" Foreground="#07142F" Margin="0,0,0,8" />
                                <ListBox x:Name="RequirementsList" BorderBrush="#E2E8F4" Height="210">
                                    <ListBoxItem Content="Aun no se han validado los requisitos." />
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Proceso" FontWeight="Black" Foreground="#07142F" Margin="0,0,0,8" />
                                <ListBox x:Name="StepsList" BorderBrush="#E2E8F4" Height="210">
                                    <ListBoxItem Content="1. Validar acceso del administrador" />
                                    <ListBoxItem Content="2. Obtener empresas disponibles" />
                                    <ListBoxItem Content="3. Preparar base local" />
                                    <ListBoxItem Content="4. Guardar configuración" />
                                    <ListBoxItem Content="5. Sincronizar datos iniciales" />
                                    <ListBoxItem Content="6. Instalar tarea automática de Windows" />
                                    <ListBoxItem Content="7. Iniciar worker y finalizar instalación" />
                                </ListBox>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Background="#F8FAFE" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="TechnicalSummaryText" Text="Los detalles tecnicos estan ocultos. Abrelos solo si necesitas soporte." TextWrapping="Wrap" Foreground="#5B6B8A" FontWeight="SemiBold" />
                                <Button x:Name="TechnicalDetailsButton" Content="Ver detalles tecnicos" Width="190" HorizontalAlignment="Left" Margin="0,12,0,0" Click="TechnicalDetails_Click" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="TechnicalDetailsPanel" Grid.Row="3" Visibility="Collapsed" BorderBrush="#DCE5F5" BorderThickness="1" CornerRadius="10">
                            <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" BorderThickness="0" Padding="14" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F4" BorderThickness="0,1,0,0" Padding="28,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Cuando termine, esta computadora quedara lista para abrir el sistema principal." Foreground="#5B6B8A" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button x:Name="OpenMainButton" DockPanel.Dock="Right" Content="Abrir Sistema de Inventario" Width="230" Background="{StaticResource AccentBrush}" Foreground="White" Margin="12,0,0,0" Visibility="Collapsed" Click="OpenMain_Click" />
                <Button DockPanel.Dock="Right" Content="Cerrar" Width="120" Click="Close_Click" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
