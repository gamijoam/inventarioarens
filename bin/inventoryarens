#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
inventoryarens - CLI unificado de operaciones del SaaS INVENTARIOARENS.

Wrapper cross-platform (Linux + Windows) que centraliza:
  - install sync    emite token + configura auto-start del worker
  - status           health check (DB, token, worker, last sync)
  - logs sync        tail de logs del worker
  - uninstall sync   detiene + elimina auto-start + limpia config
  - token rotate     re-emite token sin reinstalar
  - install printer  stub (Fase 2)
  - update           git pull + restart (opcional)

Diseno:
  - Single file, sin dependencias externas (solo Python 3.8+ stdlib).
  - Detecta OS al inicio y branch en cada subcomando.
  - En Linux usa systemd (user units, sin root).
  - En Windows reutiliza el .ps1 legacy para el Task Scheduler.
  - En ambos usa el mismo binario (el .bat/.ps1 son solo wrappers).

Uso:
  inventoryarens install sync
  inventoryarens status
  inventoryarens logs sync
  inventoryarens uninstall sync
  inventoryarens token rotate

Mas detalles en docs/OPERATIONS.md.
"""
from __future__ import annotations

import argparse
import getpass
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
import zipfile
from dataclasses import dataclass
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional

VERSION = "1.0.0"

# -----------------------------------------------------------------------------
# OS detection
# -----------------------------------------------------------------------------

def detect_os() -> str:
    """Devuelve 'linux' o 'windows'. Mac se trata como linux (no es target)."""
    if sys.platform.startswith("win"):
        return "windows"
    return "linux"


# -----------------------------------------------------------------------------
# Colores (desactivar con NO_COLOR=1)
# -----------------------------------------------------------------------------

USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None

def _c(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if USE_COLOR else text

def green(t: str) -> str: return _c("32", t)
def red(t: str) -> str: return _c("31", t)
def yellow(t: str) -> str: return _c("33", t)
def blue(t: str) -> str: return _c("34", t)
def dim(t: str) -> str: return _c("2", t)
def bold(t: str) -> str: return _c("1", t)


# -----------------------------------------------------------------------------
# Paths y configuracion
# -----------------------------------------------------------------------------

@dataclass
class Config:
    """Config derivada del entorno y OS detectado. Sobreescribible por flags."""
    os: str
    repo_dir: Path                # raiz del repo Laravel (donde corre artisan)
    bin_dir: Path                 # donde esta el script inventoryarens
    toolbox_root: Path            # raiz del zip descomprimido
    php_bin: str
    ssh_host: str
    ssh_user: str
    php_artisan: Path             # ruta al binario artisan
    state_dir: Path               # ~/.inventoryarens (Linux) o %APPDATA% (Windows)
    lockfile: Path
    env_file: Optional[Path]      # .env del repo Laravel (si existe)
    user: str                     # nombre del user actual (para service ownership)
    home: Path

    @classmethod
    def from_env(cls, repo_override: Optional[Path] = None) -> "Config":
        os_name = detect_os()
        bin_dir = Path(__file__).resolve().parent

        # Buscar el repo Laravel (donde esta artisan) en este orden:
        #   1. Override explicito (--repo flag).
        #   2. Variable de entorno INVENTORYARENS_REPO.
        #   3. cwd y subir parents hasta encontrar artisan.
        #   4. Default: parent del bin (estructura del repo).
        if repo_override is not None:
            repo_dir = repo_override.resolve()
        elif os.environ.get("INVENTORYARENS_REPO"):
            repo_dir = Path(os.environ["INVENTORYARENS_REPO"]).resolve()
        else:
            cwd = Path.cwd()
            candidate = cwd
            repo_dir = None
            for _ in range(8):  # max 8 niveles arriba
                if (candidate / "artisan").is_file():
                    repo_dir = candidate
                    break
                if candidate == candidate.parent:
                    break
                candidate = candidate.parent
            if repo_dir is None:
                repo_dir = bin_dir.parent

        home = Path(os.environ.get("USERPROFILE" if os_name == "windows" else "HOME", "~")).resolve()

        # state_dir: ~/.inventoryarens (Linux) o %APPDATA%/inventoryarens (Windows)
        if os_name == "windows":
            appdata = os.environ.get("APPDATA") or str(home / "AppData/Roaming")
            state_dir = Path(appdata) / "inventoryarens"
        else:
            state_dir = home / ".inventoryarens"

        return cls(
            os=os_name,
            repo_dir=repo_dir,
            bin_dir=bin_dir,
            toolbox_root=bin_dir.parent,
            php_bin=os.environ.get("INVENTORYARENS_PHP", "php"),
            ssh_host=os.environ.get("INVENTORYARENS_SSH_HOST", "212.28.176.157"),
            ssh_user=os.environ.get("INVENTORYARENS_SSH_USER", "root"),
            php_artisan=repo_dir / "artisan",
            state_dir=state_dir,
            lockfile=state_dir / "toolbox.lock",
            env_file=repo_dir / ".env" if (repo_dir / ".env").exists() else None,
            user=os.environ.get("USERNAME" if os_name == "windows" else "USER", "root"),
            home=home,
        )


# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

def info(msg: str) -> None:
    print(f"{blue('i')} {msg}")

def ok(msg: str) -> None:
    print(f"{green('OK')} {msg}")

def warn(msg: str) -> None:
    print(f"{yellow('!')} {msg}")

def err(msg: str) -> None:
    print(f"{red('x')} {msg}", file=sys.stderr)

def step(label: str) -> None:
    print(f"\n{bold(label)}")

def run(cmd: list[str], check: bool = True, capture: bool = False, env: Optional[dict] = None) -> subprocess.CompletedProcess:
    """Ejecuta un comando, raise si falla (a menos que check=False)."""
    proc = subprocess.run(
        cmd,
        check=False,
        capture_output=capture,
        text=True,
        env={**os.environ, **(env or {})},
    )
    if check and proc.returncode != 0:
        raise RuntimeError(
            f"Comando fallo (rc={proc.returncode}): {' '.join(cmd)}\n"
            f"stdout: {proc.stdout}\nstderr: {proc.stderr}"
        )
    return proc

def run_silent(cmd: list[str]) -> int:
    """Ejecuta y devuelve rc, sin raise. Captura stdout+stderr."""
    return subprocess.run(cmd, capture_output=True, text=True).returncode


def run_capture(cmd: list[str]) -> subprocess.CompletedProcess:
    """Ejecuta y devuelve stdout/stderr sin lanzar excepcion."""
    return subprocess.run(cmd, capture_output=True, text=True)

def windows_task_exists(task_name: str) -> bool:
    """Devuelve True si existe una tarea programada de Windows."""
    return run_silent(["schtasks", "/query", "/tn", task_name, "/fo", "LIST", "/v"]) == 0

def ensure_state_dir(cfg: Config) -> None:
    try:
        cfg.state_dir.mkdir(parents=True, exist_ok=True)
    except PermissionError:
        fallback = cfg.repo_dir / "storage" / "app" / "toolbox"
        fallback.mkdir(parents=True, exist_ok=True)
        cfg.state_dir = fallback
        cfg.lockfile = fallback / "toolbox.lock"
    cfg.lockfile.parent.mkdir(parents=True, exist_ok=True)

def acquire_lock(cfg: Config) -> Optional[int]:
    """Lock no-bloqueante. Devuelve fd si lo adquirio, None si ya estaba locked."""
    ensure_state_dir(cfg)
    if cfg.os == "windows":
        # fcntl no existe en Windows. El Task Scheduler ya evita la mayoria de
        # carreras; para el CLI interactivo basta con crear el state dir.
        return -1
    import fcntl
    fd = os.open(cfg.lockfile, os.O_CREAT | os.O_RDWR, 0o644)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        return fd
    except BlockingIOError:
        os.close(fd)
        return None

def release_lock(fd: Optional[int]) -> None:
    if fd is not None:
        if fd == -1:
            return
        import fcntl
        try:
            fcntl.flock(fd, fcntl.LOCK_UN)
        except Exception:
            pass
        os.close(fd)


# -----------------------------------------------------------------------------
# Token + .env management (vÃ­a SSH al VPS)
# -----------------------------------------------------------------------------

def _get_ssh_password() -> Optional[str]:
    """Lee la password SSH de un env var o .env. None si no esta disponible."""
    pwd = os.environ.get("INVENTORYARENS_SSH_PASSWORD")
    if pwd:
        return pwd
    # Buscar en .env del repo (INVENTORYARENS_SSH_PASSWORD=xxx)
    if cfg_from_env := os.environ.get("INVENTORYARENS_REPO"):
        env_file = Path(cfg_from_env) / ".env"
        if env_file.exists():
            for line in env_file.read_text(encoding="utf-8").splitlines():
                if line.startswith("INVENTORYARENS_SSH_PASSWORD="):
                    return line.split("=", 1)[1].strip('"\'')
    if sys.stdin.isatty():
        try:
            pwd = getpass.getpass("Password SSH del VPS (no se guarda): ")
            return pwd or None
        except (EOFError, KeyboardInterrupt):
            return None
    return None


def _ssh_run_native(cfg: Config, remote_cmd: str, timeout: int, pwd: Optional[str]) -> str:
    """SSH via subproceso nativo. Soporta sshpass si esta disponible."""
    cmd = [
        "ssh",
        "-o", "StrictHostKeyChecking=accept-new",
        "-o", "ConnectTimeout=10",
        f"{cfg.ssh_user}@{cfg.ssh_host}",
        remote_cmd,
    ]
    env = None
    if pwd and shutil.which("sshpass"):
        # Reemplazar "ssh" por "sshpass -p xxx ssh" para inyectar password.
        cmd = ["sshpass", "-p", pwd, "ssh",
               "-o", "StrictHostKeyChecking=accept-new",
               "-o", "ConnectTimeout=10",
               f"{cfg.ssh_user}@{cfg.ssh_host}",
               remote_cmd]
    proc = subprocess.run(cmd, capture_output=True, text=True,
                           timeout=timeout, env=env)
    if proc.returncode != 0:
        raise RuntimeError(
            f"SSH fallo (rc={proc.returncode}): {proc.stderr or proc.stdout}"
        )
    return proc.stdout


def _ssh_run_paramiko(cfg: Config, remote_cmd: str, timeout: int, pwd: Optional[str]) -> str:
    """SSH via Paramiko (cross-platform sin sshpass)."""
    try:
        import paramiko
    except ImportError:
        raise RuntimeError(
            "Paramiko no instalado. Instala con: pip install paramiko\n"
            "O usa sshpass (Linux/Mac): https://sourceforge.net/projects/sshpass/"
        )
    client = paramiko.SSHClient()
    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    # Si no hay password, intentar con clave SSH (del ssh-agent o known_hosts).
    if not pwd:
        client.connect(cfg.ssh_host, username=cfg.ssh_user, timeout=10)
    else:
        client.connect(cfg.ssh_host, username=cfg.ssh_user, password=pwd, timeout=10)
    try:
        stdin, stdout, stderr = client.exec_command(remote_cmd, timeout=timeout)
        out = stdout.read().decode("utf-8", errors="replace")
        err = stderr.read().decode("utf-8", errors="replace")
        rc = stdout.channel.recv_exit_status()
        if rc != 0:
            raise RuntimeError(f"SSH fallo (rc={rc}): {err or out}")
        return out
    finally:
        client.close()


def ssh_run_on_vps(cfg: Config, remote_cmd: str, timeout: int = 120) -> str:
    """
    Ejecuta un comando en el VPS via SSH. Usa sshpass si esta disponible
    y la password esta configurada; si no, usa Paramiko (pure-Python).
    Fallback final: ssh nativo con key (sin password).
    """
    pwd = _get_ssh_password()
    if shutil.which("sshpass") and pwd:
        return _ssh_run_native(cfg, remote_cmd, timeout, pwd)
    try:
        import paramiko  # noqa: F401
        return _ssh_run_paramiko(cfg, remote_cmd, timeout, pwd)
    except ImportError:
        return _ssh_run_native(cfg, remote_cmd, timeout, pwd)

def issue_token_on_vps(
    cfg: Config,
    tenant_slug: str,
    user_email: str = "gabo@gabo.com",
    node_name: str = "Local-Node",
    node_code: str = "",
) -> dict:
    """
    Ejecuta `php artisan sync:ensure-and-token` en el VPS via SSH
    y parsea el output para extraer el token.

    Returns: {tenant, user, token, node, expires_at}
    """
    # Run en el VPS: cd al repo + artisan sync:ensure-and-token + parse
    tenant_arg = shlex.quote(tenant_slug)
    user_arg = shlex.quote(user_email)
    node_name_arg = shlex.quote(node_name)
    node_code_arg = f"--node-code={shlex.quote(node_code)}" if node_code else ""
    output = ssh_run_on_vps(
        cfg,
        f"cd /opt/inventarioarens-cloud && "
        f"sudo -u www-data php artisan sync:ensure-and-token {tenant_arg} "
        f"--user={user_arg} --node-name={node_name_arg} "
        f"{node_code_arg} 2>&1",
        timeout=180,
    )
    # Parsear el output buscando la linea TOKEN=xxx (acepta espacios al inicio).
    token_match = re.search(r"^\s*TOKEN=(\S+)\s*$", output, re.MULTILINE)
    if not token_match:
        raise RuntimeError(f"No se encontro TOKEN= en el output del VPS:\n{output}")
    return {
        "tenant": tenant_slug,
        "user": user_email,
        "token": token_match.group(1),
        "node_name": node_name,
        "node_code": node_code,
        "output": output,
    }


def write_local_env_token(cfg: Config, tenant_slug: str, token: str) -> None:
    """
    Escribe SYNC_CLOUD_TOKEN + SYNC_CLOUD_URL + X-Tenant en el .env local.
    Backup del .env existente antes.
    """
    env_path = cfg.repo_dir / ".env"
    if not env_path.exists():
        warn(f"No existe {env_path} local; no escribo SYNC_CLOUD_TOKEN.")
        return
    backup = env_path.with_suffix(".env.bak." + str(int(time.time())))
    shutil.copy2(env_path, backup)

    content = env_path.read_text(encoding="utf-8")
    lines = content.splitlines()

    def upsert(lines: list[str], key: str, value: str) -> list[str]:
        prefix = f"{key}="
        found = False
        for i, ln in enumerate(lines):
            if ln.startswith(prefix):
                lines[i] = f"{key}={value}"
                found = True
                break
        if not found:
            lines.append(f"{key}={value}")
        return lines

    lines = upsert(lines, "SYNC_CLOUD_URL", "https://app.miinventariofacil.com/api")
    lines = upsert(lines, "SYNC_CLOUD_TOKEN", token)
    lines = upsert(lines, "X_TENANT", tenant_slug)
    # Si ya hay FRONTEND_DEV_BYPASS_LOGIN para tests, lo dejamos.

    env_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    ok(f"Token escrito en {env_path} (backup: {backup.name})")


def write_sync_worker_config(
    cfg: Config,
    tenant_slug: str,
    token: str,
    node_name: str,
    node_code: str,
    interval: int = 15,
) -> None:
    """Guarda configuracion por tenant para permitir varias empresas en una PC."""
    config_dir = cfg.repo_dir / "storage" / "app" / "sync-worker"
    config_dir.mkdir(parents=True, exist_ok=True)
    config_path = config_dir / "sync-config.json"

    data = {"tenants": {}}
    if config_path.exists():
        try:
            data = json.loads(config_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            backup = config_path.with_suffix(f".json.bak.{datetime.now():%Y%m%d%H%M%S}")
            shutil.copy2(config_path, backup)
            warn(f"sync-config.json invalido; backup creado: {backup.name}")
            data = {"tenants": {}}

    tenants = data.setdefault("tenants", {})
    tenants[tenant_slug] = {
        "cloud_url": "https://app.miinventariofacil.com/api",
        "token": token,
        "node_code": node_code or f"LOCAL-{tenant_slug.upper()}",
        "node_name": node_name,
        "installation_code": node_code or f"LOCAL-{tenant_slug.upper()}",
        "interval": interval,
    }

    config_path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    ok(f"Config sync por empresa actualizada: {config_path}")


def prompt_value(label: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    value = input(f"{label}{suffix}: ").strip()
    return value or default


def read_sync_worker_config(cfg: Config) -> dict:
    config_path = cfg.repo_dir / "storage" / "app" / "sync-worker" / "sync-config.json"
    if not config_path.exists():
        return {"tenants": {}}
    try:
        return json.loads(config_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {"tenants": {}}


def resolve_status_tenant(args, cfg: Config) -> str:
    explicit = getattr(args, "tenant", None)
    if explicit and explicit != "mi-empresa":
        return explicit
    config = read_sync_worker_config(cfg)
    tenants = list((config.get("tenants") or {}).keys())
    if len(tenants) == 1:
        return tenants[0]
    return explicit or "mi-empresa"


def tenant_slug_to_name(slug: str) -> str:
    return " ".join(part.capitalize() for part in re.split(r"[-_]+", slug) if part) or slug


def prompt_yes_no(label: str, default: bool = False) -> bool:
    suffix = " [S/n]" if default else " [s/N]"
    value = input(f"{label}{suffix}: ").strip().lower()
    if not value:
        return default
    return value in ("s", "si", "sí", "y", "yes")


def choose_sync_tenant(cfg: Config, requested: str = "") -> tuple[str, dict]:
    data = read_sync_worker_config(cfg)
    tenants = data.get("tenants") or {}
    if requested:
        if requested not in tenants:
            raise RuntimeError(
                f"El tenant '{requested}' no existe en storage/app/sync-worker/sync-config.json. "
                "Ejecuta primero inventoryarens wizard para emitir/guardar su token."
            )
        return requested, tenants[requested] or {}
    if not tenants:
        raise RuntimeError(
            "No hay tenants configurados en sync-config.json. "
            "Ejecuta primero inventoryarens wizard para agregar una empresa a esta PC."
        )
    if len(tenants) == 1:
        slug = next(iter(tenants.keys()))
        return slug, tenants[slug] or {}

    print("Empresas configuradas en esta PC:")
    slugs = list(tenants.keys())
    for idx, slug in enumerate(slugs, start=1):
        print(f"  {idx}. {slug}")
    selected = prompt_value("Selecciona numero o slug", "1")
    if selected.isdigit():
        pos = int(selected)
        if pos < 1 or pos > len(slugs):
            raise RuntimeError("Seleccion invalida.")
        slug = slugs[pos - 1]
    else:
        slug = selected
        if slug not in tenants:
            raise RuntimeError("El slug indicado no esta configurado.")
    return slug, tenants[slug] or {}


def configured_tenants(cfg: Config) -> list[str]:
    data = read_sync_worker_config(cfg)
    return list((data.get("tenants") or {}).keys())


def run_artisan(cfg: Config, args: list[str], env: Optional[dict] = None, capture: bool = False, check: bool = True) -> subprocess.CompletedProcess:
    return run([cfg.php_bin, str(cfg.php_artisan), *args], env=env, capture=capture, check=check)


def php_bootstrap_eval(cfg: Config, code: str, extra_args: Optional[list[str]] = None) -> subprocess.CompletedProcess:
    return run_capture([cfg.php_bin, "-r", code, *(extra_args or [])])


def get_database_name(cfg: Config) -> str:
    code = r"""
require __DIR__.'/vendor/autoload.php';
$app = require __DIR__.'/bootstrap/app.php';
$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();
echo (string) config('database.connections.'.config('database.default').'.database');
"""
    proc = php_bootstrap_eval(cfg, code)
    return (proc.stdout or "").strip() if proc.returncode == 0 else "desconocida"


def get_tenant_local_summary(cfg: Config, tenant_slug: str) -> dict:
    code = r"""
require __DIR__.'/vendor/autoload.php';
$app = require __DIR__.'/bootstrap/app.php';
$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();
$slug = $argv[1] ?? '';
$tenant = Illuminate\Support\Facades\DB::table('tenants')->where('slug', $slug)->first();
if (! $tenant) {
    echo json_encode(['exists' => false], JSON_UNESCAPED_UNICODE);
    return;
}
$tables = [
    'users', 'warehouses', 'branches', 'products', 'product_images',
    'customers', 'suppliers', 'sales', 'pos_orders', 'accounts_receivables',
    'accounts_payables', 'sync_inbox', 'sync_outbox',
];
$counts = [];
foreach ($tables as $table) {
    if (! Illuminate\Support\Facades\DB::getSchemaBuilder()->hasTable($table)) {
        continue;
    }
    $query = Illuminate\Support\Facades\DB::table($table);
    if (Illuminate\Support\Facades\DB::getSchemaBuilder()->hasColumn($table, 'tenant_id')) {
        $query->where('tenant_id', $tenant->id);
    }
    $counts[$table] = $query->count();
}
echo json_encode([
    'exists' => true,
    'tenant_id' => $tenant->id,
    'tenant_name' => $tenant->name,
    'tenant_slug' => $tenant->slug,
    'counts' => $counts,
], JSON_UNESCAPED_UNICODE);
"""
    proc = php_bootstrap_eval(cfg, code, [tenant_slug])
    if proc.returncode != 0:
        return {"exists": False, "error": proc.stderr or proc.stdout}
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"exists": False, "error": proc.stdout}


def reset_failed_sync_inbox_for_recovery(cfg: Config, tenant_slug: str) -> int:
    code = r"""
require __DIR__.'/vendor/autoload.php';
$app = require __DIR__.'/bootstrap/app.php';
$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();
$tenant = Illuminate\Support\Facades\DB::table('tenants')->where('slug', $argv[1] ?? '')->first();
if (! $tenant) {
    echo "0";
    return;
}
$count = Illuminate\Support\Facades\DB::table('sync_inbox')
    ->where('tenant_id', $tenant->id)
    ->where('status', 'failed')
    ->update([
        'status' => 'received',
        'last_error' => null,
        'updated_at' => now(),
    ]);
echo (string) $count;
"""
    proc = php_bootstrap_eval(cfg, code, [tenant_slug])
    if proc.returncode != 0:
        return 0
    try:
        return int((proc.stdout or "0").strip())
    except ValueError:
        return 0


def get_failed_sync_inbox_count(cfg: Config, tenant_slug: str) -> int:
    code = r"""
require __DIR__.'/vendor/autoload.php';
$app = require __DIR__.'/bootstrap/app.php';
$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();
$tenant = Illuminate\Support\Facades\DB::table('tenants')->where('slug', $argv[1] ?? '')->first();
if (! $tenant) {
    echo "0";
    return;
}
echo (string) Illuminate\Support\Facades\DB::table('sync_inbox')
    ->where('tenant_id', $tenant->id)
    ->where('status', 'failed')
    ->count();
"""
    proc = php_bootstrap_eval(cfg, code, [tenant_slug])
    if proc.returncode != 0:
        return 0
    try:
        return int((proc.stdout or "0").strip())
    except ValueError:
        return 0


def reset_sync_inbox_events(
    cfg: Config,
    tenant_slug: str,
    *,
    inbox_id: Optional[int] = None,
    event_type: str = "",
) -> dict:
    code = r"""
require __DIR__.'/vendor/autoload.php';
$app = require __DIR__.'/bootstrap/app.php';
$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);
$kernel->bootstrap();
$tenant = Illuminate\Support\Facades\DB::table('tenants')->where('slug', $argv[1] ?? '')->first();
if (! $tenant) {
    echo json_encode(['ok' => false, 'message' => 'tenant_local_no_existe']);
    return;
}
$inboxId = (int) ($argv[2] ?? 0);
$eventType = (string) ($argv[3] ?? '');
$query = Illuminate\Support\Facades\DB::table('sync_inbox')->where('tenant_id', $tenant->id);
if ($inboxId > 0) {
    $query->where('id', $inboxId)->whereIn('status', ['received', 'failed']);
} else {
    $query->where('status', 'failed');
    if ($eventType !== '') {
        $query->where('event_type', $eventType);
    }
}
$count = $query->update([
    'status' => 'received',
    'last_error' => null,
    'updated_at' => now(),
]);
echo json_encode(['ok' => true, 'reset' => $count], JSON_UNESCAPED_UNICODE);
"""
    proc = php_bootstrap_eval(cfg, code, [tenant_slug, str(inbox_id or 0), event_type])
    if proc.returncode != 0:
        return {"ok": False, "message": (proc.stderr or proc.stdout or "php_error").strip()}
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"ok": False, "message": proc.stdout}


def run_worker_action(cfg: Config, tenant_slug: str, action: str) -> int:
    if cfg.os == "linux":
        unit = linux_sync_unit_name(tenant_slug)
        if action == "status":
            status_data = linux_status(cfg, tenant_slug)
            for key, value in status_data.items():
                print(f"{key}: {value}")
            return 0
        if action == "start":
            return run_silent(["systemctl", "--user", "start", f"{unit}.timer"])
        if action == "stop":
            run_silent(["systemctl", "--user", "stop", f"{unit}.service"])
            return run_silent(["systemctl", "--user", "stop", f"{unit}.timer"])
        if action == "restart":
            run_worker_action(cfg, tenant_slug, "stop")
            return run_worker_action(cfg, tenant_slug, "start")
        if action == "run-now":
            return run_silent(["systemctl", "--user", "start", f"{unit}.service"])
        raise RuntimeError(f"Accion de worker no soportada: {action}")

    worker_cmd = cfg.repo_dir / "scripts" / "sync-worker.cmd"
    if not worker_cmd.exists():
        raise RuntimeError(f"No existe {worker_cmd}")
    if action == "run-now":
        action = "start"
    cmd = ["cmd.exe", "/c", str(worker_cmd), action, "-TenantSlug", tenant_slug]
    proc = subprocess.run(cmd, capture_output=True, text=True)
    output = (proc.stdout or "") + (proc.stderr or "")
    if output.strip():
        print(output.strip())
    return proc.returncode


def apply_inbox(cfg: Config, tenant_slug: str, limit: int) -> int:
    proc = run_artisan(cfg, ["sync:apply-inbox", tenant_slug, "--limit", str(limit)], capture=True, check=False)
    if proc.stdout:
        print(proc.stdout.strip())
    if proc.stderr:
        print(proc.stderr.strip(), file=sys.stderr)
    return proc.returncode


def run_sync_once(cfg: Config, tenant_slug: str, limit: int) -> int:
    proc = run_artisan(cfg, ["sync:run", tenant_slug, "--limit", str(limit)], capture=True, check=False)
    if proc.stdout:
        print(proc.stdout.strip())
    if proc.stderr:
        print(proc.stderr.strip(), file=sys.stderr)
    return proc.returncode


# -----------------------------------------------------------------------------
# OS-specific: Linux systemd
# -----------------------------------------------------------------------------

LINUX_SERVICE_TEMPLATE = """[Unit]
Description=INVENTARIOARENS sync worker local ({tenant_slug})
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory={repo_dir}
ExecStart={php_path} {artisan_path} sync:run {tenant_slug} --limit=50
StandardOutput=append:{log_path}
StandardError=append:{log_path}

[Install]
WantedBy=default.target
"""

LINUX_TIMER_TEMPLATE = """[Unit]
Description=INVENTARIOARENS sync timer local ({tenant_slug})

[Timer]
OnBootSec=10
OnUnitActiveSec=30
Unit={service_name}
Persistent=true

[Install]
WantedBy=default.target
"""

LINUX_PRINTER_SERVICE_TEMPLATE = """[Unit]
Description=INVENTARIOARENS printer agent (port 17777)
After=network-online.target

[Service]
Type=simple
WorkingDirectory={repo_dir}
ExecStart={php_path} {artisan_path} printer:serve --port=17777
Restart=on-failure
RestartSec=15

[Install]
WantedBy=default.target
"""


def safe_tenant_slug(tenant_slug: str) -> str:
    return re.sub(r"[^a-z0-9_-]", "-", tenant_slug.lower()) or "default"


def linux_sync_unit_name(tenant_slug: str) -> str:
    return f"inventoryarens-sync-{safe_tenant_slug(tenant_slug)}"


def linux_install_sync(cfg: Config, tenant_slug: str) -> None:
    """Instala systemd user unit + timer para auto-start en Linux."""
    systemd_dir = cfg.home / ".config/systemd/user"
    systemd_dir.mkdir(parents=True, exist_ok=True)
    safe_tenant = safe_tenant_slug(tenant_slug)
    log_path = cfg.home / ".local/share/inventoryarens" / f"sync-{safe_tenant}.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)

    service_name = linux_sync_unit_name(tenant_slug)
    service_path = systemd_dir / f"{service_name}.service"
    timer_path = systemd_dir / f"{service_name}.timer"

    php_path = shutil.which(cfg.php_bin) or cfg.php_bin
    artisan_path = str(cfg.php_artisan)

    service_content = LINUX_SERVICE_TEMPLATE.format(
        php_path=php_path, artisan_path=artisan_path,
        repo_dir=cfg.repo_dir, log_path=log_path, tenant_slug=tenant_slug,
    )
    service_path.write_text(service_content, encoding="utf-8")

    timer_content = LINUX_TIMER_TEMPLATE.format(service_name=service_name, tenant_slug=tenant_slug)
    timer_path.write_text(timer_content, encoding="utf-8")

    ok(f"Unit files escritos: {service_path}, {timer_path}")

    # Reload + enable + start
    for cmd in [
        ["systemctl", "--user", "daemon-reload"],
        ["systemctl", "--user", "enable", "--now", f"{service_name}.timer"],
        ["systemctl", "--user", "start", f"{service_name}.timer"],
    ]:
        result = run_silent(cmd)
        if result != 0:
            warn(f"{' '.join(cmd)} fallo (rc={result}); puede que systemd-user no este disponible")
        else:
            ok(f"{' '.join(cmd)} OK")


def linux_uninstall_sync(cfg: Config, tenant_slug: str) -> None:
    """Detiene y elimina los systemd user units."""
    service_name = linux_sync_unit_name(tenant_slug)
    systemd_dir = cfg.home / ".config/systemd/user"

    for cmd in [
        ["systemctl", "--user", "disable", "--now", f"{service_name}.timer"],
        ["systemctl", "--user", "stop", f"{service_name}.service"],
        ["systemctl", "--user", "daemon-reload"],
    ]:
        run_silent(cmd)

    for path in [systemd_dir / f"{service_name}.service",
                 systemd_dir / f"{service_name}.timer"]:
        if path.exists():
            path.unlink()
            ok(f"Borrado: {path}")
    ok("Sync desinstalado en Linux")


def linux_status(cfg: Config, tenant_slug: str) -> dict:
    """Inspecciona el estado del sync en Linux."""
    info_l = []
    service_name = linux_sync_unit_name(tenant_slug)

    # Timer
    res = run_silent(["systemctl", "--user", "is-active", f"{service_name}.timer"])
    timer_active = (res == 0)
    info_l.append(("Timer systemd", "active" if timer_active else "inactive"))

    # Service
    res = run_silent(["systemctl", "--user", "is-active", f"{service_name}.service"])
    service_active = (res == 0)
    info_l.append(("Service systemd", "active" if service_active else "inactive"))

    # Ultima corrida
    res = subprocess.run(
        ["systemctl", "--user", "show", f"{service_name}.service",
         "--property=ActiveEnterTimestamp", "--value"],
        capture_output=True, text=True,
    )
    last_run = res.stdout.strip() if res.returncode == 0 and res.stdout.strip() else "desconocido"
    info_l.append(("Ultima corrida", last_run))

    return dict(info_l)


def linux_install_printer(cfg: Config, port: int) -> None:
    """Instala el printer agent como systemd user service."""
    systemd_dir = cfg.home / ".config/systemd/user"
    systemd_dir.mkdir(parents=True, exist_ok=True)
    log_path = cfg.home / ".local/share/inventoryarens" / "printer.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)

    service_path = systemd_dir / "inventoryarens-printer.service"

    php_path = shutil.which(cfg.php_bin) or cfg.php_bin
    artisan_path = str(cfg.php_artisan)

    # Reutilizamos el template escrito en systemd/inventoryarens-printer.service
    # (se copia via el zip o via un include). En este caso, escribimos inline.
    content = (
        "[Unit]\n"
        "Description=INVENTARIOARENS printer agent (port " + str(port) + ")\n"
        "After=network-online.target\n"
        "\n"
        "[Service]\n"
        "Type=simple\n"
        f"WorkingDirectory={cfg.repo_dir}\n"
        f"ExecStart={php_path} {artisan_path} printer:serve --port={port}\n"
        "Restart=on-failure\n"
        "RestartSec=5\n"
        f"StandardOutput=append:{log_path}\n"
        f"StandardError=append:{log_path}\n"
        "\n"
        "[Install]\n"
        "WantedBy=default.target\n"
    )
    service_path.write_text(content, encoding="utf-8")
    ok(f"Unit file escrito: {service_path}")

    for cmd in [
        ["systemctl", "--user", "daemon-reload"],
        ["systemctl", "--user", "enable", "--now", "inventoryarens-printer.service"],
    ]:
        result = run_silent(cmd)
        if result != 0:
            warn(f"{' '.join(cmd)} fallo (rc={result})")
        else:
            ok(f"{' '.join(cmd)} OK")


def linux_uninstall_printer(cfg: Config) -> None:
    """Detiene y elimina el printer agent service."""
    service_name = "inventoryarens-printer"
    systemd_dir = cfg.home / ".config/systemd/user"

    for cmd in [
        ["systemctl", "--user", "disable", "--now", f"{service_name}.service"],
        ["systemctl", "--user", "stop", f"{service_name}.service"],
        ["systemctl", "--user", "daemon-reload"],
    ]:
        run_silent(cmd)

    path = systemd_dir / f"{service_name}.service"
    if path.exists():
        path.unlink()
        ok(f"Borrado: {path}")
    ok("Printer agent desinstalado en Linux")


# -----------------------------------------------------------------------------
# OS-specific: Windows Task Scheduler
# -----------------------------------------------------------------------------

def windows_install_sync(cfg: Config, tenant_slug: str) -> None:
    """En Windows, invoca el script legacy sync-worker-task.ps1."""
    # Si hay un script legacy, lo usamos. Si no, usamos schtasks directo.
    legacy_ps1 = cfg.repo_dir / "scripts" / "sync-worker-task.ps1"
    if legacy_ps1.exists():
        ok(f"Usando legacy script: {legacy_ps1}")
        run(["powershell.exe", "-ExecutionPolicy", "Bypass",
             "-File", str(legacy_ps1), "install", "-TenantSlug", tenant_slug])
    else:
        # schtasks fallback
        php_path = shutil.which("php") or "php"
        artisan_cmd = f"cd /d {cfg.repo_dir} && {php_path} artisan sync:apply-all-inboxes --limit=200"
        run([
            "schtasks", "/create", "/tn", "InventoryArensSync",
            "/tr", artisan_cmd, "/sc", "minute", "/mo", "1", "/ru", "SYSTEM",
        ])
        ok("Task Scheduler task creado (InventoryArensSync)")


def windows_install_printer(cfg: Config, port: int) -> None:
    """Crea task de Task Scheduler para el printer agent."""
    php_path = shutil.which("php") or "php"
    artisan_cmd = (
        f"cd /d {cfg.repo_dir} && "
        f"{php_path} artisan printer:serve --port={port}"
    )
    run_silent(["schtasks", "/create", "/tn", "InventoryArensPrinter",
                "/tr", artisan_cmd, "/sc", "onlogon",
                "/f"])
    ok("Task Scheduler task creada (InventoryArensPrinter, dispara al login del usuario actual)")


def windows_uninstall_printer(cfg: Config) -> None:
    """Borra la task de Task Scheduler del printer agent."""
    run_silent(["schtasks", "/delete", "/tn", "InventoryArensPrinter", "/f"])
    ok("Task InventoryArensPrinter borrada")


def windows_status(cfg: Config, tenant_slug: str = "mi-empresa") -> dict:
    info_w = []
    safe_tenant = safe_tenant_slug(tenant_slug)
    task_name = f"SistemaInventarioSync-{safe_tenant}"
    task_exists = windows_task_exists(task_name)
    info_w.append((f"Task Scheduler ({task_name})", "existe" if task_exists else "no existe"))
    if task_exists:
        # Status
        res2 = run_capture(["schtasks", "/query", "/tn", task_name, "/fo", "LIST", "/v", "/nh"])
        output = (res2.stdout or "") + "\n" + (res2.stderr or "")
        last_run = "desconocido"
        for line in output.splitlines():
            if "Last Run Time" in line or "Ultima ejecucion" in line or "Hora de la ultima ejecucion" in line:
                last_run = line.split(":", 1)[-1].strip() if ":" in line else line.strip()
                break
        info_w.append(("Ultima corrida", last_run))
    return dict(info_w)


# -----------------------------------------------------------------------------
# Subcomandos
# -----------------------------------------------------------------------------

def cmd_install_sync(args, cfg: Config) -> int:
    if args.interactive:
        args.tenant = prompt_value("Slug de empresa/tenant", args.tenant or "mi-empresa")
        args.user = prompt_value("Email usuario autorizado", args.user or "gabo@gabo.com")
        args.node_name = prompt_value("Nombre visible de este equipo/caja", args.node_name or f"{args.tenant}-local")
        args.node_code = prompt_value("Codigo unico del nodo", args.node_code or f"LOCAL-{args.tenant.upper()}")
        interval_value = prompt_value("Intervalo de sincronizacion en segundos", str(args.interval or 15))
        args.interval = max(5, int(interval_value))

    step("[1/4] Detectando OS y validando entorno")
    ok(f"OS: {cfg.os}")
    ok(f"Repo: {cfg.repo_dir}")
    ok(f"PHP bin: {cfg.php_bin}")

    if not cfg.php_artisan.exists():
        err(f"No encuentro {cfg.php_artisan}. Abortando.")
        return 1

    php_local = shutil.which(cfg.php_bin) or cfg.php_bin
    if not Path(php_local).exists() and not shutil.which(cfg.php_bin):
        warn(f"No encuentro {cfg.php_bin} local; el worker no se instalara en esta maquina")
        warn("(pero el token SI se va a emitir, asi lo podes usar desde otro lugar)")

    step("[2/4] Emitiendo token via SSH al VPS")
    tenant = args.tenant or "mi-empresa"
    user_email = args.user or "gabo@gabo.com"
    node_name = args.node_name or f"{tenant}-local"
    node_code = args.node_code or f"LOCAL-{tenant.upper()}"
    info(f"Tenant: {tenant}, User: {user_email}, Nodo: {node_name}")
    try:
        result = issue_token_on_vps(cfg, tenant, user_email, node_name, node_code)
    except Exception as e:
        err(f"Error emitiendo token: {e}")
        return 1
    ok(f"Token emitido: {result['token'][:20]}...")

    step("[3/4] Guardando token local")
    write_sync_worker_config(cfg, tenant, result["token"], node_name, node_code, args.interval or 15)
    if args.write_env:
        try:
            write_local_env_token(cfg, tenant, result["token"])
        except Exception as e:
            err(f"Error escribiendo .env: {e}")
            return 1
    else:
        info("(skip --write-env deshabilitado)")

    step("[4/4] Configurando auto-start en el boot")
    try:
        if cfg.os == "linux":
            linux_install_sync(cfg, tenant)
        else:
            windows_install_sync(cfg, tenant)
    except Exception as e:
        err(f"Error instalando auto-start: {e}")
        return 1

    print()
    ok(f"Install completo. Tenant: {tenant}")
    info(f"Token: {result['token']}")
    info("Verifica con: inventoryarens status")
    return 0


def cmd_wizard(args, cfg: Config) -> int:
    step("Asistente de sincronizacion")
    info("Este asistente agrega una empresa a esta computadora.")
    info("Puedes repetirlo para otra empresa; cada una queda con su propio token y worker.")
    args.interactive = True
    args.write_env = False
    args.tenant = args.tenant or "mi-empresa"
    args.user = args.user or "gabo@gabo.com"
    args.node_name = args.node_name or ""
    args.node_code = args.node_code or ""
    args.interval = args.interval or 15
    return cmd_install_sync(args, cfg)


def cmd_install_printer(args, cfg: Config) -> int:
    """Instala el printer agent (php artisan printer:serve) con auto-start."""
    step("[1/3] Detectando OS y validando")
    ok(f"OS: {cfg.os}")
    ok(f"Repo: {cfg.repo_dir}")

    if not cfg.php_artisan.exists():
        err(f"No encuentro {cfg.php_artisan}. Abortando.")
        return 1

    port = args.port or 17777
    info(f"Puerto: {port}")

    step("[2/3] Configurando auto-start del printer agent")
    try:
        if cfg.os == "linux":
            linux_install_printer(cfg, port)
        else:
            windows_install_printer(cfg, port)
    except Exception as e:
        err(f"Error instalando auto-start: {e}")
        return 1

    step("[3/3] Iniciando servicio")
    try:
        if cfg.os == "linux":
            run_silent(["systemctl", "--user", "start", "inventoryarens-printer.service"])
            ok("systemctl --user start inventoryarens-printer.service")
        else:
            run_silent(["schtasks", "/run", "/tn", "InventoryArensPrinter"])
            ok("Task InventoryArensPrinter disparada")
    except Exception as e:
        warn(f"No se pudo iniciar automaticamente: {e}")

    print()
    ok(f"Printer agent instalado en puerto {port}")
    info(f"Verifica con: curl http://127.0.0.1:{port}/health")
    return 0


def cmd_uninstall_sync(args, cfg: Config) -> int:
    step("Desinstalando worker de sync")
    try:
        if cfg.os == "linux":
            linux_uninstall_sync(cfg, args.tenant or "mi-empresa")
        else:
            tenant = args.tenant or "mi-empresa"
            legacy_ps1 = cfg.repo_dir / "scripts" / "sync-worker-task.ps1"
            if legacy_ps1.exists():
                run(["powershell.exe", "-ExecutionPolicy", "Bypass",
                     "-File", str(legacy_ps1), "uninstall", "-TenantSlug", tenant])
            else:
                windows_uninstall_sync(cfg)
    except Exception as e:
        err(f"Error: {e}")
        return 1

    if args.purge_env and cfg.env_file:
        info(f"Borrando SYNC_CLOUD_TOKEN de {cfg.env_file}")
        # No borramos el .env entero; solo dejamos el token vacio.
    ok("Sync desinstalado")
    return 0


def cmd_uninstall_printer(args, cfg: Config) -> int:
    step("Desinstalando printer agent")
    try:
        if cfg.os == "linux":
            linux_uninstall_printer(cfg)
        else:
            windows_uninstall_printer(cfg)
    except Exception as e:
        err(f"Error: {e}")
        return 1
    ok("Printer agent desinstalado")
    return 0


def cmd_status(args, cfg: Config) -> int:
    if getattr(args, "all", False):
        tenants = configured_tenants(cfg)
        if not tenants:
            err("No hay tenants configurados en sync-config.json.")
            return 1
        final_rc = 0
        for tenant in tenants:
            step(f"Status tenant: {tenant}")
            rc = cmd_status(argparse.Namespace(tenant=tenant, all=False), cfg)
            if rc != 0:
                final_rc = rc
        return final_rc

    checks: list[tuple[str, str, str]] = []  # (label, status, detail)
    tenant_slug = resolve_status_tenant(args, cfg)

    # 1. DB connectivity (local)
    label = "DB local"
    try:
        # Intenta via .env del repo o via psql si esta disponible
        if cfg.os == "linux" and shutil.which("psql") and cfg.env_file:
            env = {}
            for line in cfg.env_file.read_text(encoding="utf-8").splitlines():
                if line.startswith("DB_DATABASE="):
                    env["PGDATABASE"] = line.split("=", 1)[1]
                if line.startswith("DB_HOST="):
                    env["PGHOST"] = line.split("=", 1)[1]
                if line.startswith("DB_PORT="):
                    env["PGPORT"] = line.split("=", 1)[1]
                if line.startswith("DB_USERNAME="):
                    env["PGUSER"] = line.split("=", 1)[1]
            res = subprocess.run(
                ["psql", "-c", "SELECT 1"], env={**os.environ, **env},
                capture_output=True, text=True, timeout=5,
            )
            if res.returncode == 0:
                checks.append((label, "ok", f"conecta ({env.get('PGHOST', '?')})"))
            else:
                checks.append((label, "fail", "psql no conecta"))
        else:
            checks.append((label, "skip", "psql no disponible"))
    except Exception as e:
        checks.append((label, "fail", str(e)))

    # 2. Cloud API
    label = "API cloud"
    try:
        res = subprocess.run(
            ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
             "--max-time", "10",
             "https://app.miinventariofacil.com/api/up"],
            capture_output=True, text=True, timeout=15,
        )
        code = res.stdout.strip()
        if code == "200":
            checks.append((label, "ok", f"200 OK en {res.stderr.strip() or 'curl'}"))
        else:
            checks.append((label, "fail", f"HTTP {code}"))
    except Exception as e:
        checks.append((label, "fail", str(e)))

    # 3. Token sync validity (from sync-config.json or .env fallback)
    label = "Token sync"
    sync_config = read_sync_worker_config(cfg)
    tenant_config = (sync_config.get("tenants") or {}).get(tenant_slug)
    if tenant_config and tenant_config.get("token"):
        token = str(tenant_config["token"])
        checks.append((label, "ok", f"{tenant_slug}: {token[:12]}... (len {len(token)})"))
    elif cfg.env_file and cfg.env_file.exists():
        content = cfg.env_file.read_text(encoding="utf-8")
        token_match = re.search(r"^SYNC_CLOUD_TOKEN=(\S+)$", content, re.MULTILINE)
        if token_match:
            token = token_match.group(1)
            checks.append((label, "ok", f"{token[:12]}... (len {len(token)})"))
        else:
            checks.append((label, "fail", "SYNC_CLOUD_TOKEN no seteado en .env"))
    else:
        checks.append((label, "skip", "no .env local"))

    # 4. Worker service (OS-specific)
    label = "Worker sync"
    try:
        if cfg.os == "linux":
            status_data = linux_status(cfg, tenant_slug)
        else:
            status_data = windows_status(cfg, tenant_slug)
        if status_data:
            for sub_label, sub_status in status_data.items():
                color = green if sub_status.lower() in ("active", "existe", "ok") else red
                checks.append((f"{label} - {sub_label}", sub_status.lower(), ""))
    except Exception as e:
        checks.append((label, "fail", str(e)))

    # 5. Printer agent (health check en :17777)
    label = "Printer agent"
    try:
        res = subprocess.run(
            ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
             "--max-time", "5", "http://127.0.0.1:17777/health"],
            capture_output=True, text=True,
        )
        code = res.stdout.strip()
        if code == "200":
            detail = "responde en :17777"
            if cfg.os == "windows":
                detail += "; task InventoryArensPrinter existe" if windows_task_exists("InventoryArensPrinter") else "; task InventoryArensPrinter no existe"
            checks.append((label, "ok", detail))
        else:
            detail = f"HTTP {code}"
            if cfg.os == "windows":
                detail += "; task InventoryArensPrinter existe" if windows_task_exists("InventoryArensPrinter") else "; task InventoryArensPrinter no existe"
            checks.append((label, "fail", detail))
    except Exception as e:
        checks.append((label, "skip", str(e)))

    # 5. Last sync activity
    label = "Ultima sync"
    try:
        # Intenta via psql directo
        if shutil.which("psql") and cfg.env_file:
            env = {}
            for line in cfg.env_file.read_text(encoding="utf-8").splitlines():
                if line.startswith("DB_DATABASE="):
                    env["PGDATABASE"] = line.split("=", 1)[1]
                if line.startswith("DB_HOST="):
                    env["PGHOST"] = line.split("=", 1)[1]
                if line.startswith("DB_PORT="):
                    env["PGPORT"] = line.split("=", 1)[1]
                if line.startswith("DB_USERNAME="):
                    env["PGUSER"] = line.split("=", 1)[1]
            res = subprocess.run(
                ["psql", "-tA", "-c",
                 "SELECT MAX(applied_at) FROM sync_inbox WHERE applied_at IS NOT NULL"],
                env={**os.environ, **env}, capture_output=True, text=True, timeout=5,
            )
            last = res.stdout.strip() if res.returncode == 0 else "?"
            checks.append((label, "ok" if last != "?" else "fail", f"ultima aplicada: {last}"))
    except Exception:
        checks.append((label, "skip", "psql no disponible"))

    # Print resultados
    print()
    print(bold("CHECKLIST"))
    n_ok = 0
    n_warn = 0
    n_fail = 0
    for label, status, detail in checks:
        if status == "ok":
            sym = green("OK")
            n_ok += 1
        elif status == "skip":
            sym = yellow("-")
            n_warn += 1
        else:
            sym = red("X")
            n_fail += 1
        detail_str = f"  {dim(detail)}" if detail else ""
        print(f"  {sym} {bold(label)}: {status}{detail_str}")
    print()
    total = len(checks)
    if n_fail == 0 and n_warn == 0:
        ok(f"{n_ok}/{total} checks OK. Todo bien.")
    elif n_fail == 0:
        ok(f"{n_ok}/{total} checks OK. {n_warn} skipped.")
    else:
        warn(f"{n_ok}/{total} checks OK. {n_fail} fallaron. Acciones:")
        for label, status, _ in checks:
            if status == "fail":
                if "token" in label.lower():
                    info("  - inventoryarens install sync (re-emitir)")
                elif "cloud" in label.lower():
                    info("  - revisa la conectividad a https://app.miinventariofacil.com")
                elif "worker" in label.lower() or "timer" in label.lower():
                    if cfg.os == "linux":
                        info(f"  - systemctl --user status {linux_sync_unit_name(tenant_slug)}.timer")
                    else:
                        info(f"  - schtasks /query /tn SistemaInventarioSync-{safe_tenant_slug(tenant_slug)} /fo LIST /v")
                elif "printer" in label.lower():
                    if cfg.os == "linux":
                        info("  - systemctl --user status inventoryarens-printer.service")
                    else:
                        info("  - inventoryarens install printer")
                elif "db" in label.lower():
                    info("  - revisa la config DB_ en .env")

    return 1 if n_fail > 0 else 0


def cmd_logs(args, cfg: Config) -> int:
    target = args.target or "sync"
    tenant = getattr(args, "tenant", None) or "mi-empresa"
    safe_tenant = safe_tenant_slug(tenant)
    if cfg.os == "linux":
        if target == "sync":
            log_paths = [
                cfg.home / ".local/share/inventoryarens" / f"sync-{safe_tenant}.log",
                cfg.home / ".local/share/inventoryarens" / "sync.log",
                Path("/var/log/inventarioarens-sync.log"),
            ]
        else:
            log_paths = [
                cfg.home / ".local/share/inventoryarens" / f"{target}.log",
                Path("/var/log/inventoryarens") / f"{target}.log",
            ]
    else:
        if target == "sync":
            log_paths = [cfg.repo_dir / "storage" / "logs" / f"sync-worker-{safe_tenant}.log"]
        else:
            log_paths = [
                Path(os.environ.get("APPDATA", "")) / "inventoryarens" / f"{target}.log",
            ]

    # Si no hay log, intentar journald/systemd para printer/sync.
    if cfg.os == "linux":
        journald_unit = (
            f"{linux_sync_unit_name(tenant)}.service"
            if target == "sync"
            else f"inventoryarens-{target}.service"
        )
        if not any(p.exists() for p in log_paths):
            info(f"No hay log file. Probando journalctl -u {journald_unit} ...")
            try:
                subprocess.run(["journalctl", "-u", journald_unit, "-f", "--no-pager", "-n", "50"])
            except KeyboardInterrupt:
                pass
            return 0

    found = next((p for p in log_paths if p.exists()), None)
    if not found:
        err(f"No encontre log para {target} en: {[str(p) for p in log_paths]}")
        info("Pista: el log se crea cuando el worker corre por primera vez.")
        return 1

    info(f"Tail de {found} (Ctrl+C para salir):")
    try:
        subprocess.run(["tail", "-f", str(found)])
    except KeyboardInterrupt:
        pass
    return 0


def cmd_token_rotate(args, cfg: Config) -> int:
    step("Re-emitiendo token (sin reinstalar servicios)")
    tenant = args.tenant or "mi-empresa"
    user_email = args.user or "gabo@gabo.com"
    node_name = args.node_name or f"{tenant}-local"
    node_code = args.node_code or f"LOCAL-{tenant.upper()}"
    try:
        result = issue_token_on_vps(cfg, tenant, user_email, node_name, node_code)
    except Exception as e:
        err(f"Error: {e}")
        return 1
    ok(f"Nuevo token: {result['token'][:20]}...")
    write_sync_worker_config(cfg, tenant, result["token"], node_name, node_code, args.interval or 15)

    if args.write_env:
        try:
            write_local_env_token(cfg, tenant, result["token"])
        except Exception as e:
            err(f"Error escribiendo .env: {e}")
            return 1
    else:
        info("(skip --write-env deshabilitado)")

    return 0


def cmd_recover_tenant(args, cfg: Config) -> int:
    """
    Reconstruye un tenant local desde la nube usando el token ya guardado por el wizard.
    No borra tablas, no ejecuta migrate:fresh y no toca otros tenants.
    """
    try:
        tenant_slug, tenant_config = choose_sync_tenant(cfg, args.tenant or "")
    except RuntimeError as exc:
        err(str(exc))
        return 1

    tenant_name = args.tenant_name or tenant_slug_to_name(tenant_slug)
    if not args.tenant_name and sys.stdin.isatty():
        tenant_name = prompt_value("Nombre local de la empresa", tenant_name)

    user_email = args.user or ""
    if not user_email and sys.stdin.isatty():
        user_email = prompt_value("Email del usuario local inicial", "admin@local.test")
    if not user_email:
        err("Debes indicar --user o responder el email del usuario local inicial.")
        return 1

    user_name = args.user_name or tenant_name
    if not args.user_name and sys.stdin.isatty():
        user_name = prompt_value("Nombre del usuario local inicial", user_name)

    password = args.password or ""
    if not password and sys.stdin.isatty():
        password = getpass.getpass("Password local temporal [gabo1234]: ") or "gabo1234"
    if not password:
        err("Debes indicar --password o responder el password local temporal.")
        return 1

    step("Recuperacion local desde la nube")
    info("Este flujo NO borra datos. Solo crea/prepara el tenant local y baja eventos desde la nube.")
    info(f"Tenant: {tenant_slug}")
    info(f"Token configurado: {'si' if tenant_config.get('token') else 'no'}")
    info(f"Cloud: {tenant_config.get('cloud_url', 'https://app.miinventariofacil.com/api')}")
    info(f"DB local: {get_database_name(cfg)}")

    summary_before = get_tenant_local_summary(cfg, tenant_slug)
    if summary_before.get("exists"):
        counts = summary_before.get("counts") or {}
        non_zero = {k: v for k, v in counts.items() if v}
        warn(f"El tenant ya existe localmente: {summary_before.get('tenant_name')} (id {summary_before.get('tenant_id')}).")
        if non_zero:
            info("Conteos actuales: " + ", ".join(f"{k}={v}" for k, v in non_zero.items()))
        if not args.yes and not prompt_yes_no("Continuar y sincronizar encima sin borrar nada", default=True):
            return 1
    elif not args.yes and not prompt_yes_no("Crear/preparar este tenant local y descargar datos", default=True):
        return 1

    env = {"SYNC_BOOTSTRAP_PASSWORD": password}

    if not args.skip_migrate:
        step("[1/4] Aplicando migraciones pendientes")
        proc = run_artisan(cfg, ["migrate", "--force"], capture=True, check=False)
        if proc.returncode != 0:
            err(proc.stderr or proc.stdout or "migrate fallo")
            return proc.returncode
        ok("Migraciones verificadas.")

    step("[2/4] Preparando tenant local")
    prepare_args = [
        "sync:prepare-local",
        tenant_slug,
        tenant_name,
        user_email,
        "--user-name",
        user_name,
    ]
    proc = run_artisan(cfg, prepare_args, env=env, capture=True, check=False)
    if proc.returncode != 0:
        err(proc.stderr or proc.stdout or "sync:prepare-local fallo")
        return proc.returncode
    if proc.stdout.strip():
        print(proc.stdout.strip())

    step("[3/4] Descargando y aplicando eventos")
    cycles = max(1, args.cycles)
    limit = min(max(1, args.limit), 100)
    if args.limit > 100:
        warn("El API cloud acepta maximo limit=100; usare 100 para esta recuperacion.")
    for cycle in range(1, cycles + 1):
        info(f"Ronda {cycle}/{cycles}")
        proc = run_artisan(cfg, ["sync:run", tenant_slug, "--limit", str(limit)], capture=True, check=False)
        if proc.stdout.strip():
            print(proc.stdout.strip())
        if proc.returncode != 0:
            output = (proc.stderr or proc.stdout or "").strip()
            if "Sincronizacion ejecutada." not in output:
                err(output or "sync:run fallo")
                return proc.returncode
            warn("La ronda sincronizo datos, pero algunos eventos quedaron para reintento por dependencias temporales.")

        reset_count = reset_failed_sync_inbox_for_recovery(cfg, tenant_slug)
        if reset_count:
            info(f"Reintentando {reset_count} eventos fallidos despues de recibir mas dependencias.")

        proc = run_artisan(cfg, ["sync:apply-inbox", tenant_slug, "--limit", str(limit)], capture=True, check=False)
        if proc.stdout.strip():
            print(proc.stdout.strip())
        if proc.returncode != 0:
            warn((proc.stderr or proc.stdout or "sync:apply-inbox fallo").strip())

        proc = run_artisan(cfg, ["images:download", f"--tenant={tenant_slug}", "--limit", str(limit)], capture=True, check=False)
        if proc.stdout.strip():
            print(proc.stdout.strip())
        if proc.returncode != 0:
            warn(proc.stderr.strip() or proc.stdout.strip() or "images:download no pudo completar; puedes repetir luego.")

    step("[4/4] Resumen local")
    summary_after = get_tenant_local_summary(cfg, tenant_slug)
    if summary_after.get("exists"):
        counts = summary_after.get("counts") or {}
        for key in sorted(counts.keys()):
            print(f"  - {key}: {counts[key]}")
    else:
        warn("No se pudo confirmar el tenant local despues de la recuperacion.")

    failed_count = get_failed_sync_inbox_count(cfg, tenant_slug)
    if failed_count:
        warn(f"Quedaron {failed_count} eventos en inbox con fallo. Repite el recovery luego o revisa el log de sync.")

    ok("Recuperacion finalizada. Puedes repetir este comando si faltan eventos o imagenes.")
    info(f"Verifica el worker con: inventoryarens status --tenant {tenant_slug}")
    return 1 if failed_count else 0


def cmd_update(args, cfg: Config) -> int:
    if not (cfg.repo_dir / ".git").exists():
        err(f"{cfg.repo_dir} no es un git repo")
        return 1
    step("git pull")
    res = subprocess.run(
        ["git", "-C", str(cfg.repo_dir), "pull", "--rebase"],
        capture_output=True, text=True,
    )
    print(res.stdout)
    if res.returncode != 0:
        err(f"git pull fallo: {res.stderr}")
        return 1
    ok("git pull OK")

    step("composer install")
    run(["composer", "install", "--no-dev", "--optimize-autoloader"],
        cwd=str(cfg.repo_dir), check=False)
    ok("composer install OK")

    step("migrate")
    run([str(cfg.php_bin), "artisan", "migrate", "--force"],
        cwd=str(cfg.repo_dir), check=False)

    step("Reiniciando worker")
    if cfg.os == "linux":
        run_silent(["systemctl", "--user", "restart", "inventoryarens-sync.timer"])
    else:
        run_silent(["schtasks", "/run", "/tn", "InventoryArensSync"])
    ok("Worker reiniciado")
    return 0


def cmd_worker(args, cfg: Config) -> int:
    if getattr(args, "all", False):
        tenants = configured_tenants(cfg)
        if not tenants:
            err("No hay tenants configurados en sync-config.json.")
            return 1
        final_rc = 0
        for tenant in tenants:
            rc = cmd_worker(argparse.Namespace(
                action=args.action,
                tenant=tenant,
                event_type=getattr(args, "event_type", ""),
                limit=getattr(args, "limit", 100),
                all=False,
            ), cfg)
            if rc != 0:
                final_rc = rc
        return final_rc

    tenant_slug, _tenant_config = choose_sync_tenant(cfg, args.tenant or "")
    action = args.action

    step(f"Worker sync: {action} ({tenant_slug})")
    if action == "refresh-and-retry":
        rc = run_worker_action(cfg, tenant_slug, "restart")
        if rc != 0:
            err("No se pudo reiniciar el worker.")
            return rc
        ok("Worker reiniciado.")
        reset = reset_sync_inbox_events(cfg, tenant_slug, event_type=args.event_type or "")
        if not reset.get("ok"):
            err(f"No se pudieron preparar eventos fallidos: {reset.get('message')}")
            return 1
        ok(f"Eventos fallidos preparados para reintento: {reset.get('reset', 0)}")
        return apply_inbox(cfg, tenant_slug, args.limit)

    rc = run_worker_action(cfg, tenant_slug, action)
    if rc == 0:
        ok("Accion completada.")
    else:
        err(f"La accion fallo con codigo {rc}.")
    return rc


def cmd_sync(args, cfg: Config) -> int:
    if getattr(args, "all", False):
        if args.action == "retry-inbox":
            err("--all no aplica con retry-inbox porque el ID pertenece a un tenant especifico.")
            return 1
        tenants = configured_tenants(cfg)
        if not tenants:
            err("No hay tenants configurados en sync-config.json.")
            return 1
        final_rc = 0
        for tenant in tenants:
            rc = cmd_sync(argparse.Namespace(
                action=args.action,
                tenant=tenant,
                limit=getattr(args, "limit", 100),
                event_type=getattr(args, "event_type", ""),
                id=getattr(args, "id", 0),
                all=False,
            ), cfg)
            if rc != 0:
                final_rc = rc
        return final_rc

    tenant_slug, _tenant_config = choose_sync_tenant(cfg, args.tenant or "")
    limit = max(1, min(int(args.limit or 100), 100))

    if args.action == "run":
        step(f"Sincronizacion manual ({tenant_slug})")
        return run_sync_once(cfg, tenant_slug, limit)

    if args.action == "apply-inbox":
        step(f"Aplicar inbox pendiente ({tenant_slug})")
        return apply_inbox(cfg, tenant_slug, limit)

    if args.action == "retry-failed":
        step(f"Reintentar inbox fallido ({tenant_slug})")
        reset = reset_sync_inbox_events(cfg, tenant_slug, event_type=args.event_type or "")
        if not reset.get("ok"):
            err(f"No se pudieron preparar eventos fallidos: {reset.get('message')}")
            return 1
        ok(f"Eventos preparados: {reset.get('reset', 0)}")
        return apply_inbox(cfg, tenant_slug, limit)

    if args.action == "retry-inbox":
        step(f"Reintentar inbox #{args.id} ({tenant_slug})")
        reset = reset_sync_inbox_events(cfg, tenant_slug, inbox_id=int(args.id))
        if not reset.get("ok"):
            err(f"No se pudo preparar inbox #{args.id}: {reset.get('message')}")
            return 1
        ok(f"Eventos preparados: {reset.get('reset', 0)}")
        return apply_inbox(cfg, tenant_slug, limit)

    err(f"Accion sync no soportada: {args.action}")
    return 1


def cmd_images(args, cfg: Config) -> int:
    if getattr(args, "all", False):
        if args.action == "emit":
            err("--all no aplica con images emit porque requiere un SKU por tenant.")
            return 1
        tenants = configured_tenants(cfg)
        if not tenants:
            err("No hay tenants configurados en sync-config.json.")
            return 1
        final_rc = 0
        for tenant in tenants:
            rc = cmd_images(argparse.Namespace(
                action=args.action,
                tenant=tenant,
                limit=getattr(args, "limit", 100),
                product_sku=getattr(args, "product_sku", ""),
                all=False,
            ), cfg)
            if rc != 0:
                final_rc = rc
        return final_rc

    tenant_slug, _tenant_config = choose_sync_tenant(cfg, args.tenant or "")
    limit = max(1, min(int(args.limit or 100), 100))

    if args.action == "download":
        step(f"Descargar imagenes faltantes ({tenant_slug})")
        proc = run_artisan(cfg, ["images:download", f"--tenant={tenant_slug}", "--limit", str(limit)], capture=True, check=False)
        if proc.stdout:
            print(proc.stdout.strip())
        if proc.stderr:
            print(proc.stderr.strip(), file=sys.stderr)
        return proc.returncode

    if args.action == "emit":
        step(f"Emitir sync de imagen por SKU ({tenant_slug})")
        if not args.product_sku:
            err("Debes indicar --product-sku.")
            return 1
        proc = run_artisan(
            cfg,
            ["images:emit-sync", f"--tenant={tenant_slug}", f"--product-sku={args.product_sku}"],
            capture=True,
            check=False,
        )
        if proc.stdout:
            print(proc.stdout.strip())
        if proc.stderr:
            print(proc.stderr.strip(), file=sys.stderr)
        return proc.returncode

    if args.action == "retry-failed":
        step(f"Reintentar eventos de imagen fallidos ({tenant_slug})")
        reset = reset_sync_inbox_events(cfg, tenant_slug, event_type="product.image.uploaded")
        if not reset.get("ok"):
            err(f"No se pudieron preparar imagenes fallidas: {reset.get('message')}")
            return 1
        ok(f"Eventos de imagen preparados: {reset.get('reset', 0)}")
        rc = apply_inbox(cfg, tenant_slug, limit)
        if rc != 0:
            return rc
        return cmd_images(argparse.Namespace(action="download", tenant=tenant_slug, limit=limit), cfg)

    err(f"Accion de imagenes no soportada: {args.action}")
    return 1


def cmd_doctor(args, cfg: Config) -> int:
    tenants = configured_tenants(cfg)
    if getattr(args, "all", False):
        targets = tenants
    else:
        target, _tenant_config = choose_sync_tenant(cfg, args.tenant or "")
        targets = [target]

    if not targets:
        err("No hay tenants configurados. Ejecuta primero inventoryarens wizard.")
        return 1

    final_rc = 0
    for tenant in targets:
        step(f"Doctor tecnico ({tenant})")
        failed_count = get_failed_sync_inbox_count(cfg, tenant)
        print(f"Inbox fallidos: {failed_count}")

        worker_rc = run_worker_action(cfg, tenant, "status")
        worker_ok = worker_rc == 0
        if worker_ok:
            ok("Worker consultado.")
        else:
            warn("No se pudo consultar el worker.")
            final_rc = 1

        if failed_count > 0:
            warn("Hay eventos fallidos pendientes.")
            final_rc = 1
        else:
            ok("No hay eventos fallidos.")

        if not args.fix:
            if failed_count > 0:
                info(f"Para reparar: inventoryarens sync retry-failed --tenant {tenant}")
            info(f"Para reiniciar worker: inventoryarens worker restart --tenant {tenant}")
            continue

        step(f"Reparacion segura ({tenant})")
        rc = run_worker_action(cfg, tenant, "restart")
        if rc == 0:
            ok("Worker reiniciado.")
        else:
            warn(f"No se pudo reiniciar worker (rc={rc}).")
            final_rc = 1

        if failed_count > 0:
            reset = reset_sync_inbox_events(cfg, tenant, event_type=args.event_type or "")
            if reset.get("ok"):
                ok(f"Eventos preparados: {reset.get('reset', 0)}")
                rc = apply_inbox(cfg, tenant, args.limit)
                if rc != 0:
                    final_rc = rc
            else:
                err(f"No se pudieron preparar eventos: {reset.get('message')}")
                final_rc = 1
    return final_rc


def redact_sync_config(data: dict) -> dict:
    clone = json.loads(json.dumps(data))
    for tenant in (clone.get("tenants") or {}).values():
        token = str(tenant.get("token") or "")
        if token:
            tenant["token"] = f"{token[:8]}...redacted...len{len(token)}"
    return clone


def collect_support_text(cfg: Config, tenant_slug: str) -> str:
    lines = [
        f"Fecha: {datetime.now().isoformat(timespec='seconds')}",
        f"OS: {cfg.os}",
        f"Repo: {cfg.repo_dir}",
        f"Tenant: {tenant_slug}",
        f"PHP: {cfg.php_bin}",
        f"DB: {get_database_name(cfg)}",
        f"Inbox fallidos: {get_failed_sync_inbox_count(cfg, tenant_slug)}",
        "",
        "Resumen local:",
    ]
    summary = get_tenant_local_summary(cfg, tenant_slug)
    lines.append(json.dumps(summary, indent=2, ensure_ascii=False))
    return "\n".join(lines) + "\n"


def cmd_support(args, cfg: Config) -> int:
    tenant_slug, _tenant_config = choose_sync_tenant(cfg, args.tenant or "")
    requested_out_dir = Path(args.output) if args.output else (cfg.repo_dir / "storage" / "app" / "support-bundles")
    fallback_out_dir = cfg.repo_dir / "storage" / "app" / "support-bundles"
    try:
        requested_out_dir.mkdir(parents=True, exist_ok=True)
        probe = requested_out_dir / ".inventoryarens-write-test"
        probe.write_text("ok", encoding="utf-8")
        probe.unlink(missing_ok=True)
        out_dir = requested_out_dir
    except Exception as exc:
        warn(f"No se puede escribir en {requested_out_dir}: {exc}")
        fallback_out_dir.mkdir(parents=True, exist_ok=True)
        out_dir = fallback_out_dir
        info(f"Usando carpeta segura: {out_dir}")
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    bundle_path = out_dir / f"support-{safe_tenant_slug(tenant_slug)}-{stamp}.zip"

    step(f"Generando paquete de soporte ({tenant_slug})")
    with zipfile.ZipFile(bundle_path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        zf.writestr("diagnostico.txt", collect_support_text(cfg, tenant_slug))
        zf.writestr(
            "sync-config.redacted.json",
            json.dumps(redact_sync_config(read_sync_worker_config(cfg)), indent=2, ensure_ascii=False) + "\n",
        )

        log_candidates = []
        if cfg.os == "windows":
            log_candidates.extend([
                cfg.repo_dir / "storage" / "logs" / f"sync-worker-{tenant_slug}.log",
                cfg.repo_dir / "storage" / "logs" / "laravel.log",
                Path(os.environ.get("APPDATA", "")) / "inventoryarens" / "printer.log",
            ])
        else:
            safe_tenant = safe_tenant_slug(tenant_slug)
            log_candidates.extend([
                cfg.home / ".local/share/inventoryarens" / f"sync-{safe_tenant}.log",
                cfg.home / ".local/share/inventoryarens" / "printer.log",
                cfg.repo_dir / "storage" / "logs" / "laravel.log",
            ])
        for path in log_candidates:
            if path.exists() and path.is_file():
                zf.write(path, f"logs/{path.name}")

    ok(f"Paquete generado: {bundle_path}")
    info("No incluye tokens completos; sync-config va redactado.")
    return 0


def cmd_toolbox(args, cfg: Config) -> int:
    print()
    print(bold("INVENTARIOARENS Toolbox"))
    info("Herramienta tecnica interactiva. No borra datos.")

    while True:
        print()
        print("1. Diagnostico rapido")
        print("2. Worker sync: estado")
        print("3. Worker sync: reiniciar")
        print("4. Sync: correr ahora")
        print("5. Sync: reintentar inbox fallidos")
        print("6. Sync: reintentar inbox por ID")
        print("7. Imagenes: reintentar fallidas + descargar")
        print("8. Imagenes: emitir sync por SKU")
        print("9. Recuperar tenant desde nube")
        print("10. Doctor tecnico")
        print("11. Generar paquete de soporte")
        print("0. Salir")
        choice = prompt_value("Opcion", "1").strip()

        try:
            if choice == "0":
                return 0
            if choice == "1":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_status(argparse.Namespace(tenant=tenant), cfg)
            elif choice == "2":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_worker(argparse.Namespace(action="status", tenant=tenant, event_type="", limit=100), cfg)
            elif choice == "3":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_worker(argparse.Namespace(action="restart", tenant=tenant, event_type="", limit=100), cfg)
            elif choice == "4":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_sync(argparse.Namespace(action="run", tenant=tenant, limit=100, event_type="", id=0), cfg)
            elif choice == "5":
                tenant = prompt_value("Tenant", args.tenant or "")
                event_type = prompt_value("Tipo de evento opcional", "")
                cmd_sync(argparse.Namespace(action="retry-failed", tenant=tenant, limit=100, event_type=event_type, id=0), cfg)
            elif choice == "6":
                tenant = prompt_value("Tenant", args.tenant or "")
                inbox_id = int(prompt_value("ID de sync_inbox", "0"))
                cmd_sync(argparse.Namespace(action="retry-inbox", tenant=tenant, limit=100, event_type="", id=inbox_id), cfg)
            elif choice == "7":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_images(argparse.Namespace(action="retry-failed", tenant=tenant, limit=100, product_sku=""), cfg)
            elif choice == "8":
                tenant = prompt_value("Tenant", args.tenant or "")
                sku = prompt_value("SKU del producto", "")
                cmd_images(argparse.Namespace(action="emit", tenant=tenant, limit=100, product_sku=sku), cfg)
            elif choice == "9":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_recover_tenant(argparse.Namespace(
                    tenant=tenant,
                    tenant_name="",
                    user="",
                    user_name="",
                    password="",
                    cycles=5,
                    limit=100,
                    skip_migrate=False,
                    yes=False,
                ), cfg)
            elif choice == "10":
                tenant = prompt_value("Tenant", args.tenant or "")
                fix = prompt_yes_no("Intentar reparacion segura", False)
                cmd_doctor(argparse.Namespace(tenant=tenant, all=False, fix=fix, event_type="", limit=100), cfg)
            elif choice == "11":
                tenant = prompt_value("Tenant", args.tenant or "")
                cmd_support(argparse.Namespace(tenant=tenant, output=""), cfg)
            else:
                warn("Opcion no reconocida.")
        except KeyboardInterrupt:
            print()
            return 130
        except Exception as exc:
            err(str(exc))


# -----------------------------------------------------------------------------
# CLI parser
# -----------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="inventoryarens",
        description=f"CLI de operaciones de INVENTARIOARENS v{VERSION}",
    )
    p.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    p.add_argument("--no-color", action="store_true", help="Desactiva color ANSI")
    p.add_argument("--repo", type=Path, help="Path al repo Laravel (default: detecta subiendo parents desde cwd)")

    sub = p.add_subparsers(dest="command", required=True, metavar="COMMAND")

    # toolbox
    ptool = sub.add_parser("toolbox", help="Menu interactivo para tecnico")
    ptool.add_argument("--tenant", default="", help="Tenant sugerido para el menu")
    ptool.set_defaults(func=cmd_toolbox)

    # install sync
    pi = sub.add_parser("install", help="Instala componentes (sync | printer)")
    pi_sub = pi.add_subparsers(dest="subcommand", required=True)
    pi_sync = pi_sub.add_parser("sync", help="Instala worker de sync con auto-start")
    pi_sync.add_argument("--tenant", default="mi-empresa", help="Slug del tenant (default: mi-empresa)")
    pi_sync.add_argument("--user", default="gabo@gabo.com", help="Email del user (default: gabo@gabo.com)")
    pi_sync.add_argument("--node-name", default="", help="Nombre visible del nodo/equipo")
    pi_sync.add_argument("--node-code", default="", help="Codigo unico del nodo")
    pi_sync.add_argument("--interval", type=int, default=15, help="Intervalo del worker en segundos (default: 15)")
    pi_sync.add_argument("--interactive", action="store_true", help="Preguntar tenant, usuario y nodo paso a paso")
    pi_sync.add_argument("--write-env", action="store_true", default=True, help="Escribir token en .env (default: true)")
    pi_sync.add_argument("--no-write-env", dest="write_env", action="store_false")
    pi_sync.set_defaults(func=cmd_install_sync)
    pi_printer = pi_sub.add_parser("printer", help="Instala printer agent (Fase 2)")
    pi_printer.add_argument("--port", type=int, default=17777, help="Puerto del agente (default: 17777)")
    pi_printer.set_defaults(func=cmd_install_printer)

    # uninstall
    pu = sub.add_parser("uninstall", help="Desinstala componentes")
    pu_sub = pu.add_subparsers(dest="subcommand", required=True)
    pu_sync = pu_sub.add_parser("sync", help="Detiene + elimina auto-start")
    pu_sync.add_argument("--tenant", default="mi-empresa", help="Slug del tenant a desinstalar")
    pu_sync.add_argument("--purge-env", action="store_true", help="Borrar token del .env")
    pu_sync.set_defaults(func=cmd_uninstall_sync)
    pu_printer = pu_sub.add_parser("printer", help="Detiene + elimina el printer agent")
    pu_printer.set_defaults(func=cmd_uninstall_printer)

    # status
    ps = sub.add_parser("status", help="Health check del sistema")
    ps.add_argument("--tenant", default="mi-empresa", help="Slug del tenant para revisar worker local")
    ps.add_argument("--all", action="store_true", help="Revisar todos los tenants configurados en esta PC")
    ps.set_defaults(func=cmd_status)

    # wizard
    pw = sub.add_parser("wizard", help="Asistente interactivo para agregar una empresa a esta PC")
    pw.add_argument("--tenant", default="")
    pw.add_argument("--user", default="")
    pw.add_argument("--node-name", default="")
    pw.add_argument("--node-code", default="")
    pw.add_argument("--interval", type=int, default=15)
    pw.set_defaults(func=cmd_wizard)

    # logs
    pl = sub.add_parser("logs", help="Tail de logs")
    pl_sub = pl.add_subparsers(dest="subcommand", required=True)
    pl_sync = pl_sub.add_parser("sync", help="Logs del worker de sync")
    pl_sync.add_argument("--tenant", default="mi-empresa", help="Slug del tenant")
    pl_sync.set_defaults(func=cmd_logs, target="sync")
    pl_printer = pl_sub.add_parser("printer", help="Logs del printer agent")
    pl_printer.set_defaults(func=cmd_logs, target="printer")

    # token
    pt = sub.add_parser("token", help="Operaciones sobre el token de sync")
    pt_sub = pt.add_subparsers(dest="subcommand", required=True)
    pt_rotate = pt_sub.add_parser("rotate", help="Re-emite token (no reinstala servicios)")
    pt_rotate.add_argument("--tenant", default="mi-empresa")
    pt_rotate.add_argument("--user", default="gabo@gabo.com")
    pt_rotate.add_argument("--node-name", default="")
    pt_rotate.add_argument("--node-code", default="")
    pt_rotate.add_argument("--interval", type=int, default=15)
    pt_rotate.add_argument("--write-env", action="store_true", default=True)
    pt_rotate.add_argument("--no-write-env", dest="write_env", action="store_false")
    pt_rotate.set_defaults(func=cmd_token_rotate)

    # recover
    pr = sub.add_parser("recover", help="Recupera datos locales desde la nube")
    pr_sub = pr.add_subparsers(dest="subcommand", required=True)
    pr_tenant = pr_sub.add_parser("tenant", help="Reconstruye un tenant local usando el token del worker")
    pr_tenant.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    pr_tenant.add_argument("--tenant-name", default="", help="Nombre local de la empresa")
    pr_tenant.add_argument("--user", default="", help="Email del usuario local inicial")
    pr_tenant.add_argument("--user-name", default="", help="Nombre del usuario local inicial")
    pr_tenant.add_argument("--password", default="", help="Password local temporal del usuario inicial")
    pr_tenant.add_argument("--cycles", type=int, default=5, help="Rondas de sync/apply/images (default: 5)")
    pr_tenant.add_argument("--limit", type=int, default=100, help="Eventos por ronda, maximo cloud 100 (default: 100)")
    pr_tenant.add_argument("--skip-migrate", action="store_true", help="No ejecutar php artisan migrate --force")
    pr_tenant.add_argument("--yes", action="store_true", help="No preguntar confirmacion interactiva")
    pr_tenant.set_defaults(func=cmd_recover_tenant)

    # update
    pu2 = sub.add_parser("update", help="git pull + composer + migrate + restart")
    pu2.set_defaults(func=cmd_update)

    # worker
    pwk = sub.add_parser("worker", help="Control del worker de sincronizacion")
    pwk.add_argument("action", choices=["status", "start", "stop", "restart", "run-now", "refresh-and-retry"])
    pwk.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    pwk.add_argument("--all", action="store_true", help="Ejecuta la accion en todos los tenants configurados")
    pwk.add_argument("--event-type", default="", help="Filtra eventos fallidos por tipo al usar refresh-and-retry")
    pwk.add_argument("--limit", type=int, default=100, help="Eventos a aplicar al reintentar (max 100)")
    pwk.set_defaults(func=cmd_worker)

    # sync
    psync = sub.add_parser("sync", help="Operaciones manuales de sincronizacion")
    psync.add_argument("action", choices=["run", "apply-inbox", "retry-failed", "retry-inbox"])
    psync.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    psync.add_argument("--all", action="store_true", help="Ejecuta la accion en todos los tenants configurados")
    psync.add_argument("--limit", type=int, default=100, help="Eventos por corrida (max 100)")
    psync.add_argument("--event-type", default="", help="Filtra eventos fallidos por tipo")
    psync.add_argument("--id", type=int, default=0, help="ID de sync_inbox para retry-inbox")
    psync.set_defaults(func=cmd_sync)

    # images
    pimg = sub.add_parser("images", help="Herramientas de sincronizacion de imagenes")
    pimg.add_argument("action", choices=["download", "emit", "retry-failed"])
    pimg.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    pimg.add_argument("--all", action="store_true", help="Ejecuta la accion en todos los tenants configurados")
    pimg.add_argument("--limit", type=int, default=100, help="Imagenes/eventos a procesar (max 100)")
    pimg.add_argument("--product-sku", default="", help="SKU del producto para images emit")
    pimg.set_defaults(func=cmd_images)

    # doctor
    pdoc = sub.add_parser("doctor", help="Diagnostico tecnico con reparacion segura opcional")
    pdoc.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    pdoc.add_argument("--all", action="store_true", help="Diagnosticar todos los tenants configurados")
    pdoc.add_argument("--fix", action="store_true", help="Reinicia worker y reintenta eventos fallidos")
    pdoc.add_argument("--event-type", default="", help="Filtra eventos fallidos al reparar")
    pdoc.add_argument("--limit", type=int, default=100, help="Eventos a aplicar al reparar (max 100)")
    pdoc.set_defaults(func=cmd_doctor)

    # support
    psup = sub.add_parser("support", help="Genera paquetes de soporte")
    psup_sub = psup.add_subparsers(dest="subcommand", required=True)
    psup_bundle = psup_sub.add_parser("bundle", help="Genera ZIP con diagnostico y logs sin tokens")
    psup_bundle.add_argument("--tenant", default="", help="Slug del tenant. Si se omite, permite elegir desde sync-config.json")
    psup_bundle.add_argument("--output", default="", help="Carpeta destino del ZIP")
    psup_bundle.set_defaults(func=cmd_support)

    return p


# -----------------------------------------------------------------------------
# Entry point
# -----------------------------------------------------------------------------

def main(argv: Optional[list[str]] = None) -> int:
    global USE_COLOR
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.no_color:
        USE_COLOR = False
    cfg = Config.from_env(repo_override=args.repo)

    # Lock no-bloqueante
    lock_fd = acquire_lock(cfg)
    if lock_fd is None:
        warn("Otra instancia de inventoryarens esta corriendo. Abortando.")
        return 1
    try:
        return args.func(args, cfg)
    finally:
        release_lock(lock_fd)


if __name__ == "__main__":
    sys.exit(main())
